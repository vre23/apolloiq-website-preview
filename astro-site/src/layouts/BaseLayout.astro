---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
}

const { title, description = 'AI & Automation for Modern Healthcare', ogTitle } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{title} | ApolloIQ</title>
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={description} />
  <link rel="icon" type="image/png" href={`${base}images/686e911b4fffa681e585469e_creier-gradient.png`} />
  <link rel="apple-touch-icon" href={`${base}images/686e917cee44d5055d111740_creier-gradient_(1).png`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Roboto:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
