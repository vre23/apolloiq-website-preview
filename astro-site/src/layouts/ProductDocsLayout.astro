---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface SidebarItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

interface Props {
  title: string;
  description?: string;
  sidebarItems: SidebarItem[];
  heroTitle: string;
  heroSubtitle?: string;
  heroIcon?: string;
  activePath?: string;
  helpCentreHref?: string;
  helpCentreDescription?: string;
}

const { title, description, sidebarItems, heroTitle, heroSubtitle, heroIcon, activePath, helpCentreHref, helpCentreDescription } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <Nav />

  <!-- Page Hero -->
  <section class="pdl-hero">
    <div class="container-site">
      <div class="pdl-hero-top-row">
        <div class="pdl-hero-title-row">
          {heroIcon && <img src={heroIcon} alt="" class="pdl-hero-icon" />}
          <h1 class="pdl-hero-title">{heroTitle}</h1>
        </div>
        {helpCentreHref && (
          <a href={helpCentreHref} class="pdl-help-centre-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span class="pdl-help-centre-label">Help Centre</span>
            {helpCentreDescription && <span class="pdl-help-centre-desc">{helpCentreDescription}</span>}
          </a>
        )}
      </div>
      {heroSubtitle && <p class="pdl-hero-subtitle">{heroSubtitle}</p>}
    </div>
  </section>

  <!-- Sidebar + Content -->
  <div class="pdl-wrapper">
    <div class="container-site">
      <div class="pdl-grid">
        <!-- Left Sidebar -->
        <aside class="pdl-sidebar" id="pdl-sidebar">
          <button class="pdl-sidebar-toggle" id="sidebar-toggle" type="button" aria-label="Toggle sidebar">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>Menu</span>
          </button>
          <nav class="pdl-sidebar-nav" id="sidebar-nav" aria-label="Page navigation">
            {sidebarItems.map((item) => {
              const isUrlLink = !item.href.startsWith('#');
              const isActive = isUrlLink && currentPath.replace(/\/$/, '') === item.href.replace(/\/$/, '');
              return (
                <div class="pdl-sidebar-group">
                  <a href={item.href} class={`pdl-sidebar-link pdl-sidebar-link--parent${isActive ? ' active' : ''}`} data-section={item.href.startsWith('#') ? item.href.replace('#', '') : ''}>
                    {item.label}
                  </a>
                  {item.children && item.children.length > 0 && (
                    <div class="pdl-sidebar-children">
                      {item.children.map((child) => {
                        const childIsUrl = !child.href.startsWith('#');
                        const childIsActive = childIsUrl && currentPath.replace(/\/$/, '') === child.href.replace(/\/$/, '');
                        return (
                          <a href={child.href} class={`pdl-sidebar-link pdl-sidebar-link--child${childIsActive ? ' active' : ''}`} data-section={child.href.startsWith('#') ? child.href.replace('#', '') : ''}>
                            {child.label}
                          </a>
                        );
                      })}
                    </div>
                  )}
                </div>
              );
            })}
          </nav>
        </aside>

        <!-- Main Content -->
        <main class="pdl-content">
          <slot />
        </main>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .pdl-hero {
    padding: 3.5rem 0 2rem;
    background: linear-gradient(135deg, #f8faff 0%, #f0f7ff 50%, #f5fdf9 100%);
    border-bottom: 1px solid var(--color-brand-grey-border);
  }

  .pdl-hero-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .pdl-hero-title-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .pdl-help-centre-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--color-brand-blue);
    color: #fff;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
    white-space: nowrap;
    box-shadow: 0 1px 3px rgba(44, 112, 235, 0.2);
  }

  .pdl-help-centre-link:hover {
    background: var(--color-brand-blue-hover, #1b5ad4);
    box-shadow: 0 4px 12px rgba(44, 112, 235, 0.3);
  }

  .pdl-help-centre-link svg {
    flex-shrink: 0;
  }

  .pdl-help-centre-label {
    font-weight: 600;
  }

  .pdl-help-centre-desc {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 400;
    padding-left: 0.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
  }

  .pdl-hero-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .pdl-hero-title {
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.15;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .pdl-hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.6;
    max-width: 640px;
  }

  /* ── Wrapper ── */
  .pdl-wrapper {
    padding: 2.5rem 0 5rem;
    min-height: 60vh;
  }

  .pdl-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Sidebar ── */
  .pdl-sidebar {
    position: sticky;
    top: 88px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 1rem;
  }

  .pdl-sidebar-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-brand-grey-bg);
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 10px;
    color: var(--color-brand-black);
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-roboto);
    cursor: pointer;
    margin-bottom: 0.5rem;
    transition: background 0.2s;
  }
  .pdl-sidebar-toggle:hover {
    background: var(--color-brand-grey-border);
  }

  .pdl-sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 2px solid var(--color-brand-grey-border);
    padding-left: 0;
  }

  .pdl-sidebar-group {
    display: flex;
    flex-direction: column;
  }

  .pdl-sidebar-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--color-brand-grey-muted);
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    line-height: 1.4;
  }

  .pdl-sidebar-link--parent {
    font-weight: 500;
    color: var(--color-brand-grey);
  }

  .pdl-sidebar-link--child {
    padding-left: 1.75rem;
    font-size: 0.8125rem;
  }

  .pdl-sidebar-link:hover {
    color: var(--color-brand-blue);
    background: var(--color-brand-blue-light);
    border-radius: 0 6px 6px 0;
  }

  .pdl-sidebar-link.active {
    color: var(--color-brand-blue);
    border-left-color: var(--color-brand-blue);
    font-weight: 500;
  }

  /* ── Content ── */
  .pdl-content {
    min-width: 0;
  }

  .pdl-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 1rem;
    padding-top: 1.5rem;
    scroll-margin-top: 100px;
  }

  .pdl-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-brand-black);
    margin-bottom: 0.75rem;
    padding-top: 1rem;
    scroll-margin-top: 100px;
  }

  .pdl-content :global(p) {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .pdl-content :global(ul),
  .pdl-content :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .pdl-content :global(li) {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin-bottom: 0.375rem;
  }

  .pdl-content :global(section) {
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-brand-grey-border);
  }

  .pdl-content :global(section:last-child) {
    border-bottom: none;
  }

  .pdl-content :global(.content-card) {
    background: var(--color-brand-grey-bg-subtle);
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .pdl-content :global(.content-card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .pdl-content :global(.highlight-box) {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.06), rgba(0, 195, 147, 0.06));
    border: 1px solid rgba(44, 112, 235, 0.15);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .pdl-content :global(.stat-value) {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    line-height: 1.2;
  }

  .pdl-content :global(.stat-label) {
    font-size: 0.875rem;
    color: var(--color-brand-grey-muted);
    margin-top: 0.25rem;
  }

  .pdl-content :global(img) {
    border-radius: 12px;
    margin-bottom: 1.25rem;
  }

  .pdl-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
  }

  .pdl-content :global(th) {
    background: var(--color-brand-blue);
    color: #fff;
    font-weight: 500;
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .pdl-content :global(th:first-child) {
    border-radius: 8px 0 0 0;
  }

  .pdl-content :global(th:last-child) {
    border-radius: 0 8px 0 0;
  }

  .pdl-content :global(td) {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-brand-grey-border);
    color: var(--color-brand-grey);
  }

  .pdl-content :global(tr:hover td) {
    background: var(--color-brand-grey-bg-subtle);
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .pdl-hero-top-row {
      flex-direction: column;
      align-items: flex-start;
    }
    .pdl-hero-title { font-size: 2rem; }
    .pdl-help-centre-desc { display: none; }

    .pdl-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .pdl-sidebar {
      position: relative;
      top: 0;
      max-height: none;
      padding-right: 0;
      margin-bottom: 1.5rem;
    }

    .pdl-sidebar-toggle {
      display: flex;
    }

    .pdl-sidebar-nav {
      display: none;
      border-left: none;
      background: var(--color-brand-grey-bg-subtle);
      border: 1px solid var(--color-brand-grey-border);
      border-radius: 10px;
      padding: 0.75rem;
    }

    .pdl-sidebar-nav.open {
      display: flex;
    }

    .pdl-sidebar-link {
      border-left: none;
      margin-left: 0;
      border-radius: 6px;
    }
  }

  @media (max-width: 480px) {
    .pdl-hero { padding: 2.5rem 0 1.5rem; }
    .pdl-hero-title { font-size: 1.75rem; }
    .pdl-wrapper { padding: 1.5rem 0 3rem; }
  }
</style>

<script>
  // Sidebar toggle for mobile
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebarNav = document.getElementById('sidebar-nav');

  sidebarToggle?.addEventListener('click', () => {
    sidebarNav?.classList.toggle('open');
  });

  // Active section tracking with Intersection Observer (only for anchor-based links)
  const sections = document.querySelectorAll('.pdl-content section[id]');
  const sidebarLinks = document.querySelectorAll('.pdl-sidebar-link[data-section]:not([data-section=""])');

  if (sections.length > 0 && sidebarLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            sidebarLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('data-section') === id);
            });
          }
        });
      },
      { rootMargin: '-100px 0px -60% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
  }

  // Close sidebar on link click (mobile)
  sidebarLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 860) {
        sidebarNav?.classList.remove('open');
      }
    });
  });
</script>
