---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Services" description="From automation to software development, we deliver intelligent, practical solutions that streamline operations across GP practices, hospitals, private clinics, and beyond.">
  <Nav />

  <!-- Hero -->
  <section class="page-hero">
    <div class="container-site">
      <div class="hero-grid">
        <div class="hero-left">
          <h1 class="hero-title">
            Digital <span class="text-gradient">Healthcare</span> Solutions That Work for You!
          </h1>
        </div>
        <div class="hero-right">
          <p class="hero-subtitle">
            From automation to software development, we deliver intelligent, practical solutions
            that streamline operations across GP practices, hospitals, private clinics, and beyond.
          </p>
          <a href={`${base}about`} class="btn-primary">Find out more</a>
        </div>
      </div>
    </div>
    <div class="hero-orb hero-orb--1"></div>
    <div class="hero-orb hero-orb--2"></div>
  </section>

  <!-- Service Cards -->
  <section class="section">
    <div class="container-site">
      <div class="services-tag">SERVICES</div>
      <div class="services-grid">
        <!-- Custom Automation Processes -->
        <a href={`${base}services/custom-automation-processes-copy`} class="service-card">
          <div class="service-card-header">
            <h2 class="service-card-title">Custom Automation Processes</h2>
            <div class="service-card-arrow">
              <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
                <rect width="50" height="50" rx="25" fill="currentColor" />
                <path d="M15 15H35M35 15V35M35 15L15 35" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
          <div class="service-card-body">
            <p>
              <strong>Tailored automation that fits your exact workflow.</strong><br />
              We analyse, design, and implement automation built specifically for your
              organisation's needs -- boosting efficiency without disrupting care.
            </p>
          </div>
        </a>

        <!-- Digitalisation Consultancy -->
        <a href={`${base}services/digitalisation-consultancy`} class="service-card">
          <div class="service-card-header">
            <h2 class="service-card-title">Digitalisation Consultancy</h2>
            <div class="service-card-arrow">
              <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
                <rect width="50" height="50" rx="25" fill="currentColor" />
                <path d="M15 15H35M35 15V35M35 15L15 35" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
          <div class="service-card-body">
            <p>
              <strong>Move from paper to pixels, the smart way.</strong>
              Let us guide your transition to digital. We design and implement transformation
              strategies that work -- supported by training and change management.
            </p>
          </div>
        </a>

        <!-- Custom Software Solutions -->
        <a href={`${base}services/custom-software-solutions`} class="service-card">
          <div class="service-card-header">
            <h2 class="service-card-title">Custom Software Solutions</h2>
            <div class="service-card-arrow">
              <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
                <rect width="50" height="50" rx="25" fill="currentColor" />
                <path d="M15 15H35M35 15V35M35 15L15 35" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
          <div class="service-card-body">
            <p>
              <strong>Bespoke tools that adapt to your clinical world.</strong><br />
              Our custom software is designed around your existing systems and workflows --
              delivering intuitive, secure, and scalable platforms for any healthcare provider.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .page-hero {
    position: relative;
    padding: 7rem 0 5rem;
    overflow: hidden;
    background: linear-gradient(175deg, #ffffff 0%, #f0f4fb 40%, #eef8f5 70%, #f5f7fa 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-title {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }
  .hero-orb--1 {
    width: 500px;
    height: 500px;
    background: rgba(44, 112, 235, 0.12);
    top: -10%;
    right: -5%;
  }
  .hero-orb--2 {
    width: 400px;
    height: 400px;
    background: rgba(0, 195, 147, 0.10);
    bottom: -20%;
    left: -5%;
  }

  /* Services Tag */
  .services-tag {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-brand-blue);
    margin-bottom: 2rem;
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .service-card {
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.06);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .service-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .service-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .service-card-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-black);
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .service-card-arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    color: var(--color-brand-black);
    transition: color 0.3s, transform 0.4s ease;
  }
  .service-card:hover .service-card-arrow {
    color: var(--color-brand-blue);
    transform: rotate(45deg);
  }
  .service-card-arrow svg {
    width: 100%;
    height: 100%;
  }

  .service-card-body p {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .page-hero {
      padding: 5rem 0 3rem;
    }
    .hero-title {
      font-size: 2rem;
    }
    .service-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
