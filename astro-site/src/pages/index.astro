<style is:global>
  /* ── Book a Demo Modal ── */
  .demo-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .demo-overlay.open {
    display: flex;
  }

  .demo-modal {
    background: #fff;
    border-radius: 20px;
    max-width: 520px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    position: relative;
    animation: demo-slide-up 0.25s ease;
  }

  @keyframes demo-slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .demo-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border: none;
    background: var(--color-brand-grey-bg, #f1f5f9);
    border-radius: 50%;
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted, #6b7280);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }

  .demo-close:hover {
    background: var(--color-brand-grey-border, #e5e7eb);
  }

  .demo-header {
    padding: 2rem 2rem 1rem;
    text-align: center;
  }

  .demo-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-black, #111827);
    margin-bottom: 0.375rem;
  }

  .demo-subtitle {
    font-size: 0.9375rem;
    color: var(--color-brand-grey-muted, #6b7280);
  }

  .demo-products {
    padding: 0 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .demo-product-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-brand-grey-border, #e5e7eb);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .demo-product-card:hover {
    border-color: var(--color-brand-blue, #2c70eb);
    background: rgba(44, 112, 235, 0.03);
    transform: translateX(2px);
  }

  .demo-product-card--highlight {
    border-color: var(--color-brand-blue, #2c70eb);
    background: rgba(44, 112, 235, 0.04);
  }

  .demo-product-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
