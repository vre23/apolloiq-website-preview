<script>
  const cdmSafetyForm = document.getElementById('cdm-safety-form') as HTMLFormElement;
  if (cdmSafetyForm) {
    cdmSafetyForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = cdmSafetyForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      try {
        const res = await fetch(cdmSafetyForm.action, {
          method: 'POST',
          body: new FormData(cdmSafetyForm),
          headers: { 'Accept': 'application/json' }
        });
        if (res.ok) {
          document.getElementById('cdm-safety-form-wrap')!.innerHTML = '<p style="color:var(--color-brand-green);font-weight:600;margin-top:1rem;">✓ Request submitted! We\'ll send the documentation to your email shortly.</p>';
        } else { throw new Error('Failed'); }
      } catch {
        btn.textContent = 'Submit Request';
        btn.disabled = false;
        alert('Something went wrong. Please try again or email vlad.repede@apolloiq.co.uk directly.');
      }
    });
  }
</script>

<script>
  // CDM Business Case Calculator
  const ADMIN_SALARY = 22383;
  const ADMIN_HOURLY = 11.48;
  const WORKING_DAYS = 230;
  const NI_RATE = 0.0891;
  const PENSION_RATE = 0.1524;
  const HOLIDAY_COVER = 1500;
  const PRICE_PER_PATIENT = 0.30;
  const LETTERS_PER_10K = 36500;

  function formatCurrency(n) {
    return '£' + new Intl.NumberFormat('en-GB').format(Math.round(n));
  }

  function recalcCDM() {
    const input = document.getElementById('cdm-patient-count');
    if (!input) return;
    const patients = parseInt(input.value) || 10000;
    const ratio = patients / 10000;

    const letters = Math.round(LETTERS_PER_10K * ratio);
    const hours = Math.round(866 * ratio);
    const costPerDoc = 0.53;
    const labourCost = Math.round(hours * ADMIN_HOURLY);
    const niCost = Math.round(labourCost * NI_RATE);
    const pensionCost = Math.round(labourCost * PENSION_RATE);
    const totalManual = labourCost + niCost + pensionCost + HOLIDAY_COVER;
    const apolloCost = patients * PRICE_PER_PATIENT;
    const savings = totalManual - apolloCost;

    // Update stats
    const hoursEl = document.getElementById('cdm-hours');
    if (hoursEl) hoursEl.textContent = new Intl.NumberFormat('en-GB').format(hours);

    const costEl = document.getElementById('cdm-cost-manual');
    if (costEl) costEl.textContent = '£' + costPerDoc.toFixed(2);

    // Update cost breakdown
    const labourEl = document.getElementById('cdm-labour');
    if (labourEl) labourEl.textContent = hours + ' hrs x £' + ADMIN_HOURLY + '/hr = ' + formatCurrency(labourCost);

    const niEl = document.getElementById('cdm-ni');
    if (niEl) niEl.textContent = formatCurrency(niCost);

    const pensionEl = document.getElementById('cdm-pension');
    if (pensionEl) pensionEl.textContent = formatCurrency(pensionCost);

    const totalManualEl = document.getElementById('cdm-total-manual');
    if (totalManualEl) totalManualEl.textContent = formatCurrency(totalManual);

    // Update apollo cost
    const apolloCalcEl = document.getElementById('cdm-apollo-calc');
    if (apolloCalcEl) apolloCalcEl.textContent = new Intl.NumberFormat('en-GB').format(patients) + ' patients x £0.30 = ' + formatCurrency(apolloCost) + '/year';

    // Update savings
    const savingsEl = document.getElementById('cdm-total-savings');
    if (savingsEl) savingsEl.textContent = formatCurrency(savings);

    // Update pricing section example
    const pricingCalcEl = document.getElementById('cdm-pricing-example');
    if (pricingCalcEl) pricingCalcEl.textContent = formatCurrency(apolloCost) + '/year';

    const pricingMonthEl = document.getElementById('cdm-pricing-month');
    if (pricingMonthEl) pricingMonthEl.textContent = formatCurrency(apolloCost / 12) + '/month';
  }

  document.getElementById('cdm-patient-count')?.addEventListener('input', recalcCDM);
  recalcCDM();

  // ── CDM Lead Gate ──
  const cdmGateForm = document.getElementById('cdm-calc-gate-form') as HTMLFormElement;
  if (cdmGateForm) {
    cdmGateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = cdmGateForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'Unlocking...';
      btn.disabled = true;

      const name = (document.getElementById('cdm-gate-name') as HTMLInputElement).value;
      const role = (document.getElementById('cdm-gate-role') as HTMLSelectElement).value;
      const practice = (document.getElementById('cdm-gate-practice') as HTMLInputElement).value;
      const email = (document.getElementById('cdm-gate-email') as HTMLInputElement).value;
      const patients = parseInt((document.getElementById('cdm-patient-count') as HTMLInputElement).value) || 10000;

      // Calculate key metrics for email and gated content
      const ratio = patients / 10000;
      const letters = Math.round(LETTERS_PER_10K * ratio);
      const hours = Math.round(866 * ratio);
      const labourCost = Math.round(hours * ADMIN_HOURLY);
      const niCost = Math.round(labourCost * NI_RATE);
      const pensionCost = Math.round(labourCost * PENSION_RATE);
      const totalManual = labourCost + niCost + pensionCost + HOLIDAY_COVER;
      const apolloCost = patients * PRICE_PER_PATIENT;
      const savings = totalManual - apolloCost;
      const costPerDocManual = (totalManual / letters).toFixed(2);
      const costPerDocApollo = (apolloCost / letters).toFixed(2);
      const multiplier = (totalManual / apolloCost).toFixed(1);

      // Update gated comparison section with calculated values
      const u = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };
      u('cdm-compare-manual-total', formatCurrency(totalManual));
      u('cdm-compare-manual-perdoc', '£' + costPerDocManual);
      u('cdm-compare-manual-hours', String(hours));
      u('cdm-compare-apollo-total', formatCurrency(apolloCost));
      u('cdm-compare-apollo-perdoc', '£' + costPerDocApollo);
      u('cdm-compare-savings', formatCurrency(savings));
      u('cdm-compare-multiplier', multiplier + 'x');
      u('cdm-reason-multiplier', multiplier + 'x');

      // Send to Formspree (non-blocking)
      const fd = new FormData(cdmGateForm);
      fd.append('patients', String(patients));
      fd.append('annual_savings', formatCurrency(savings));
      fetch(cdmGateForm.action, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } }).catch(() => {});

      // Send personalised email via Google Apps Script (non-blocking)
      fetch('https://script.google.com/macros/s/AKfycbw_88x4yCO66ZqKzM90EaarkQo8OtrP0JywqkMdDHChOgVInN_ZdibpXm7vH1PFZTMP9A/exec', {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({
          type: 'cdm',
          email: email,
          name: name,
          practice: practice,
          role: role,
          patients: patients,
          letters: letters,
          hours: hours,
          totalManual: totalManual,
          apolloCost: Math.round(apolloCost),
          savings: savings,
          multiplier: multiplier
        })
      }).catch(() => {});

      // Show gated content, hide gate
      (document.getElementById('cdm-calc-gate') as HTMLElement).style.display = 'none';
      (document.getElementById('cdm-gated-content') as HTMLElement).style.display = 'block';

      // Scroll to the unlocked content
      document.getElementById('cdm-gated-content')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>
