      const data = {};
      inputs.forEach((inp) => { if (inp.name || inp.placeholder) data[inp.placeholder || inp.name] = inp.value; });
      console.log('Safety docs request:', { ...data, product: 'Clinical Document Management', timestamp: new Date().toISOString() });
      document.getElementById('cdm-safety-form-wrap').innerHTML = '<p style="color:var(--color-brand-green);font-weight:600;margin-top:1rem;">✓ Request submitted! We\'ll send the documentation to your email shortly.</p>';
    });
  }
</script>

<script>
  // CDM Business Case Calculator
  const ADMIN_SALARY = 22383;
  const ADMIN_HOURLY = 11.48;
  const WORKING_DAYS = 230;
  const NI_RATE = 0.0891;
  const PENSION_RATE = 0.1524;
  const HOLIDAY_COVER = 1500;
  const PRICE_PER_PATIENT = 0.30;
  const LETTERS_PER_10K = 36500;

  function formatCurrency(n) {
    return '£' + new Intl.NumberFormat('en-GB').format(Math.round(n));
  }

  function recalcCDM() {
    const input = document.getElementById('cdm-patient-count');
    if (!input) return;
    const patients = parseInt(input.value) || 10000;
    const ratio = patients / 10000;

    const letters = Math.round(LETTERS_PER_10K * ratio);
    const hours = Math.round(866 * ratio);
    const costPerDoc = 0.53;
    const labourCost = Math.round(hours * ADMIN_HOURLY);
    const niCost = Math.round(labourCost * NI_RATE);
    const pensionCost = Math.round(labourCost * PENSION_RATE);
    const totalManual = labourCost + niCost + pensionCost + HOLIDAY_COVER;
    const apolloCost = patients * PRICE_PER_PATIENT;
    const savings = totalManual - apolloCost;

    // Update stats
    const hoursEl = document.getElementById('cdm-hours');
    if (hoursEl) hoursEl.textContent = new Intl.NumberFormat('en-GB').format(hours);

    const costEl = document.getElementById('cdm-cost-manual');
    if (costEl) costEl.textContent = '£' + costPerDoc.toFixed(2);

    // Update cost breakdown
    const labourEl = document.getElementById('cdm-labour');
    if (labourEl) labourEl.textContent = hours + ' hrs x £' + ADMIN_HOURLY + '/hr = ' + formatCurrency(labourCost);

    const niEl = document.getElementById('cdm-ni');
    if (niEl) niEl.textContent = formatCurrency(niCost);

    const pensionEl = document.getElementById('cdm-pension');
    if (pensionEl) pensionEl.textContent = formatCurrency(pensionCost);

    const totalManualEl = document.getElementById('cdm-total-manual');
    if (totalManualEl) totalManualEl.textContent = formatCurrency(totalManual);

    // Update apollo cost
    const apolloCalcEl = document.getElementById('cdm-apollo-calc');
    if (apolloCalcEl) apolloCalcEl.textContent = new Intl.NumberFormat('en-GB').format(patients) + ' patients x £0.30 = ' + formatCurrency(apolloCost) + '/year';

    // Update savings
    const savingsEl = document.getElementById('cdm-total-savings');
    if (savingsEl) savingsEl.textContent = formatCurrency(savings);

    // Update pricing section example
    const pricingCalcEl = document.getElementById('cdm-pricing-example');
    if (pricingCalcEl) pricingCalcEl.textContent = formatCurrency(apolloCost) + '/year';

    const pricingMonthEl = document.getElementById('cdm-pricing-month');
    if (pricingMonthEl) pricingMonthEl.textContent = formatCurrency(apolloCost / 12) + '/month';
  }

  document.getElementById('cdm-patient-count')?.addEventListener('input', recalcCDM);
  recalcCDM();

  // Lead gate
  const cdmGateForm = document.getElementById('cdm-calc-gate-form');
  if (cdmGateForm) {
    cdmGateForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('cdm-gate-name').value;
      const role = document.getElementById('cdm-gate-role').value;
      const practice = document.getElementById('cdm-gate-practice').value;
      const email = document.getElementById('cdm-gate-email').value;
      const patients = document.getElementById('cdm-patient-count').value;

      const leadData = { name, role, practice, email, patients, product: 'Clinical Document Management', source: 'Business Case Calculator', timestamp: new Date().toISOString() };
      console.log('Lead captured:', leadData);

      // Replace gate with success message
      document.getElementById('cdm-calc-gate').innerHTML = '<div style="text-align:center;padding:2rem;"><div style="font-size:2rem;margin-bottom:0.75rem;">✓</div><h3 style="font-size:1.25rem;font-weight:700;color:var(--color-brand-black);margin-bottom:0.5rem;">Business Case Sent!</h3><p style="color:var(--color-brand-grey);font-size:0.9375rem;">Check your inbox for your personalised savings report.</p></div>';
    });
  }
</script>
