<script>
  // ── ROI Calculator ──
  const slClinicians = document.getElementById('sl-clinicians') as HTMLInputElement;
  const slConsults = document.getElementById('sl-consults') as HTMLInputElement;
  const slDoctime = document.getElementById('sl-doctime') as HTMLInputElement;
  const slDays = document.getElementById('sl-days') as HTMLInputElement;

  function calcROI() {
    const c = parseInt(slClinicians.value);
    const n = parseInt(slConsults.value);
    const d = parseInt(slDoctime.value);
    const w = parseInt(slDays.value);

    document.getElementById('val-clinicians')!.textContent = String(c);
    document.getElementById('val-consults')!.textContent = String(n);
    document.getElementById('val-doctime')!.textContent = String(d);
    document.getElementById('val-days')!.textContent = String(w);

    const savedMinPerDay = c * n * d * 0.7;
    const hDay = (savedMinPerDay / 60).toFixed(1);
    const hWeek = (parseFloat(hDay) * w).toFixed(0);
    const hYear = (parseFloat(hWeek) * 48).toFixed(0);
    const extraConsults = Math.floor((savedMinPerDay * w) / (10 * 5));

    document.getElementById('res-hours-day')!.textContent = hDay + ' hrs';
    document.getElementById('res-hours-week')!.textContent = hWeek + ' hrs';
    document.getElementById('res-hours-year')!.textContent = Number(hYear).toLocaleString() + ' hrs';
    document.getElementById('res-consults-extra')!.textContent = '+' + extraConsults;
  }

  if (slClinicians) {
    [slClinicians, slConsults, slDoctime, slDays].forEach((sl) => {
      sl.addEventListener('input', calcROI);
    });
    calcROI();
  }

  // ── Practice Readiness Audit ──
  const auditAnswers: Record<string, number> = {};
  const totalQs = 8;

  document.querySelectorAll('.audit-opt').forEach((opt) => {
    opt.addEventListener('click', () => {
      const card = opt.closest('.audit-card') as HTMLElement;
      const q = card.getAttribute('data-q')!;
      card.querySelectorAll('.audit-opt').forEach((o) => o.classList.remove('selected'));
      opt.classList.add('selected');
      card.classList.add('answered');
      auditAnswers[q] = parseInt(opt.getAttribute('data-v')!);

      // Update progress
      const answered = Object.keys(auditAnswers).length;
      (document.getElementById('audit-progress') as HTMLElement).style.width = (answered / totalQs * 100) + '%';

      // Enable submit
      const btn = document.getElementById('audit-submit') as HTMLButtonElement;
      if (answered >= totalQs) {
        btn.classList.add('enabled');
        btn.disabled = false;
      }
    });
  });

  const submitBtn = document.getElementById('audit-submit');
  if (submitBtn) {
    submitBtn.addEventListener('click', () => {
      let total = 0;
      for (const k in auditAnswers) total += auditAnswers[k];
      const pct = Math.round((total / (totalQs * 3)) * 100);
      document.getElementById('audit-score-num')!.textContent = pct + '%';

      let level: string, desc: string;
      if (pct >= 85) {
        level = 'Excellent Readiness';
        desc = 'Your practice is well positioned to adopt ScribeCraft with minimal preparation.';
      } else if (pct >= 65) {
        level = 'Good Readiness';
        desc = 'Your practice is ready with a few areas to address. Our team will help with the transition.';
      } else if (pct >= 45) {
        level = 'Moderate Readiness';
        desc = 'Some preparation is needed. We can help identify and resolve any gaps before deployment.';
      } else {
        level = 'Early Stage';
        desc = 'Additional groundwork is recommended. Contact us for a guided assessment and support plan.';
      }

      document.getElementById('audit-level')!.textContent = level;
      document.getElementById('audit-level-desc')!.textContent = desc;
      (document.getElementById('audit-quiz') as HTMLElement).style.display = 'none';
      (document.getElementById('audit-results') as HTMLElement).style.display = 'block';
    });
  }

  const restartBtn = document.getElementById('audit-restart');
  if (restartBtn) {
    restartBtn.addEventListener('click', () => {
      for (const k in auditAnswers) delete auditAnswers[k];
      document.querySelectorAll('.audit-opt').forEach((o) => o.classList.remove('selected'));
      document.querySelectorAll('.audit-card').forEach((c) => c.classList.remove('answered'));
      (document.getElementById('audit-progress') as HTMLElement).style.width = '0';
      const btn = document.getElementById('audit-submit') as HTMLButtonElement;
      btn.classList.remove('enabled');
      btn.disabled = true;
      (document.getElementById('audit-quiz') as HTMLElement).style.display = 'block';
      (document.getElementById('audit-results') as HTMLElement).style.display = 'none';
    });
  }
</script>
