---
import ProductDocsLayout from '../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Overview', href: '#overview' },
  {
    label: 'Features',
    href: '#features',
    children: [
      { label: 'Live Consultation Capture', href: '#live-consultation-capture' },
      { label: 'Flexible Clinical Formats', href: '#flexible-clinical-formats' },
      { label: 'Multi-Specialty Support', href: '#multi-specialty-support' },
      { label: 'EPR-Ready Output', href: '#epr-ready-output' },
    ],
  },
  {
    label: 'How It Works',
    href: '#how-it-works',
  },
  {
    label: 'Safety & Security',
    href: '#safety-and-security',
    children: [
      { label: 'Patient Consent', href: '#patient-consent' },
      { label: 'Compliance', href: '#compliance' },
    ],
  },
  { label: 'By the Numbers', href: '#by-the-numbers' },
  { label: 'Getting Started', href: '#getting-started' },
  {
    label: 'Help Centre',
    href: '#help-centre',
    children: [
      { label: 'Quick Start Guide', href: '#quick-start-guide' },
      { label: 'Accuracy Optimisation', href: '#accuracy-optimisation' },
      { label: 'FAQ', href: '#faq' },
      { label: 'For Patients', href: '#for-patients' },
      { label: 'For Practices', href: '#for-practices' },
      { label: 'For Clinicians', href: '#for-clinicians' },
      { label: 'ROI Calculator', href: '#roi-calculator' },
      { label: 'Practice Readiness Audit', href: '#practice-readiness-audit' },
    ],
  },
];
---

<ProductDocsLayout
  title="ScribeCraft - AI Clinical Note-Taking | ApolloIQ"
  description="ScribeCraft is an AI-powered clinical documentation tool that transforms patient consultations into structured clinical notes in real time."
  heroTitle="ScribeCraft"
  heroSubtitle="Listen. Understand. Document. Your AI assistant that transforms patient consultations into structured clinical notes in real time."
  sidebarItems={sidebarItems}
>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- OVERVIEW                                                 -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="overview">
    <h2>Overview</h2>
    <div class="highlight-box">
      <span class="sc-badge">CLASS I MEDICAL DEVICE</span>
      <p style="margin-top: 1rem;">
        ScribeCraft is an AI-powered clinical documentation tool that listens to clinician-patient consultations,
        transcribes the conversation in real time, and automatically generates structured, accurate clinical notes
        — ready to copy into your EPR system.
      </p>
    </div>
    <p>
      Up to <strong>70% of consultation time</strong> is lost to data entry. The leading cause of clinician burnout
      is after-hours administrative work. ScribeCraft eliminates this burden by handling the documentation so you
      can focus on what matters: the patient.
    </p>
    <p>
      Reclaim up to <strong>2 hours a day</strong> and eliminate administrative burden.
    </p>
    <div class="content-card">
      <p>
        ScribeCraft is a <strong>registered Class I medical device</strong>, designed as an administrative support tool.
        It does not provide diagnoses, suggest treatments, or replace clinical judgement. Every note generated is a
        draft that requires clinician review and validation before use.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FEATURES                                                 -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="features">
    <h2>Key Features</h2>
    <p>
      Purpose-built for NHS and UK primary care. ScribeCraft understands medical terminology and structures notes
      the way clinicians need them.
    </p>

    <div id="live-consultation-capture" class="content-card" style="scroll-margin-top: 100px;">
      <h3>Live Consultation Capture</h3>
      <p>
        Transcribes and structures your patient conversations in real time — face-to-face, telephone, or video
        consultations. ScribeCraft works in the background without interrupting your clinical workflow.
      </p>
    </div>

    <div id="flexible-clinical-formats" class="content-card" style="scroll-margin-top: 100px;">
      <h3>Flexible Clinical Formats</h3>
      <p>
        Generates notes in SOAP format, clinical letters, referral letters, and other structured templates to match
        your workflow. Choose the right template before recording and ScribeCraft structures information exactly the
        way you need it.
      </p>
    </div>

    <div id="multi-specialty-support" class="content-card" style="scroll-margin-top: 100px;">
      <h3>Multi-Specialty Support</h3>
      <p>
        Trained for General Practice, Cardiology, Paediatrics, Neurology, Dermatology, Mental Health, and many more
        specialties. Templates actively guide the AI algorithm — a cardiology template prioritises cardiovascular
        terms, a dermatology template is optimised for lesion descriptions.
      </p>
    </div>

    <div id="epr-ready-output" class="content-card" style="scroll-margin-top: 100px;">
      <h3>EPR-Ready Output</h3>
      <p>
        Clean, structured text ready for one-click copy-paste into EMIS Web, SystmOne, Vision, or any EPR system.
        Also exportable as PDF for printing or patient records.
      </p>
    </div>

    <div class="content-card">
      <h3>No Installation Required</h3>
      <p>
        ScribeCraft is a web application that runs directly in your browser — Chrome, Edge, Firefox, or Safari.
        Works on desktop, laptop, tablet, or phone. No applications, extensions, or additional software required.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- HOW IT WORKS                                             -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="how-it-works">
    <h2>How It Works</h2>
    <p>
      ScribeCraft is built for clinical ease — no steep learning curve, no interruptions, just seamless transcription.
      Set up takes 15 minutes and you start saving time from the very first consultation.
    </p>

    <div class="content-card">
      <h3>1. Log into Merlin</h3>
      <p>
        Access ScribeCraft through your dedicated account on the Merlin platform. No software to install — it runs
        in your browser.
      </p>
    </div>

    <div class="content-card">
      <h3>2. Choose a Note Format</h3>
      <p>
        Select from the available clinical templates — SOAP notes, clinical letters, referral letters, or
        specialty-specific formats.
      </p>
    </div>

    <div class="content-card">
      <h3>3. Start a New Session</h3>
      <p>
        Press "New Session" to begin recording. ScribeCraft is ready to capture your consultation with the patient.
      </p>
    </div>

    <div class="content-card">
      <h3>4. Speak Naturally</h3>
      <p>
        Conduct your consultation as usual. ScribeCraft records and transcribes in real time using advanced speech
        recognition optimised for medical terminology.
      </p>
    </div>

    <div class="content-card">
      <h3>5. Notes Are Structured Automatically</h3>
      <p>
        When you stop the session, the transcription is analysed and organised into your chosen template — a
        complete, structured clinical note ready for review.
      </p>
    </div>

    <div class="content-card">
      <h3>6. Review, Copy, and File</h3>
      <p>
        Read and validate the draft, then copy it directly into your EPR system or export it as a PDF for printing
        or patient records.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- SAFETY & SECURITY                                        -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="safety-and-security">
    <h2>Safety & Security</h2>
    <p>
      ScribeCraft is designed from the ground up to meet the highest standards of data protection and clinical
      safety required by UK healthcare.
    </p>

    <div class="content-card">
      <h3>Clinician in Control (Human-in-the-Loop)</h3>
      <p>
        ScribeCraft is an administrative support tool — it does not make clinical decisions. Every document generated
        is a draft that must be reviewed and validated by the clinician before use. The clinician retains full
        responsibility for the final content.
      </p>
    </div>

    <div class="content-card">
      <h3>Zero-Retention Architecture</h3>
      <p>
        Audio data is processed in real time and immediately deleted. No recordings or patient data are retained on
        our servers. Zero-retention by design.
      </p>
    </div>

    <div class="content-card">
      <h3>UK GDPR & Data Protection Act 2018 Compliant</h3>
      <p>
        All data processing complies with UK GDPR and the Data Protection Act 2018. Your practice is the Data
        Controller; ApolloIQ is the Data Processor, formalised through a Data Processing Agreement (DPA) signed
        at account activation.
      </p>
    </div>

    <div class="content-card">
      <h3>Encryption at Every Layer</h3>
      <p>
        All data is encrypted in transit (TLS 1.2+) and at rest (AES-256). Only the authenticated user can access
        their generated documents — the ApolloIQ team has no access to document content.
      </p>
    </div>

    <div class="content-card">
      <h3>AI Training Guarantee</h3>
      <p>
        Your data is never used to train, retrain, or improve any AI models. This is contractually guaranteed in
        our Terms of Service and DPA.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- PATIENT CONSENT                                          -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="patient-consent">
    <h2>Patient Consent</h2>
    <p>
      Before using ScribeCraft in a consultation, the patient must be informed and their consent obtained. This is
      a legal requirement under UK data protection law and good clinical practice.
    </p>

    <div class="highlight-box">
      <h3>What to tell the patient</h3>
      <p>
        That the consultation will be recorded by an AI tool to generate clinical documentation, how the data is
        processed and stored, and that they can decline without any impact on their care.
      </p>
    </div>

    <div class="content-card">
      <h3>Written consent</h3>
      <p>
        ApolloIQ provides a customisable patient consent form template compliant with UK GDPR.
      </p>
    </div>

    <div class="content-card">
      <h3>Verbal consent</h3>
      <p>
        Acceptable if documented in the patient record. Suggested phrasing:
        <em>"I'll be using a digital assistant that transcribes our conversation to generate clinical notes. Are you
        happy with that?"</em>
      </p>
    </div>

    <div class="content-card">
      <h3>If the patient declines</h3>
      <p>
        The consultation proceeds normally without ScribeCraft. The patient's refusal has no effect on the quality
        of care received.
      </p>
    </div>

    <p>
      We recommend displaying an informational poster in your waiting room. ApolloIQ provides printable
      patient-facing materials free of charge.
    </p>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- COMPLIANCE & CERTIFICATIONS                              -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="compliance">
    <h2>Compliance & Certifications</h2>
    <p>ScribeCraft meets the regulatory requirements for use in UK healthcare settings.</p>

    <div class="content-card-grid">
      <div class="content-card">
        <h3>Class I Medical Device</h3>
        <p>
          Registered under the UK Medical Devices Regulations 2002 (as amended). ScribeCraft is classified as an
          administrative documentation tool and does not perform diagnostic or therapeutic functions.
        </p>
      </div>
      <div class="content-card">
        <h3>UK GDPR Compliant</h3>
        <p>
          Fully compliant with UK GDPR and the Data Protection Act 2018, processing sensitive health data (Article 9
          equivalent) to the highest standards.
        </p>
      </div>
      <div class="content-card">
        <h3>ISO 27001 Standards</h3>
        <p>
          Information security management aligned with ISO 27001 standards, ensuring robust protection of clinical data.
        </p>
      </div>
      <div class="content-card">
        <h3>AI Act Ready</h3>
        <p>
          Designed with full transparency obligations in accordance with the EU AI Act (Regulation 2024/1689). All
          AI-generated content is clearly identified as requiring human validation.
        </p>
      </div>
      <div class="content-card">
        <h3>Microsoft for Startups Partner</h3>
        <p>
          Built on Microsoft Azure infrastructure, benefiting from enterprise-grade security, redundancy, and
          compliance frameworks.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- BY THE NUMBERS                                           -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="by-the-numbers">
    <h2>By the Numbers</h2>
    <p>The impact on your practice.</p>

    <div class="content-card-grid">
      <div class="content-card" style="text-align: center;">
        <div class="stat-value">70%</div>
        <div class="stat-label">documentation time saved per consultation</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <div class="stat-value">2 hrs</div>
        <div class="stat-label">reclaimed every day</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <div class="stat-value" style="color: var(--color-brand-green);">100%</div>
        <div class="stat-label">UK GDPR compliant</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <div class="stat-value" style="color: var(--color-brand-green);">24/7</div>
        <div class="stat-label">available 365 days a year</div>
      </div>
    </div>

    <div class="content-card-grid" style="margin-top: 0.5rem;">
      <div class="content-card" style="text-align: center;">
        <strong style="color: var(--color-brand-black);">Class I Medical Device</strong>
        <div class="stat-label">UK MDR 2002</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <strong style="color: var(--color-brand-black);">ISO 27001</strong>
        <div class="stat-label">Security Standards</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <strong style="color: var(--color-brand-black);">Zero-Retention</strong>
        <div class="stat-label">Audio Architecture</div>
      </div>
      <div class="content-card" style="text-align: center;">
        <strong style="color: var(--color-brand-black);">Microsoft Azure</strong>
        <div class="stat-label">Enterprise Infrastructure</div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- GETTING STARTED                                          -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="getting-started">
    <h2>Getting Started</h2>
    <p>
      ScribeCraft is designed for rapid deployment. Most practices begin saving time from day one.
    </p>

    <div class="content-card">
      <h3>Step 1 — Initial Discussion</h3>
      <p>We understand your practice volume, specialty mix, and documentation needs.</p>
    </div>

    <div class="content-card">
      <h3>Step 2 — Account & Template Setup</h3>
      <p>We configure ScribeCraft with templates tailored to your specialties and preferences.</p>
    </div>

    <div class="content-card">
      <h3>Step 3 — Training Session (15 minutes)</h3>
      <p>A short, hands-on walkthrough showing your team how to use ScribeCraft effectively.</p>
    </div>

    <div class="content-card">
      <h3>Step 4 — Go Live with Ongoing Support</h3>
      <p>Start using ScribeCraft immediately. Our support team is available for any questions or fine-tuning.</p>
    </div>

    <div class="highlight-box">
      <h3>Technical Requirements</h3>
      <p>
        Any modern browser (Chrome, Edge, Firefox, Safari), a stable internet connection (2 Mbps upload recommended),
        and a microphone — the built-in mic on your laptop or phone works well in most settings. No installation or
        additional software required.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- HELP CENTRE                                              -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="help-centre">
    <h2>Help Centre</h2>
    <p>
      Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice.
    </p>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- QUICK START GUIDE                                        -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="quick-start-guide">
    <h2>Quick Start Guide</h2>
    <p>Follow these simple steps to start using ScribeCraft in your consultations.</p>

    <div class="content-card">
      <h3>1. Log into Merlin</h3>
      <p>
        Access ScribeCraft through your dedicated account on the <strong>Merlin platform</strong>. Navigate to
        <strong>merlin.apolloiq.co.uk</strong> and sign in with your credentials. No software to install —
        ScribeCraft runs entirely in your browser.
      </p>
    </div>

    <div class="highlight-box">
      <strong>Tip:</strong> ScribeCraft works on Chrome, Edge, Firefox, and Safari — on any device with a microphone
      and internet connection.
    </div>

    <div class="content-card">
      <h3>2. Set Up Your Microphone</h3>
      <p>Before your first session, ensure your microphone is configured correctly:</p>
      <ol>
        <li><strong>Select your microphone</strong> — Click the microphone icon next to the Start button and choose your preferred device from the list.</li>
        <li><strong>Test audio capture</strong> — Verify the microphone picks up your voice clearly at a comfortable distance.</li>
        <li><strong>Grant browser permissions</strong> — When prompted, click <em>Allow</em> to let ScribeCraft access your microphone. If you accidentally blocked it, click the lock icon in the address bar and change the Microphone setting to Allow.</li>
      </ol>
    </div>

    <div class="highlight-box">
      <strong>Tip:</strong> A USB desk microphone gives the best audio quality. Your laptop's built-in microphone works
      well for short distances. Position the microphone 30-50 cm from the speaker for optimal results.
    </div>

    <div class="content-card">
      <h3>3. Choose a Note Format</h3>
      <p>
        Select from the available clinical templates — <strong>SOAP notes</strong>, <strong>clinical letters</strong>,
        <strong>referral letters</strong>, or specialty-specific formats. Choosing the right template before recording
        helps ScribeCraft structure information exactly the way you need it.
      </p>
    </div>

    <div class="content-card">
      <h3>4. Obtain Patient Consent</h3>
      <p>
        Before starting the recording, inform the patient and obtain their consent. This is a legal requirement
        under UK data protection law and good clinical practice.
      </p>
      <p>
        Suggested phrasing: <em>"I'll be using a digital assistant that transcribes our conversation to generate
        clinical notes. Are you happy with that?"</em>
      </p>
    </div>

    <div class="sc-warning-box">
      <strong>Important:</strong> Patient consent is mandatory under UK GDPR. Ensure the patient understands and
      agrees before recording the consultation.
    </div>

    <div class="content-card">
      <h3>5. Start Recording</h3>
      <p>
        Press the <strong>Start</strong> button to begin recording. Conduct your consultation naturally — ScribeCraft
        works in the background without interrupting your clinical workflow.
      </p>
    </div>

    <div class="content-card">
      <h3>6. Stop and Process</h3>
      <p>
        When the consultation ends, click <strong>Stop</strong>. ScribeCraft will automatically process the
        conversation and generate a structured clinical note according to your chosen template. Processing usually
        takes just a few seconds.
      </p>
    </div>

    <div class="content-card">
      <h3>7. Review and Edit</h3>
      <p>
        Read the generated draft carefully. Check that all clinical details are accurate — especially medication
        doses, numerical values, and diagnoses. Edit directly in the editor if any corrections are needed.
      </p>
    </div>

    <div class="sc-warning-box">
      <strong>Important:</strong> Always review the generated note before using it officially. ScribeCraft produces
      draft documents — final clinical responsibility remains with you.
    </div>

    <div class="content-card">
      <h3>8. Copy and File</h3>
      <p>Once you're satisfied with the note:</p>
      <ul>
        <li><strong>Copy to your EPR</strong> — Paste the note directly into EMIS Web, SystmOne, Vision, or any EPR system.</li>
        <li><strong>Export as PDF</strong> — Generate a professional document for printing or patient records.</li>
      </ul>
    </div>

    <div class="highlight-box">
      <strong>Tip:</strong> Notes are saved automatically in your Merlin account. You can return to any previous note
      from the History section at any time.
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- ACCURACY OPTIMISATION                                    -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="accuracy-optimisation">
    <h2>Accuracy Optimisation</h2>
    <p>Tips for achieving the most precise transcriptions and clinical notes.</p>

    <div class="content-card">
      <h3>Understanding Accuracy</h3>
      <p>
        Transcription accuracy is the foundation of every clinical note generated by ScribeCraft. ScribeCraft uses
        AI models trained on medical terminology, capable of recognising thousands of clinical terms, drug names
        from the BNF, and specialty-specific vocabulary.
      </p>
      <p>
        Average accuracy exceeds <strong>96%</strong> in optimal conditions, but can be significantly influenced by
        factors you can control. The difference between 94% and 98% accuracy in a typical 15-minute consultation
        generating approximately 2,000 words means the difference between 120 potentially incorrect words and only 40.
      </p>
    </div>

    <div class="content-card">
      <h3>Microphone Positioning</h3>
      <p>Audio quality is the most important technical factor affecting transcription accuracy.</p>
      <p><strong>Face-to-face consultations:</strong></p>
      <ul>
        <li><strong>USB desk microphone</strong> — Position 30-50 cm away, oriented towards the centre between clinician and patient.</li>
        <li><strong>Lapel microphone</strong> — Clip to your lapel, approximately 15-20 cm from your mouth. Ideal for noisy consulting rooms.</li>
        <li><strong>Laptop microphone</strong> — Keep the laptop open at 90-120 degrees. Ideal distance is 40-60 cm.</li>
      </ul>
      <p><strong>Home visits:</strong></p>
      <p>
        Use a lapel microphone connected to your phone or tablet. Place the recording device on a stable surface
        — not on your lap or on the patient's bed.
      </p>
    </div>

    <div class="highlight-box">
      <strong>Tip:</strong> Do a 30-second test before each clinic session. Record a short phrase and check the
      preview to verify the transcription is accurate.
    </div>

    <div class="content-card">
      <h3>Optimising Your Recording Environment</h3>
      <p>Background noise, reverberation, and interference are the main enemies of accurate transcription.</p>
      <p><strong>Reducing background noise:</strong></p>
      <ol>
        <li><strong>Air conditioning</strong> — Turn off or reduce to minimum during consultations.</li>
        <li><strong>Waiting room noise</strong> — Ensure the consulting room door is fully closed.</li>
        <li><strong>Medical equipment</strong> — Schedule noisy equipment use outside recording periods where possible.</li>
        <li><strong>Phone notifications</strong> — Enable silent mode on your phone during consultations.</li>
      </ol>
    </div>

    <div class="sc-warning-box">
      <strong>Important:</strong> Do not try to compensate for ambient noise by speaking louder. Raised voice
      distorts the sound and can reduce accuracy. It is always more effective to reduce noise at the source.
    </div>

    <div class="content-card">
      <h3>Speaking Clearly</h3>
      <p>You don't need to change your natural communication style — just avoid a few common pitfalls:</p>
      <ul>
        <li><strong>Normal conversational pace</strong> — Speak as you would on the phone with a colleague.</li>
        <li><strong>Brief pauses at transitions</strong> — When moving between sections, pause for 1-2 seconds to help identify the transition.</li>
        <li><strong>Slow down for lists</strong> — When listing medications or results, slightly reduce your pace.</li>
        <li><strong>Dictate numbers clearly</strong> — For blood pressure, say each digit: "one three zero over eight five". Specify units immediately.</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Choosing the Right Template</h3>
      <p>
        Templates actively guide the AI algorithm. When you select a template matching your consultation type,
        ScribeCraft knows what information to expect.
      </p>
    </div>

    <div class="sc-warning-box">
      <strong>Important:</strong> Using an inappropriate template can reduce accuracy. An ophthalmology template used
      for a general medicine consultation will prioritise the wrong vocabulary.
    </div>

    <div class="content-card">
      <h3>Review and Feedback</h3>
      <p>No automated transcription is 100% accurate. Always review the generated note:</p>
      <ul>
        <li><strong>Correct words or phrases</strong> — Click on text to modify it directly.</li>
        <li><strong>Add missing details</strong> — If information was not captured, add it manually.</li>
        <li><strong>Verify critical values</strong> — Pay special attention to medication doses, numerical values, and diagnoses.</li>
      </ul>
    </div>

    <div class="highlight-box">
      <strong>Tip:</strong> Review clinical notes immediately after each consultation while the information is fresh.
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FAQ                                                      -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="faq">
    <h2>Frequently Asked Questions</h2>
    <p>Answers to the most common questions about ScribeCraft.</p>

    <!-- About ScribeCraft -->
    <h3>About ScribeCraft</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>What is ScribeCraft?</summary>
        <p>
          ScribeCraft is an AI-powered clinical documentation tool that listens to clinician-patient consultations,
          transcribes the conversation in real time, and automatically generates structured, accurate clinical notes
          — ready to copy into your EPR system. It is a web application that runs directly in your browser on any
          device with an internet connection. No installation required.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Who uses ScribeCraft?</summary>
        <p>
          ScribeCraft is used by healthcare professionals who need to document consultations: GPs, hospital
          specialists, mental health professionals, allied health professionals, and other clinicians where accurate
          documentation is essential.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Is ScribeCraft a generic AI like ChatGPT?</summary>
        <p>
          No. ScribeCraft is not a creative content generator or chatbot. It is a specialised system optimised
          exclusively for documenting and structuring clinical conversations. It understands medical terminology
          and generates structured documents according to clinical templates.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Is ScribeCraft just a dictation app?</summary>
        <p>
          No. Standard dictation apps produce raw text that requires extensive editing. ScribeCraft goes further:
          after transcription, it analyses the content and generates a structured draft according to your chosen
          template — ready to review and validate, without manual rewriting.
        </p>
      </details>
      <details class="faq-detail">
        <summary>What problem does ScribeCraft solve?</summary>
        <p>
          It eliminates "administrative latency" — the time and cognitive effort consumed between finishing a
          consultation and completing the documentation. Up to 70% of consultation time is lost to data entry.
          ScribeCraft generates a structured draft in seconds.
        </p>
      </details>
    </div>

    <!-- How It Works -->
    <h3>How It Works</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>What is the ScribeCraft workflow?</summary>
        <div>
          <ol>
            <li><strong>Start:</strong> Open ScribeCraft in your browser and press Record.</li>
            <li><strong>Consult:</strong> Conduct your consultation normally. ScribeCraft works in the background.</li>
            <li><strong>Review:</strong> ScribeCraft generates a structured draft. Review and correct as needed.</li>
            <li><strong>Validate and export:</strong> Copy to your EPR, print, or export as PDF.</li>
          </ol>
        </div>
      </details>
      <details class="faq-detail">
        <summary>Can ScribeCraft make clinical decisions or recommendations?</summary>
        <p>
          No. ScribeCraft does not offer diagnoses, suggest treatments, or substitute clinical judgement. Its role
          is strictly documentation support: listen, transcribe, and structure. All clinical decisions remain
          entirely with you.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Does ScribeCraft understand multiple speakers?</summary>
        <p>
          Yes. The system is designed to work with conversations between two or more people. For optimal results,
          we recommend a quiet environment and reasonable microphone distance.
        </p>
      </details>
    </div>

    <!-- Security & Confidentiality -->
    <h3>Security & Confidentiality</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>Is it safe to use ScribeCraft with patient data?</summary>
        <p>
          Yes. All data is encrypted in transit (TLS 1.2+) and at rest (AES-256), processed on Microsoft Azure
          infrastructure with enterprise-grade security, redundancy, and compliance frameworks.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Are audio recordings stored?</summary>
        <p>
          No. We apply a zero-retention architecture: audio data is processed in real time to generate the draft,
          then immediately deleted. No audio recordings are retained after processing.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Who has access to generated documents?</summary>
        <p>
          Only you and people you explicitly grant access to. The ApolloIQ team has no access to your document
          content. Access is secured through authentication protocols and encryption.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Is my data used to train AI models?</summary>
        <p>
          No. Your data is never used to train, retrain, or improve any AI models. This is contractually guaranteed
          in our Terms of Service and Data Processing Agreement (DPA).
        </p>
      </details>
    </div>

    <!-- Patient Consent FAQ -->
    <h3>Patient Consent</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>Is patient consent required?</summary>
        <div>
          <p>Yes. UK data protection law requires that patients are informed and consent is obtained before recording. The patient must know:</p>
          <ul>
            <li>That the consultation will be recorded by an AI tool</li>
            <li>Why the recording is being made (to generate clinical documentation)</li>
            <li>Who processes the data and how it is stored</li>
            <li>That they can decline without any impact on their care</li>
          </ul>
        </div>
      </details>
      <details class="faq-detail">
        <summary>How do I obtain consent?</summary>
        <div>
          <ul>
            <li><strong>Written consent:</strong> The patient signs a dedicated form. ApolloIQ provides a customisable consent form template compliant with UK GDPR.</li>
            <li><strong>Verbal consent:</strong> Acceptable if documented in the patient record. Suggested phrasing: "I'll be using a digital assistant that transcribes our conversation to generate clinical notes. Are you happy with that?"</li>
          </ul>
        </div>
      </details>
      <details class="faq-detail">
        <summary>What if the patient declines?</summary>
        <p>
          The consultation proceeds normally without ScribeCraft. The patient's refusal has no effect on the quality
          of care received. You document manually as usual.
        </p>
      </details>
    </div>

    <!-- Accuracy & Limits -->
    <h3>Accuracy & Limits</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>How accurate is the transcription?</summary>
        <p>
          ScribeCraft achieves high accuracy rates for medical terminology in optimal recording conditions.
          Performance varies based on microphone quality, ambient noise, speech clarity, and terminology complexity.
          Regardless of accuracy rate, every generated document must be reviewed and validated by you before use.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Can ScribeCraft make mistakes?</summary>
        <div>
          <p>Yes. As with any NLP technology, potential issues include:</p>
          <ul>
            <li><strong>Transcription errors:</strong> phonetically similar words may be confused</li>
            <li><strong>Contextual misinterpretation:</strong> information may be placed in the wrong template section</li>
            <li><strong>Omissions:</strong> some details mentioned in conversation may be absent from the draft</li>
            <li><strong>AI hallucinations:</strong> in rare cases, information not explicitly mentioned may appear</li>
          </ul>
        </div>
      </details>
      <details class="faq-detail">
        <summary>What is "Mandatory Human Validation"?</summary>
        <div>
          <p>ScribeCraft operates on the "Human-in-the-Loop" principle. Every generated document is a draft. As a clinician, you must:</p>
          <ul>
            <li>Read the entire generated draft</li>
            <li>Correct any errors identified</li>
            <li>Validate the document before printing, exporting, or filing</li>
          </ul>
        </div>
      </details>
    </div>

    <!-- Features & Customisation -->
    <h3>Features & Customisation</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>Can I customise document templates?</summary>
        <p>
          Yes. ScribeCraft offers fully customisable templates. You can create your own or adapt existing ones.
          We provide pre-built templates for common specialties including General Practice, Cardiology, Paediatrics,
          Mental Health, Dermatology, and more.
        </p>
      </details>
      <details class="faq-detail">
        <summary>How do I export generated documents?</summary>
        <div>
          <ul>
            <li><strong>Copy</strong> — one-click copy to paste into any EPR system (EMIS Web, SystmOne, Vision)</li>
            <li><strong>Export as PDF</strong> — professional format, customisable with your practice details</li>
            <li><strong>Print directly</strong> — printed document includes your practice header</li>
          </ul>
        </div>
      </details>
      <details class="faq-detail">
        <summary>Can ScribeCraft integrate with my EPR system?</summary>
        <p>
          We can explore integration possibilities with your EPR. However, the greatest time saving comes from
          automatic draft generation — you can copy documents directly into your EPR in seconds regardless of integration.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Can I delete my data?</summary>
        <p>
          Yes. You can delete any generated document at any time. Under UK GDPR, you can also request complete
          deletion of all data associated with your account.
        </p>
      </details>
    </div>

    <!-- Technical Requirements -->
    <h3>Technical Requirements</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>What devices can I use?</summary>
        <p>
          ScribeCraft is a web application that works in any modern browser — Chrome, Firefox, Safari, or Edge.
          Access it from a desktop, laptop, tablet, or phone.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Do I need to install anything?</summary>
        <p>
          No. ScribeCraft runs entirely in your browser. No applications, extensions, or additional software required.
        </p>
      </details>
      <details class="faq-detail">
        <summary>What internet connection do I need?</summary>
        <p>
          A stable internet connection during recording. We recommend a minimum of 2 Mbps upload for smooth
          transcription. Standard surgery Wi-Fi is usually sufficient.
        </p>
      </details>
      <details class="faq-detail">
        <summary>What microphone do you recommend?</summary>
        <p>
          Your laptop or phone's built-in microphone works well in most situations. For consulting rooms with
          background noise or longer distances, we recommend a USB desk microphone or headset with microphone.
        </p>
      </details>
    </div>

    <!-- Onboarding -->
    <h3>Onboarding</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>How do I get started with ScribeCraft?</summary>
        <div>
          <ol>
            <li><strong>Initial discussion</strong> — we understand your practice volume and specialty mix.</li>
            <li><strong>Account and template setup</strong> — we configure ScribeCraft to your specialties and preferences.</li>
            <li><strong>Training session (15 minutes)</strong> — a short walkthrough showing your team how to use ScribeCraft.</li>
            <li><strong>Go live with ongoing support</strong> — our team is available for any questions.</li>
          </ol>
        </div>
      </details>
      <details class="faq-detail">
        <summary>How quickly will I start saving time?</summary>
        <p>
          From your very first consultation. After the 15-minute training session, you can use ScribeCraft
          immediately. Most practices report significant documentation time reduction from day one.
        </p>
      </details>
      <details class="faq-detail">
        <summary>What if I decide to stop using ScribeCraft?</summary>
        <p>
          Your data remains yours. You can export all generated documents, and we delete your data in accordance
          with UK GDPR and the Data Processing Agreement.
        </p>
      </details>
    </div>

    <!-- Compliance & Regulations -->
    <h3>Compliance & Regulations</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>Is ScribeCraft UK GDPR compliant?</summary>
        <p>
          Yes. ScribeCraft is fully compliant with UK GDPR and the Data Protection Act 2018. Your practice is
          the Data Controller; ApolloIQ is the Data Processor, formalised through a Data Processing Agreement (DPA)
          signed at account activation.
        </p>
      </details>
      <details class="faq-detail">
        <summary>Is ScribeCraft a medical device?</summary>
        <p>
          ScribeCraft is registered as a Class I medical device under the UK Medical Devices Regulations 2002
          (as amended). It is classified as an administrative documentation tool and does not perform diagnostic
          or therapeutic functions.
        </p>
      </details>
      <details class="faq-detail">
        <summary>What data rights do I have?</summary>
        <div>
          <p>Under UK GDPR, you have the right to:</p>
          <ul>
            <li><strong>Access</strong> — know what data is processed</li>
            <li><strong>Rectification</strong> — correct inaccurate data</li>
            <li><strong>Erasure</strong> — request data deletion ("right to be forgotten")</li>
            <li><strong>Portability</strong> — receive data in a structured format</li>
            <li><strong>Objection</strong> — object to processing under certain conditions</li>
          </ul>
        </div>
      </details>
    </div>

    <!-- Support -->
    <h3>Support</h3>
    <div class="faq-group">
      <details class="faq-detail">
        <summary>How do I contact support?</summary>
        <div>
          <ul>
            <li><strong>Email:</strong> contact@apolloiq.co.uk</li>
            <li><strong>In-platform chat:</strong> Available within the Merlin interface</li>
            <li><strong>Contact form:</strong> Available on our website</li>
          </ul>
          <p>
            Our support team responds during business hours (Monday-Friday, 9:00-18:00). For urgent issues
            related to data access, we respond within 24 hours.
          </p>
        </div>
      </details>
    </div>
  </section>

