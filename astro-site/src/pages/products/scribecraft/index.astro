  <!-- ════════════════════════════════════════════════════════ -->
  <!-- PRICING                                                   -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="pricing">
    <h2>Pricing</h2>
    <p>Simple, transparent pricing with no hidden fees.</p>

    <div class="sc-pricing-cards">
      <div class="sc-pricing-card">
        <div class="sc-pricing-label">Individual</div>
        <div class="sc-pricing-price">&pound;24.99</div>
        <div class="sc-pricing-billed">per user / month</div>
        <ul class="sc-pricing-features">
          <li>Full access to ScribeCraft</li>
          <li>Real-time transcription</li>
          <li>All clinical note formats</li>
          <li>Multi-specialty templates</li>
        </ul>
        <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
      </div>
      <div class="sc-pricing-card">
        <div class="sc-pricing-label">Organisation</div>
        <div class="sc-pricing-price">&pound;16.99</div>
        <div class="sc-pricing-billed">per user / month</div>
        <div class="sc-pricing-calc">
          <div class="sc-pricing-calc-row">
            <span>Min. users</span>
            <span class="sc-pricing-calc-val">5</span>
          </div>
