---
import ProductDocsLayout from '../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Overview', href: '#overview' },
  {
    label: 'Features',
    href: '#features',
    children: [
      { label: 'Live Consultation Capture', href: '#live-consultation-capture' },
      { label: 'Flexible Clinical Formats', href: '#flexible-clinical-formats' },
      { label: 'Multi-Specialty Support', href: '#multi-specialty-support' },
      { label: 'EPR-Ready Output', href: '#epr-ready-output' },
    ],
  },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'By the Numbers', href: '#by-the-numbers' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Getting Started', href: '#getting-started' },
];
---

<ProductDocsLayout
  title="ScribeCraft - AI Clinical Note-Taking | ApolloIQ"
  description="ScribeCraft is an AI-powered clinical documentation tool that transforms patient consultations into structured clinical notes in real time."
  heroTitle="ScribeCraft"
  heroSubtitle="Listen. Understand. Document. Your AI assistant that transforms patient consultations into structured clinical notes in real time."
  heroIcon={`${base}images/icon-scribe.svg`}
  sidebarItems={sidebarItems}
  helpCentreHref={`${base}products/scribecraft/help-centre`}
  helpCentreDescription="Guides, FAQs & resources"
>

  <!-- Hero Actions -->
  <a slot="hero-actions" href={`${base}contact-us`} class="btn-primary">Activate Spell</a>
  <a slot="hero-actions" href="#book-demo" class="btn-secondary" data-product="scribecraft">Book a Demo</a>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- OVERVIEW                                                 -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="overview">
    <h2>Overview</h2>

    <div class="sc-overview-hero-card">
      <div class="sc-overview-hero-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </div>
      <span class="sc-badge">CLASS I MEDICAL DEVICE</span>
      <p class="sc-overview-hero-text">
        ScribeCraft is an AI-powered clinical documentation tool that listens to clinician-patient consultations,
        transcribes the conversation in real time, and automatically generates structured, accurate clinical notes
        — ready to copy into your EPR system.
      </p>
    </div>

    <div class="sc-overview-stats-row">
      <div class="sc-overview-stat">
        <div class="sc-overview-stat-icon sc-overview-stat-icon--blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <strong class="sc-overview-stat-value">70%</strong>
          <span class="sc-overview-stat-label">of consultation time saved</span>
        </div>
      </div>
      <div class="sc-overview-stat">
        <div class="sc-overview-stat-icon sc-overview-stat-icon--green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div>
          <strong class="sc-overview-stat-value">2 hours</strong>
          <span class="sc-overview-stat-label">reclaimed every day</span>
        </div>
      </div>
    </div>

    <p>
      Up to <strong>70% of consultation time</strong> is lost to data entry. The leading cause of clinician burnout
      is after-hours administrative work. ScribeCraft eliminates this burden by handling the documentation so you
      can focus on what matters: the patient.
    </p>

    <div class="sc-overview-notice">
      <div class="sc-overview-notice-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <p>
        ScribeCraft is a <strong>registered Class I medical device</strong>, designed as an administrative support tool.
        It does not provide diagnoses, suggest treatments, or replace clinical judgement. Every note generated is a
        draft that requires clinician review and validation before use.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FEATURES                                                 -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="features">
    <h2>Key Features</h2>
    <p>
      Purpose-built for NHS and UK primary care. ScribeCraft understands medical terminology and structures notes
      the way clinicians need them.
    </p>

    <div class="sc-features-grid">
      <div id="live-consultation-capture" class="sc-feature-card" style="scroll-margin-top: 100px;">
        <div class="sc-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </div>
        <h3>Live Consultation Capture</h3>
        <p>
          Transcribes and structures your patient conversations in real time — face-to-face, telephone, or video
          consultations. Works in the background without interrupting your clinical workflow.
        </p>
      </div>

      <div id="flexible-clinical-formats" class="sc-feature-card" style="scroll-margin-top: 100px;">
        <div class="sc-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3>Flexible Clinical Formats</h3>
        <p>
          SOAP notes, clinical letters, referral letters, and specialty-specific templates. Choose the right format
          before recording and ScribeCraft structures information exactly the way you need it.
        </p>
      </div>

      <div id="multi-specialty-support" class="sc-feature-card" style="scroll-margin-top: 100px;">
        <div class="sc-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Multi-Specialty Support</h3>
        <p>
          GP, Cardiology, Paediatrics, Neurology, Dermatology, Mental Health, and more. Templates actively guide
          the AI — a cardiology template prioritises cardiovascular terms, dermatology is optimised for lesion descriptions.
        </p>
      </div>

      <div id="epr-ready-output" class="sc-feature-card" style="scroll-margin-top: 100px;">
        <div class="sc-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
        </div>
        <h3>EPR-Ready Output</h3>
        <p>
          One-click copy-paste into EMIS Web, SystmOne, Vision, or any EPR system. Also exportable as PDF for
          printing or patient records.
        </p>
      </div>

      <div class="sc-feature-card">
        <div class="sc-feature-icon sc-feature-icon-green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>No Installation Required</h3>
        <p>
          Runs directly in your browser — Chrome, Edge, Firefox, or Safari. Desktop, laptop, tablet, or phone. No
          software or extensions needed.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- HOW IT WORKS                                             -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="how-it-works">
    <h2>How It Works</h2>
    <p>
      ScribeCraft is built for clinical ease — no steep learning curve, no interruptions, just seamless transcription.
      Set up takes 15 minutes and you start saving time from the very first consultation.
    </p>

    <div class="sc-steps">
      <div class="sc-step">
        <div class="sc-step-num">1</div>
        <div class="sc-step-content">
          <h3>Log into Merlin</h3>
          <p>Access ScribeCraft through your dedicated account on the Merlin platform. No software to install — it runs in your browser.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">2</div>
        <div class="sc-step-content">
          <h3>Choose a Note Format</h3>
          <p>Select from SOAP notes, clinical letters, referral letters, or specialty-specific templates.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">3</div>
        <div class="sc-step-content">
          <h3>Start a New Session</h3>
          <p>Press "New Session" to begin recording. ScribeCraft captures your consultation in the background.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">4</div>
        <div class="sc-step-content">
          <h3>Speak Naturally</h3>
          <p>Conduct your consultation as usual. Real-time transcription handles the rest, optimised for medical terminology.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">5</div>
        <div class="sc-step-content">
          <h3>Notes Structured Automatically</h3>
          <p>When you stop the session, the transcription is organised into your chosen template — a complete clinical note ready for review.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">6</div>
        <div class="sc-step-content">
          <h3>Review, Copy, and File</h3>
          <p>Validate the draft, then copy into your EPR system or export as PDF.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- SAFETY & COMPLIANCE LINK                                -->
  <!-- ════════════════════════════════════════════════════════ -->
  <div class="sc-safety-link-box">
    <div class="sc-safety-link-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    </div>
    <div class="sc-safety-link-content">
      <h3>Safety & Compliance</h3>
      <p>Class I Medical Device. DCB 0129 compliant. ISO 27001 aligned. UK GDPR compliant. Zero-retention architecture.</p>
      <a href={`${base}products/scribecraft/help-centre/safety`} class="sc-safety-link-cta">View full safety documentation &rarr;</a>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- BY THE NUMBERS                                           -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="by-the-numbers">
    <h2>By the Numbers</h2>
    <p>The impact on your practice.</p>

    <div class="sc-stats-grid">
      <div class="sc-stat-card">
        <div class="sc-stat-icon sc-stat-icon--blue">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="sc-stat-value">70%</div>
        <div class="sc-stat-label">documentation time saved per consultation</div>
      </div>
      <div class="sc-stat-card">
        <div class="sc-stat-icon sc-stat-icon--blue">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
        </div>
        <div class="sc-stat-value">2 hrs</div>
        <div class="sc-stat-label">reclaimed every day</div>
      </div>
      <div class="sc-stat-card">
        <div class="sc-stat-icon sc-stat-icon--green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="sc-stat-value sc-stat-value--green">100%</div>
        <div class="sc-stat-label">UK GDPR compliant</div>
      </div>
      <div class="sc-stat-card">
        <div class="sc-stat-icon sc-stat-icon--green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="sc-stat-value sc-stat-value--green">24/7</div>
        <div class="sc-stat-label">available 365 days a year</div>
      </div>
    </div>

    <div class="sc-cert-grid">
      <div class="sc-cert-card">
        <div class="sc-cert-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <strong>Class I Medical Device</strong>
        <span>UK MDR 2002</span>
      </div>
      <div class="sc-cert-card">
        <div class="sc-cert-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <strong>ISO 27001</strong>
        <span>Security Standards</span>
      </div>
      <div class="sc-cert-card">
        <div class="sc-cert-icon sc-cert-icon--green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 6 6"/><line x1="11" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="11" y2="12"/><polyline points="16 12 18 12 21 12"/><line x1="3" y1="18" x2="8" y2="18"/><line x1="13" y1="18" x2="21" y2="18"/></svg>
        </div>
        <strong>Zero-Retention</strong>
        <span>Audio Architecture</span>
      </div>
      <div class="sc-cert-card">
        <div class="sc-cert-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        </div>
        <strong>Microsoft Azure</strong>
        <span>Enterprise Infrastructure</span>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- PRICING                                                   -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="pricing">
    <h2>Pricing</h2>
    <p>Simple, transparent pricing with no hidden fees.</p>

    <div class="sc-pricing-cards">
      <div class="sc-pricing-card">
        <div class="sc-pricing-label">Individual</div>
        <div class="sc-pricing-price">&pound;24.99</div>
        <div class="sc-pricing-billed">per user / month</div>
        <ul class="sc-pricing-features">
          <li>Full access to ScribeCraft</li>
          <li>Real-time transcription</li>
          <li>All clinical note formats</li>
          <li>Multi-specialty templates</li>
        </ul>
        <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Activate Spell</a>
      </div>
      <div class="sc-pricing-card">
        <div class="sc-pricing-label">Organisation</div>
        <div class="sc-pricing-price">&pound;16.99</div>
        <div class="sc-pricing-billed">per user / month</div>
        <div class="sc-pricing-calc">
          <div class="sc-pricing-calc-row">
            <span>Min. users</span>
            <span class="sc-pricing-calc-val">5</span>
          </div>
          <div class="sc-pricing-calc-row">
            <span>Example (10 users)</span>
            <span class="sc-pricing-calc-val">&pound;169.90/mo</span>
          </div>
        </div>
        <ul class="sc-pricing-features">
          <li>Everything in Individual</li>
          <li>Volume discount pricing</li>
          <li>Practice-wide deployment</li>
          <li>Priority support</li>
        </ul>
        <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Activate Spell</a>
      </div>
      <div class="sc-pricing-card">
        <div class="sc-pricing-label">Enterprise</div>
        <div class="sc-pricing-price" style="font-size: 2.25rem;">Custom</div>
        <div class="sc-pricing-billed">tailored to your needs</div>
        <ul class="sc-pricing-features">
          <li>Everything in Organisation</li>
          <li>Custom user limits</li>
          <li>Dedicated account manager</li>
          <li>Custom integrations</li>
        </ul>
        <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- GETTING STARTED                                          -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="getting-started">
    <h2>Getting Started</h2>
    <p>
      ScribeCraft is designed for rapid deployment. Most practices begin saving time from day one.
    </p>

    <div class="sc-steps">
      <div class="sc-step">
        <div class="sc-step-num">1</div>
        <div class="sc-step-content">
          <h3>Initial Discussion</h3>
          <p>We understand your practice volume, specialty mix, and documentation needs.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">2</div>
        <div class="sc-step-content">
          <h3>Account & Template Setup</h3>
          <p>We configure ScribeCraft with templates tailored to your specialties and preferences.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">3</div>
        <div class="sc-step-content">
          <h3>Training Session (15 minutes)</h3>
          <p>A short, hands-on walkthrough showing your team how to use ScribeCraft effectively.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">4</div>
        <div class="sc-step-content">
          <h3>Go Live with Ongoing Support</h3>
          <p>Start using ScribeCraft immediately. Our support team is available for any questions or fine-tuning.</p>
        </div>
      </div>
    </div>

    <div class="highlight-box">
      <h3>Technical Requirements</h3>
      <p>
        Any modern browser (Chrome, Edge, Firefox, Safari), a stable internet connection (2 Mbps upload recommended),
        and a microphone — the built-in mic on your laptop or phone works well in most settings. No installation or
        additional software required.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- HELP CENTRE LINK                                        -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="help-centre-link">
    <h2>Help Centre</h2>
    <p>Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice.</p>
    <div class="content-card" style="text-align: center; padding: 2.5rem;">
      <h3 style="margin-bottom: 0.75rem;">Need Help Getting Started?</h3>
      <p style="margin-bottom: 1.5rem;">Visit our comprehensive Help Centre for quick start guides, accuracy tips, FAQs, and practice readiness tools.</p>
      <a href={`${base}products/scribecraft/help-centre`} class="btn-primary">Visit Help Centre</a>
    </div>
  </section>

</ProductDocsLayout>

<style>
  /* ── Overview Hero Card ── */
  .sc-overview-hero-card {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.05) 0%, rgba(0, 195, 147, 0.04) 50%, rgba(44, 112, 235, 0.03) 100%);
    border: 1px solid rgba(44, 112, 235, 0.12);
    border-radius: 20px;
    padding: 2.25rem;
    margin-bottom: 1.75rem;
    position: relative;
    overflow: hidden;
  }

  .sc-overview-hero-card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(44, 112, 235, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .sc-overview-hero-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 16px rgba(44, 112, 235, 0.25);
  }

  .sc-overview-hero-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin-top: 1.25rem;
  }

  /* ── Overview Stats Row ── */
  .sc-overview-stats-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .sc-overview-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.08);
    border-radius: 14px;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .sc-overview-stat:hover {
    border-color: rgba(44, 112, 235, 0.2);
    box-shadow: 0 4px 20px rgba(44, 112, 235, 0.08);
