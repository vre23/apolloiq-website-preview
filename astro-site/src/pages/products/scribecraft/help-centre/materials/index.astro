---
import ProductDocsLayout from '../../../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Quick Start Guide', href: `${base}products/scribecraft/help-centre/quick-start` },
  { label: 'Accuracy Optimisation', href: `${base}products/scribecraft/help-centre/accuracy` },
  { label: 'FAQ', href: `${base}products/scribecraft/help-centre/faq` },
  { label: 'Materials & Explainers', href: `${base}products/scribecraft/help-centre/materials` },
  { label: 'Practice Readiness Audit', href: `${base}products/scribecraft/help-centre/practice-audit` },
];
---

<ProductDocsLayout
  title="Materials & Explainers - ScribeCraft Help Centre | ApolloIQ"
  description="Resources for patients, practices, and clinicians using ScribeCraft."
  sidebarItems={sidebarItems}
  heroTitle="ScribeCraft Help Centre"
  heroSubtitle="Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice."
  heroIcon={`${base}images/icon-scribe.svg`}
>

  <a href={`${base}products/scribecraft/help-centre`} class="help-back-link">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Back to Help Centre
  </a>

  <section id="materials">
    <h2>Materials & Explainers</h2>
    <p>Resources for patients, practices, and clinicians — plus an ROI calculator to estimate your savings.</p>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FOR PATIENTS                                             -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="for-patients">
    <h2>For Patients</h2>
    <p>This information can be shared with patients or displayed in your waiting room.</p>

    <div class="content-card">
      <h3>What is ScribeCraft?</h3>
      <p>
        ScribeCraft is a digital assistant used by your clinician to help with note-taking during your consultation.
        It listens to the conversation and creates a written summary for your medical records.
      </p>
    </div>

    <div class="content-card">
      <h3>What happens during the consultation?</h3>
      <ul>
        <li>Your clinician will ask for your permission before using ScribeCraft</li>
        <li>The conversation is recorded by the device's microphone</li>
        <li>ScribeCraft creates a draft of clinical notes from the conversation</li>
        <li>Your clinician reviews and checks the notes before they are saved</li>
        <li>The audio recording is automatically deleted — it is never stored</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Is my data safe?</h3>
      <ul>
        <li>Audio recordings are deleted immediately after processing</li>
        <li>All data is encrypted and securely stored</li>
        <li>Only your clinician can access the generated notes</li>
        <li>Your data is never used to train AI systems</li>
        <li>You can request deletion of your data at any time</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Can I refuse?</h3>
      <p>
        Absolutely. If you prefer not to have ScribeCraft used during your consultation, simply tell your clinician.
        Your care will continue exactly as normal. There is no penalty or change in the quality of service.
      </p>
    </div>

    <div class="highlight-box">
      <strong>Printable Materials:</strong> ApolloIQ provides free printable waiting room posters and patient
      information leaflets. Contact us at <strong>contact@apolloiq.co.uk</strong> to request your materials.
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FOR PRACTICES                                            -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="for-practices">
    <h2>For Practices</h2>
    <p>Key information for practice managers and administrative teams considering ScribeCraft.</p>

    <div class="content-card">
      <h3>What does ScribeCraft do for your practice?</h3>
      <ul>
        <li>Reduces clinician documentation time by up to 70%</li>
        <li>Reclaims up to 2 hours per clinician per day</li>
        <li>Reduces after-hours administrative work and clinician burnout</li>
        <li>Improves documentation consistency and completeness</li>
        <li>No hardware installation — runs in any web browser</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Implementation</h3>
      <ul>
        <li>Setup takes approximately 15 minutes per clinician</li>
        <li>No IT infrastructure changes required</li>
        <li>Works alongside existing EPR systems (EMIS Web, SystmOne, Vision)</li>
        <li>ApolloIQ provides training and ongoing support</li>
        <li>Customisable templates for each specialty in your practice</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Compliance & Governance</h3>
      <ul>
        <li>Registered Class I Medical Device (UK MDR 2002)</li>
        <li>Fully UK GDPR and Data Protection Act 2018 compliant</li>
        <li>Data Processing Agreement (DPA) signed at account activation</li>
        <li>Your practice is the Data Controller; ApolloIQ is the Data Processor</li>
        <li>ISO 27001 aligned information security management</li>
      </ul>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- FOR CLINICIANS                                           -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="for-clinicians">
    <h2>For Clinicians</h2>
    <p>Clinical guidance for integrating ScribeCraft into your daily workflow.</p>

    <div class="content-card">
      <h3>Your responsibilities</h3>
      <ul>
        <li><strong>Obtain consent</strong> — Inform the patient and obtain their consent before each recording</li>
        <li><strong>Review every note</strong> — ScribeCraft generates drafts. You must read, correct, and validate every document before use</li>
        <li><strong>Maintain clinical judgement</strong> — ScribeCraft is an administrative tool. It does not diagnose, recommend treatment, or replace your clinical expertise</li>
        <li><strong>Report concerns</strong> — If you notice recurring errors or concerns, contact our support team</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Best practices</h3>
      <ul>
        <li>Choose the correct template for each consultation type</li>
        <li>Position your microphone optimally (see our Accuracy Optimisation guide)</li>
        <li>Review notes immediately after each consultation while details are fresh</li>
        <li>Pay special attention to medication names, doses, and numerical values</li>
        <li>Use the feedback feature to help improve ScribeCraft's accuracy</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Clinical safety</h3>
      <p>
        ScribeCraft is registered as a Class I medical device — an administrative documentation tool. It has no
        diagnostic or therapeutic function. Every AI-generated document is clearly marked as a draft requiring human
        validation. This aligns with the Human-in-the-Loop principle and the EU AI Act transparency requirements.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- ROI CALCULATOR                                           -->
  <!-- ════════════════════════════════════════════════════════ -->
  <section id="roi-calculator">
    <h2>ROI Calculator</h2>
    <p>Estimate the time and cost savings ScribeCraft can deliver for your practice.</p>

    <div class="roi-grid">
      <div class="roi-inputs">
        <h3>Your Practice Details</h3>
        <div class="slider-group">
          <div class="slider-label">
            <span>Clinicians using ScribeCraft</span>
            <span class="slider-value" id="val-clinicians">3</span>
          </div>
          <input type="range" min="1" max="20" value="3" id="sl-clinicians" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Consultations per clinician per day</span>
            <span class="slider-value" id="val-consults">25</span>
          </div>
          <input type="range" min="5" max="50" value="25" id="sl-consults" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Minutes on documentation per consultation</span>
            <span class="slider-value" id="val-doctime">5</span>
          </div>
          <input type="range" min="2" max="15" value="5" id="sl-doctime" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Working days per week</span>
            <span class="slider-value" id="val-days">5</span>
          </div>
          <input type="range" min="3" max="6" value="5" id="sl-days" />
        </div>
      </div>

      <div class="roi-results-card">
        <h3>Estimated Savings</h3>
        <div class="result-item">
          <div class="result-num" id="res-hours-day">&mdash;</div>
          <div class="result-label">Hours saved per day (all clinicians)</div>
        </div>
        <div class="result-item">
          <div class="result-num" id="res-hours-week">&mdash;</div>
          <div class="result-label">Hours saved per week</div>
        </div>
        <div class="result-item">
          <div class="result-num" id="res-hours-year">&mdash;</div>
          <div class="result-label">Hours saved per year</div>
        </div>
        <div class="roi-highlight">
          <div class="result-num" id="res-consults-extra">&mdash;</div>
          <div class="result-label">Additional consultations possible per week</div>
        </div>
      </div>
    </div>
    <p class="roi-disclaimer">Based on ScribeCraft reducing documentation time by 70%. Figures are estimates and actual savings may vary.</p>
  </section>

</ProductDocsLayout>

<style>
  .help-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-brand-blue);
    font-weight: 500;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }
  .help-back-link:hover { opacity: 0.7; }

  /* ── ROI Calculator ── */
  .roi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .roi-inputs {
    background: #fff;
    border: none;
    border-radius: var(--radius-card);
    padding: 32px;
    box-shadow: 4px 4px 30px 10px rgba(0, 0, 0, 0.06);
  }

  .roi-inputs h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 1.75rem;
  }

  .slider-group {
    margin-bottom: 1.75rem;
  }

  .slider-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.625rem;
  }

  .slider-label span {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-brand-black);
  }

  .slider-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-blue);
  }

  input[type='range'] {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    background: linear-gradient(90deg, rgba(44, 112, 235, 0.15), rgba(0, 195, 147, 0.15));
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }

  input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    cursor: pointer;
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(44, 112, 235, 0.35);
  }

  input[type='range']::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    cursor: pointer;
    border: 3px solid #fff;
  }

  .roi-results-card {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.06), rgba(0, 195, 147, 0.06));
    border-radius: var(--radius-card);
    padding: 32px;
    color: var(--color-brand-black);
    position: sticky;
    top: 100px;
    box-shadow: var(--shadow-card-lg);
    border: 1px solid rgba(44, 112, 235, 0.12);
  }

  .roi-results-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
    color: var(--color-brand-black);
  }

  .result-item {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-brand-grey-border);
  }

  .result-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .result-num {
    font-size: 2rem;
    font-weight: 800;
    color: #00c393;
    line-height: 1;
    margin-bottom: 6px;
  }

  .result-label {
    font-size: 0.85rem;
    color: var(--color-brand-grey-muted);
  }

  .roi-highlight {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.1), rgba(0, 195, 147, 0.1));
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    margin-top: 1.25rem;
    border: 1px solid rgba(44, 112, 235, 0.15);
  }

  .roi-highlight .result-num {
    color: var(--color-brand-blue);
    font-size: 2.25rem;
  }

  .roi-highlight .result-label {
    color: var(--color-brand-grey-muted);
  }

  .roi-disclaimer {
    color: var(--color-brand-grey-muted);
    font-size: 0.8rem;
    margin-top: 1rem;
  }

  @media (max-width: 860px) {
    .roi-grid {
      grid-template-columns: 1fr;
    }

    .roi-results-card {
      position: static;
    }
  }
</style>

<script>
  // ── ROI Calculator ──
  const slClinicians = document.getElementById('sl-clinicians') as HTMLInputElement;
  const slConsults = document.getElementById('sl-consults') as HTMLInputElement;
  const slDoctime = document.getElementById('sl-doctime') as HTMLInputElement;
  const slDays = document.getElementById('sl-days') as HTMLInputElement;

  function calcROI() {
    const c = parseInt(slClinicians.value);
    const n = parseInt(slConsults.value);
    const d = parseInt(slDoctime.value);
    const w = parseInt(slDays.value);

    document.getElementById('val-clinicians')!.textContent = String(c);
    document.getElementById('val-consults')!.textContent = String(n);
    document.getElementById('val-doctime')!.textContent = String(d);
    document.getElementById('val-days')!.textContent = String(w);

    const savedMinPerDay = c * n * d * 0.7;
    const hDay = (savedMinPerDay / 60).toFixed(1);
    const hWeek = (parseFloat(hDay) * w).toFixed(0);
    const hYear = (parseFloat(hWeek) * 48).toFixed(0);
    const extraConsults = Math.floor((savedMinPerDay * w) / (10 * 5));

    document.getElementById('res-hours-day')!.textContent = hDay + ' hrs';
    document.getElementById('res-hours-week')!.textContent = hWeek + ' hrs';
    document.getElementById('res-hours-year')!.textContent = Number(hYear).toLocaleString() + ' hrs';
    document.getElementById('res-consults-extra')!.textContent = '+' + extraConsults;
  }

  if (slClinicians) {
    [slClinicians, slConsults, slDoctime, slDays].forEach((sl) => {
      sl.addEventListener('input', calcROI);
    });
    calcROI();
  }
</script>
