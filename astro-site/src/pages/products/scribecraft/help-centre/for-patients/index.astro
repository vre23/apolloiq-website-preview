---
import ProductDocsLayout from '../../../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Quick Start Guide', href: `${base}products/scribecraft/help-centre/quick-start` },
  { label: 'Accuracy Optimisation', href: `${base}products/scribecraft/help-centre/accuracy` },
  { label: 'FAQ', href: `${base}products/scribecraft/help-centre/faq` },
  { label: 'Safety & Compliance', href: `${base}products/scribecraft/help-centre/safety` },
  { label: 'For Patients', href: `${base}products/scribecraft/help-centre/for-patients` },
  { label: 'For Practices', href: `${base}products/scribecraft/help-centre/for-practices` },
  { label: 'Practice Readiness Audit', href: `${base}products/scribecraft/help-centre/practice-audit` },
];
---

<ProductDocsLayout
  title="For Patients - ScribeCraft Help Centre | ApolloIQ"
  description="Information for patients about ScribeCraft AI clinical documentation."
  sidebarItems={sidebarItems}
  heroTitle="ScribeCraft Help Centre"
  heroSubtitle="Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice."
  heroIcon={`${base}images/icon-scribe.svg`}
>

  <a href={`${base}products/scribecraft/help-centre`} class="help-back-link">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Back to Help Centre
  </a>

  <section id="for-patients">
    <h2>For Patients</h2>

    <div class="content-card">
      <h3>What is ScribeCraft?</h3>
      <p>
        ScribeCraft is a digital assistant used by your clinician to help with note-taking during your consultation.
        Instead of typing while you speak, your clinician can focus entirely on you. ScribeCraft listens to the
        conversation and creates a written summary for your medical records — which your clinician then reviews and
        checks before saving.
      </p>
    </div>

    <div class="content-card">
      <h3>What happens during your consultation?</h3>
      <ul>
        <li>Your clinician will let you know that ScribeCraft is being used</li>
        <li>The conversation is recorded by the device's microphone</li>
        <li>ScribeCraft creates a draft of clinical notes from the conversation</li>
        <li>Your clinician reviews and checks the notes before they are saved</li>
        <li>The audio recording is automatically deleted — it is never stored</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Is my data safe?</h3>
      <ul>
        <li>Audio recordings are deleted immediately after processing — they are never stored</li>
        <li>All data is encrypted and securely stored within the United Kingdom</li>
        <li>Only your clinician can access the generated notes</li>
        <li>Your data is never used to train AI systems</li>
        <li>You can request deletion of your data at any time</li>
      </ul>
    </div>

    <div class="content-card">
      <h3>Can I opt out?</h3>
      <p>
        Absolutely. If you'd prefer ScribeCraft isn't used during your consultation, simply let your clinician know
        at the start. Your care will continue exactly as normal — there is no change in the quality of service you
        receive.
      </p>
    </div>

    <h2>Your Questions Answered</h2>

    <div class="content-card">
      <h3>Who has access to my medical information?</h3>
      <p>
        Only your clinician has access to the notes generated by ScribeCraft. The notes are reviewed and saved into
        your medical record within the practice's clinical system. ApolloIQ (the company behind ScribeCraft) does
        not have access to the content of your consultations or notes.
      </p>
    </div>

    <div class="content-card">
      <h3>Where is my data stored?</h3>
      <p>
        All data is processed and stored within the United Kingdom, on infrastructure that meets ISO 27001 security
        standards. Data is encrypted both in transit and at rest.
      </p>
    </div>

    <div class="content-card">
      <h3>Do you store audio recordings of the consultation?</h3>
      <p>
        No. Audio is processed in real time to create a text transcription, and is then immediately and permanently
        deleted. ScribeCraft never stores audio recordings. Only the text notes — which your clinician reviews and
        approves — are retained as part of your medical record.
      </p>
    </div>

    <div class="content-card">
      <h3>How is my data used?</h3>
      <p>
        ScribeCraft processes your data solely for the purpose of generating clinical documentation for your
        clinician. Your data is:
      </p>
      <ul>
        <li>Never sold or shared with third parties</li>
        <li>Never used to train or improve AI models</li>
        <li>Only accessible to your clinician</li>
      </ul>
    </div>
  </section>

</ProductDocsLayout>

<style>
  .help-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-brand-blue);
    font-weight: 500;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }
  .help-back-link:hover { opacity: 0.7; }
</style>
