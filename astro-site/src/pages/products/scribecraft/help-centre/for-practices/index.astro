---
import ProductDocsLayout from '../../../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Quick Start Guide', href: `${base}products/scribecraft/help-centre/quick-start` },
  { label: 'Accuracy Optimisation', href: `${base}products/scribecraft/help-centre/accuracy` },
  { label: 'FAQ', href: `${base}products/scribecraft/help-centre/faq` },
  { label: 'Safety & Compliance', href: `${base}products/scribecraft/help-centre/safety` },
  { label: 'For Patients', href: `${base}products/scribecraft/help-centre/for-patients` },
  { label: 'For Practices', href: `${base}products/scribecraft/help-centre/for-practices` },
  { label: 'Practice Readiness Audit', href: `${base}products/scribecraft/help-centre/practice-audit` },
];
---

<ProductDocsLayout
  title="For Practices - ScribeCraft Help Centre | ApolloIQ"
  description="Implementation guide, GDPR compliance, and ROI calculator for practices using ScribeCraft."
  sidebarItems={sidebarItems}
  heroTitle="ScribeCraft Help Centre"
  heroSubtitle="Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice."
  heroIcon={`${base}images/icon-scribe.svg`}
>

  <a href={`${base}products/scribecraft/help-centre`} class="help-back-link">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Back to Help Centre
  </a>

  <section id="benefits">
    <h2>Benefits of ScribeCraft for Your Practice</h2>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Reduced documentation time</h3>
        <p>Clinicians focus on the patient, not paperwork. ScribeCraft automatically captures relevant information from the consultation.</p>
      </div>
    </div>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Complete & accurate documentation</h3>
        <p>All consultation details are recorded correctly, reducing the risk of omissions or manual transcription errors.</p>
      </div>
    </div>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Increased operational efficiency</h3>
        <p>Less time on administration means more consultations and a better experience for both clinicians and patients.</p>
      </div>
    </div>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Integration with clinical systems</h3>
        <p>Generated notes can be saved directly into the patient's electronic health record (EMIS Web, SystmOne, Vision).</p>
      </div>
    </div>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>No hardware installation</h3>
        <p>Runs in any web browser. No apps, extensions, or additional software required.</p>
      </div>
    </div>
  </section>

  <section id="setup">
    <h2>Getting Set Up</h2>
    <p>ScribeCraft is designed for rapid deployment. Most practices begin saving time from day one.</p>
    <div class="sc-steps">
      <div class="sc-step">
        <div class="sc-step-num">1</div>
        <div class="sc-step-content">
          <h3>Create accounts</h3>
          <p>Visit <strong><a href="https://merlin.apolloiq.co.uk" target="_blank" rel="noopener">merlin.apolloiq.co.uk</a></strong> and create accounts for each clinician who will use the platform.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">2</div>
        <div class="sc-step-content">
          <h3>Select templates</h3>
          <p>Choose consultation templates suited to your clinical specialties (general practice, dermatology, cardiology, etc.).</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">3</div>
        <div class="sc-step-content">
          <h3>Set up equipment</h3>
          <p>Ensure each consulting room has a working microphone. The built-in microphones in laptops or tablets work well in most settings.</p>
        </div>
      </div>
      <div class="sc-step">
        <div class="sc-step-num">4</div>
        <div class="sc-step-content">
          <h3>Train the team</h3>
          <p>Walk clinicians through the workflow: starting the recording, reviewing the notes, and saving to the clinical system. Takes approximately 15 minutes per clinician.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="gdpr">
    <h2>GDPR Compliance</h2>
    <p>When introducing ScribeCraft, your practice's existing privacy policy should be updated to reflect this new processing activity.</p>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Privacy Policy Addendum</h3>
        <p>Add the following to your practice's privacy policy (adapt as needed):</p>
        <h4>AI-Assisted Clinical Documentation</h4>
        <p>This practice uses <strong>ScribeCraft</strong>, provided by ApolloIQ Ltd, to assist clinicians with documenting consultations. ScribeCraft is an AI-powered tool that listens to the clinician-patient conversation and generates a draft of the clinical notes, which the clinician then reviews, edits, and approves before saving to your medical record.</p>
        <h4>What data is processed?</h4>
        <p>During a consultation, the audio of the conversation is temporarily processed to produce a text transcription. The audio is processed in real time and is <strong>never stored</strong>. Only the clinician-approved written notes are retained as part of your medical record.</p>
        <h4>Legal basis for processing</h4>
        <p>Processing is carried out under <strong>Article 6(1)(e) UK GDPR</strong> (public interest — healthcare provision) and <strong>Article 9(2)(h)</strong> (processing necessary for health or social care).</p>
        <h4>Data controller and processor</h4>
        <p><strong>[Practice Name]</strong> remains the Data Controller. ApolloIQ Ltd acts as Data Processor under a signed Data Processing Agreement (DPA).</p>
        <h4>Where is data stored?</h4>
        <p>All data is processed and stored within the <strong>United Kingdom</strong>. Infrastructure is ISO 27001 aligned; data is encrypted in transit and at rest.</p>
        <h4>Patient rights</h4>
        <p>Patient rights under UK GDPR are unchanged. Patients can opt out of ScribeCraft at any time by telling their clinician.</p>
      </div>
    </div>

    <div class="sc-info-card">
      <div class="sc-info-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="sc-info-content">
        <h3>Informing Patients</h3>
        <p>Under UK GDPR, no separate consent form is required — the legal basis is "public interest" (healthcare provision). However, patients should be informed:</p>
        <ul>
          <li>Display a waiting room notice (see our <a href={`${base}products/scribecraft/help-centre/for-patients`}>For Patients</a> page for suggested wording)</li>
          <li>Clinicians should briefly mention ScribeCraft at the start of consultations</li>
          <li>Patients can opt out at any time — their care continues as normal</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="checklist">
    <h2>Practice Checklist</h2>
    <p>Complete these steps before going live with ScribeCraft:</p>
    <div class="sc-checklist">
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>Privacy policy updated with ScribeCraft addendum</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>Updated privacy policy published on practice website</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>Waiting room notice or patient explainer displayed</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>Record of Processing Activities (ROPA) updated</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>DPIA completed or review decision documented</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>Data Processing Agreement (DPA) signed with ApolloIQ</span>
      </div>
      <div class="sc-check-item">
        <div class="sc-check-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>All clinicians briefed on informing patients about ScribeCraft</span>
      </div>
    </div>
  </section>

  <section id="roi-calculator">
    <h2>ROI Calculator</h2>
    <p>Estimate the time and cost savings ScribeCraft can deliver for your practice.</p>

    <div class="roi-grid">
      <div class="roi-inputs">
        <h3>Your Practice Details</h3>
        <div class="slider-group">
          <div class="slider-label">
            <span>Clinicians using ScribeCraft</span>
            <span class="slider-value" id="val-clinicians">3</span>
          </div>
          <input type="range" min="1" max="20" value="3" id="sl-clinicians" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Consultations per clinician per day</span>
            <span class="slider-value" id="val-consults">25</span>
          </div>
          <input type="range" min="5" max="50" value="25" id="sl-consults" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Minutes on documentation per consultation</span>
            <span class="slider-value" id="val-doctime">5</span>
          </div>
          <input type="range" min="2" max="15" value="5" id="sl-doctime" />
        </div>
        <div class="slider-group">
          <div class="slider-label">
            <span>Working days per week</span>
            <span class="slider-value" id="val-days">5</span>
          </div>
          <input type="range" min="3" max="6" value="5" id="sl-days" />
        </div>
      </div>

      <div class="roi-results-card">
        <h3>Estimated Savings</h3>
        <div class="result-item">
          <div class="result-num" id="res-hours-day">&mdash;</div>
          <div class="result-label">Hours saved per day (all clinicians)</div>
        </div>
        <div class="result-item">
          <div class="result-num" id="res-hours-week">&mdash;</div>
          <div class="result-label">Hours saved per week</div>
        </div>
        <div class="result-item">
          <div class="result-num" id="res-hours-year">&mdash;</div>
          <div class="result-label">Hours saved per year</div>
        </div>
        <div class="roi-highlight">
          <div class="result-num" id="res-consults-extra">&mdash;</div>
          <div class="result-label">Additional consultations possible per week</div>
        </div>
      </div>
    </div>
    <p class="roi-disclaimer">Based on ScribeCraft reducing documentation time by 70%. Figures are estimates and actual savings may vary.</p>
  </section>

</ProductDocsLayout>

<style>
  .help-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-brand-blue);
    font-weight: 500;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }
  .help-back-link:hover { opacity: 0.7; }

  .roi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .roi-inputs {
    background: #fff;
    border: none;
    border-radius: var(--radius-card);
    padding: 32px;
    box-shadow: 4px 4px 30px 10px rgba(0, 0, 0, 0.06);
  }
  .roi-inputs h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 1.75rem;
  }
  .slider-group { margin-bottom: 1.75rem; }
  .slider-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.625rem;
  }
  .slider-label span {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-brand-black);
  }
  .slider-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-blue);
  }
  input[type='range'] {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    background: linear-gradient(90deg, rgba(44, 112, 235, 0.15), rgba(0, 195, 147, 0.15));
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }
  input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    cursor: pointer;
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(44, 112, 235, 0.35);
  }
  input[type='range']::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    cursor: pointer;
    border: 3px solid #fff;
  }
  .roi-results-card {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.06), rgba(0, 195, 147, 0.06));
    border-radius: var(--radius-card);
    padding: 32px;
    color: var(--color-brand-black);
    position: sticky;
    top: 100px;
    box-shadow: var(--shadow-card-lg);
    border: 1px solid rgba(44, 112, 235, 0.12);
  }
  .roi-results-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
    color: var(--color-brand-black);
  }
  .result-item {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-brand-grey-border);
  }
  .result-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .result-num {
    font-size: 2rem;
    font-weight: 800;
    color: #00c393;
    line-height: 1;
    margin-bottom: 6px;
  }
  .result-label {
    font-size: 0.85rem;
    color: var(--color-brand-grey-muted);
  }
  .roi-highlight {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.1), rgba(0, 195, 147, 0.1));
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    margin-top: 1.25rem;
    border: 1px solid rgba(44, 112, 235, 0.15);
  }
  .roi-highlight .result-num { color: var(--color-brand-blue); font-size: 2.25rem; }
  .roi-highlight .result-label { color: var(--color-brand-grey-muted); }
  .roi-disclaimer { color: var(--color-brand-grey-muted); font-size: 0.8rem; margin-top: 1rem; }
  @media (max-width: 860px) {
    .roi-grid { grid-template-columns: 1fr; }
    .roi-results-card { position: static; }
  }

  /* ── Info Cards ── */
  .sc-info-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.08);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .sc-info-card:hover {
    border-color: rgba(44, 112, 235, 0.2);
    box-shadow: 0 6px 24px rgba(44, 112, 235, 0.08);
  }

  .sc-info-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.1), rgba(44, 112, 235, 0.04));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-blue);
  }

  .sc-info-content h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .sc-info-content p,
  .sc-info-content ul,
  .sc-info-content ol {
    font-size: 0.925rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.65;
  }

  .sc-info-content h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-top: 1rem;
    margin-bottom: 0.375rem;
  }

  /* ── Steps ── */
  .sc-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1.5rem;
    position: relative;
  }

  .sc-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 0;
    position: relative;
  }

  .sc-step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 21px;
    top: calc(1.25rem + 42px);
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, rgba(44, 112, 235, 0.15), rgba(0, 195, 147, 0.1));
  }

  .sc-step-num {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2c70eb, #00c393);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(44, 112, 235, 0.2);
  }

  .sc-step-content h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.25rem;
    margin-top: 0.25rem;
  }

  .sc-step-content p {
    font-size: 0.925rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.6;
  }

  /* ── Checklist ── */
  .sc-checklist {
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.08);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    margin-top: 1rem;
  }

  .sc-check-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 0.625rem 0;
    border-bottom: 1px solid rgba(44, 112, 235, 0.05);
  }

  .sc-check-item:last-child {
    border-bottom: none;
  }

  .sc-check-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(0, 195, 147, 0.12), rgba(0, 195, 147, 0.04));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-green);
  }

  .sc-check-item span {
    font-size: 0.925rem;
    color: var(--color-brand-grey);
    line-height: 1.5;
    padding-top: 2px;
  }

  @media (max-width: 480px) {
    .sc-info-card {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<script>
  const slClinicians = document.getElementById('sl-clinicians');
  const slConsults = document.getElementById('sl-consults');
  const slDoctime = document.getElementById('sl-doctime');
  const slDays = document.getElementById('sl-days');

  function calcROI() {
    const c = parseInt(slClinicians.value);
    const n = parseInt(slConsults.value);
    const d = parseInt(slDoctime.value);
    const w = parseInt(slDays.value);

    document.getElementById('val-clinicians').textContent = String(c);
    document.getElementById('val-consults').textContent = String(n);
    document.getElementById('val-doctime').textContent = String(d);
    document.getElementById('val-days').textContent = String(w);

    const savedMinPerDay = c * n * d * 0.7;
    const hDay = (savedMinPerDay / 60).toFixed(1);
    const hWeek = (parseFloat(hDay) * w).toFixed(0);
    const hYear = (parseFloat(hWeek) * 48).toFixed(0);
    const extraConsults = Math.floor((savedMinPerDay * w) / (10 * 5));

    document.getElementById('res-hours-day').textContent = hDay + ' hrs';
    document.getElementById('res-hours-week').textContent = hWeek + ' hrs';
    document.getElementById('res-hours-year').textContent = Number(hYear).toLocaleString() + ' hrs';
    document.getElementById('res-consults-extra').textContent = '+' + extraConsults;
  }

  if (slClinicians) {
    [slClinicians, slConsults, slDoctime, slDays].forEach((sl) => {
      sl.addEventListener('input', calcROI);
    });
    calcROI();
  }
</script>
