<script>
  const scSafetyForm = document.getElementById('sc-safety-form');
  if (scSafetyForm) {
    scSafetyForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const inputs = scSafetyForm.querySelectorAll('input, select');
      const data = {};
      inputs.forEach((inp) => { if (inp.name || inp.placeholder) data[inp.placeholder || inp.name] = inp.value; });
      console.log('Safety docs request:', { ...data, product: 'ScribeCraft', page: 'help-centre/safety', timestamp: new Date().toISOString() });
      document.getElementById('sc-safety-form-wrap').innerHTML = '<p style="color:var(--color-brand-green);font-weight:600;margin-top:1rem;">Request submitted! We\'ll send the documentation to your email shortly.</p>';
    });
  }
</script>
