---
import ProductDocsLayout from '../../../../layouts/ProductDocsLayout.astro';
const base = import.meta.env.BASE_URL;

const sidebarItems = [
  { label: 'Quick Start Guide', href: `${base}products/scribecraft/help-centre/quick-start` },
  { label: 'Accuracy Optimisation', href: `${base}products/scribecraft/help-centre/accuracy` },
  { label: 'FAQ', href: `${base}products/scribecraft/help-centre/faq` },
  { label: 'Materials & Explainers', href: `${base}products/scribecraft/help-centre/materials` },
  { label: 'Practice Readiness Audit', href: `${base}products/scribecraft/help-centre/practice-audit` },
];
---

<ProductDocsLayout
  title="ScribeCraft Help Centre | ApolloIQ"
  description="Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice."
  sidebarItems={sidebarItems}
  heroTitle="ScribeCraft Help Centre"
  heroSubtitle="Guides, FAQs, and resources to help you get the most from ScribeCraft in your practice."
  heroIcon={`${base}images/icon-scribe.svg`}
>

  <a href={`${base}products/scribecraft`} class="help-back-link">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Back to ScribeCraft
  </a>

  <section id="overview">
    <h2>Welcome to the Help Centre</h2>
    <p>Everything you need to get started with ScribeCraft and make the most of AI-powered clinical documentation.</p>

    <div class="hc-cards">
      <a href={`${base}products/scribecraft/help-centre/quick-start`} class="hc-card">
        <div class="hc-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3>Quick Start Guide</h3>
        <p>Step-by-step instructions to begin using ScribeCraft in your consultations — from login to filing notes.</p>
      </a>

      <a href={`${base}products/scribecraft/help-centre/accuracy`} class="hc-card">
        <div class="hc-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3>Accuracy Optimisation</h3>
        <p>Tips for microphone positioning, environment setup, and speaking techniques to maximise transcription accuracy.</p>
      </a>

      <a href={`${base}products/scribecraft/help-centre/faq`} class="hc-card">
        <div class="hc-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <h3>Frequently Asked Questions</h3>
        <p>Answers about security, consent, accuracy, features, technical requirements, onboarding, and compliance.</p>
      </a>

      <a href={`${base}products/scribecraft/help-centre/materials`} class="hc-card">
        <div class="hc-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3>Materials & Explainers</h3>
        <p>Resources for patients, practices, and clinicians — plus an ROI calculator to estimate your savings.</p>
      </a>

      <a href={`${base}products/scribecraft/help-centre/practice-audit`} class="hc-card">
        <div class="hc-card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <h3>Practice Readiness Audit</h3>
        <p>Answer 8 quick questions to assess how ready your practice is to adopt ScribeCraft.</p>
      </a>
    </div>
  </section>

</ProductDocsLayout>

<style>
  /* ── Back Link ── */
  .help-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-brand-blue);
    font-weight: 500;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }
  .help-back-link:hover { opacity: 0.7; }

  /* ── Help Centre Cards ── */
  .hc-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .hc-card {
    background: #fff;
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .hc-card:hover {
    border-color: var(--color-brand-blue);
    box-shadow: 0 4px 20px rgba(44, 112, 235, 0.1);
    transform: translateY(-2px);
  }

  .hc-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.08), rgba(0, 195, 147, 0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--color-brand-blue);
  }

  .hc-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .hc-card p {
    font-size: 0.9rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
