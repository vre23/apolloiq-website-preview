<script>
  const pathSafetyForm = document.getElementById('path-safety-form') as HTMLFormElement;
  if (pathSafetyForm) {
    pathSafetyForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = pathSafetyForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      var fd = new FormData(pathSafetyForm);
      fetch('https://script.google.com/macros/s/AKfycbyxiagGQW6AIdiR8o8o0u4c0ET1I70injnp9ExqGWvFYHj6ucqSlPOe-ijPuewWToFZMw/exec', {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({
          type: 'safety-request',
          name: fd.get('name'),
          role: fd.get('role'),
          organisation: fd.get('organisation'),
          email: fd.get('email'),
          purpose: fd.get('purpose'),
          _source: fd.get('_source') || 'Safety Documentation Request - Pathology Automation'
        })
      }).catch(function(){});

      document.getElementById('path-safety-form-wrap')!.innerHTML = '<p style="color:var(--color-brand-green);font-weight:600;margin-top:1rem;">✓ Request submitted! We\'ll send the documentation to your email shortly.</p>';
    });
  }
</script>
