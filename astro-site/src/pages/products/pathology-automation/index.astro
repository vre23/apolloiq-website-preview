    color: var(--color-brand-grey-muted);
    line-height: 1.5;
  }

  /* Stats */
  .path-stats-section {
    background: #fff;
  }

  .path-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .path-stat-card {
    text-align: center;
    padding: 2rem 1.5rem;
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
  }

  .path-stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .path-stat-green {
    color: var(--color-brand-green);
  }

  .path-stat-desc {
    font-size: 0.9375rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.4;
  }

  /* Pricing */
  .path-pricing-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .path-pricing-wrap {
    text-align: center;
  }

  .path-pricing-card {
    max-width: 480px;
    margin: 0 auto 1.5rem;
    border-radius: 16px;
    padding: 2.5rem;
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
    text-align: center;
  }

  .path-pricing-label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-grey-muted);
    margin-bottom: 0.25rem;
  }

  .path-pricing-price {
    font-size: 3.25rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    line-height: 1;
  }

  .path-pricing-billed {
    font-size: 0.875rem;
    color: var(--color-brand-grey-muted);
    margin-top: 0.375rem;
    margin-bottom: 1.5rem;
  }

  .path-pricing-calc {
    background: #f9fafb;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .path-pricing-calc-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    margin-bottom: 0.25rem;
  }

  .path-pricing-calc-row:last-child {
    margin-bottom: 0;
  }

  .path-pricing-calc-val {
    font-weight: 700;
    color: var(--color-brand-blue);
  }

  .path-check-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    text-align: left;
  }

  .path-check-list li {
    padding: 0.375rem 0 0.375rem 1.5rem;
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
  }

  .path-check-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  /* Safety Credentials */
  .path-safety-section {
    background: #fff;
  }

  .path-safety-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .path-safety-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border-radius: 12px;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .path-safety-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .path-safety-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    flex-shrink: 0;
  }

  .path-safety-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.25rem;
  }

  .path-safety-desc {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  /* Guardrails */
  .path-guardrails-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .path-guardrail-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .path-guardrail {
    background: #fff;
    border-radius: 12px;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(44, 112, 235, 0.06);
    overflow: hidden;
    transition: box-shadow 0.3s;
  }
  .path-guardrail:hover {
    box-shadow: var(--shadow-hover);
  }
  .path-guardrail[open] {
    border-color: rgba(44, 112, 235, 0.15);
  }

  .path-guardrail-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .path-guardrail-summary::-webkit-details-marker { display: none; }

  .path-guardrail-num {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    font-weight: 800;
    font-size: 0.875rem;
    flex-shrink: 0;
    font-family: var(--font-display);
  }

  .path-guardrail-info strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.125rem;
  }
  .path-guardrail-info span {
    font-size: 0.8125rem;
    color: var(--color-brand-grey-muted);
  }

  .path-guardrail-chevron {
    margin-left: auto;
    color: var(--color-brand-grey-light);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .path-guardrail[open] .path-guardrail-chevron {
    transform: rotate(180deg);
  }

  .path-guardrail-body {
    padding: 0 1.5rem 1.5rem 4.75rem;
  }
  .path-guardrail-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .path-guardrail-body li {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
  }
  .path-guardrail-body li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-green);
  }

  /* Governance */
  .path-governance {
    margin-top: 2.5rem;
    padding: 2rem;
    background: #fff;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(44, 112, 235, 0.06);
  }

  .path-governance-title {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-brand-grey-light);
    margin-bottom: 1.25rem;
  }

  .path-governance-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .path-governance-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .path-governance-item strong {
    font-size: 0.9375rem;
    color: var(--color-brand-black);
  }
  .path-governance-item span {
    font-size: 0.8125rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.5;
  }

  /* Hero badges row */
  .path-hero-badges {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .path-badge-green {
    background: rgba(0, 195, 147, 0.1);
    color: var(--color-brand-green);
  }

  /* File/Skip action cards */
  .path-action-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .path-action-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 12px;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
  }

  .path-action-file {
    background: linear-gradient(135deg, rgba(0, 195, 147, 0.04), rgba(0, 195, 147, 0.01));
    border-left: 4px solid var(--color-brand-green);
  }

  .path-action-skip {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.04), rgba(245, 158, 11, 0.01));
    border-left: 4px solid #f59e0b;
  }

  .path-action-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .path-action-file .path-action-icon {
    background: rgba(0, 195, 147, 0.1);
    color: var(--color-brand-green);
  }

  .path-action-skip .path-action-icon {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
  }

  .path-action-card strong {
    display: block;
    font-size: 1rem;
    color: var(--color-brand-black);
    margin-bottom: 0.25rem;
  }

  .path-action-card span {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  /* Dashboard section */
  .path-dashboard-section {
    background: #fff;
  }

  .path-dashboard-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .path-dashboard-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .path-dashboard-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }

  .path-dashboard-card strong {
    font-size: 1rem;
    color: var(--color-brand-black);
  }

  .path-dashboard-card span {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  /* Processing Rules section */
  .path-rules-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .path-rules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .path-rule-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: #fff;
    border-radius: 12px;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
  }

  .path-rule-num {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    font-weight: 800;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .path-rule-card strong {
    display: block;
    font-size: 0.9375rem;
    color: var(--color-brand-black);
    margin-bottom: 0.25rem;
  }

  .path-rule-card span {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  .path-clinical-logic {
    margin-top: 2rem;
    padding: 2rem;
    background: #fff;
    border-radius: 16px;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(44, 112, 235, 0.06);
  }

  .path-clinical-logic-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.75rem;
  }

  .path-psa-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .path-psa-item {
    text-align: center;
    padding: 1rem;
    background: linear-gradient(180deg, #f0f4fb, #eef8f5);
    border-radius: 12px;
  }

  .path-psa-item strong {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-brand-blue);
    margin-bottom: 0.375rem;
  }

  .path-psa-item span {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-brand-black);
  }

  /* Intended Users section */
  .path-users-section {
    background: #fff;
  }

  .path-users-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .path-user-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
  }

  .path-user-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .path-user-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .path-user-card p {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin: 0;
  }

  /* Clinical Safety section */
  .path-clinical-safety-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .path-cs-badge-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .path-cs-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 16px;
    background: var(--color-brand-blue);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .path-cs-badge-green {
    background: var(--color-brand-green);
  }

  .path-cs-statement {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.04), rgba(0, 195, 147, 0.03));
    border-left: 4px solid var(--color-brand-blue);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .path-cs-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(44, 112, 235, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .path-cs-subtitle {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 1rem;
  }

  .path-hazard-card {
    background: #fff;
    border: 1px solid rgba(44, 112, 235, 0.06);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-card);
  }

  .path-hazard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .path-hazard-ref {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    background: rgba(44, 112, 235, 0.08);
    padding: 3px 10px;
    border-radius: 8px;
    letter-spacing: 0.5px;
  }

  .path-hazard-risk {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 8px;
    letter-spacing: 0.3px;
  }

  .path-risk-medium {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
  }

  .path-risk-high {
    background: rgba(239, 68, 68, 0.1);
    color: #dc2626;
  }

  .path-hazard-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .path-hazard-desc {
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-brand-grey);
    margin-bottom: 1rem;
  }

  .path-control-box {
    background: linear-gradient(135deg, rgba(0, 195, 147, 0.04), rgba(44, 112, 235, 0.03));
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .path-control-box strong {
    display: block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-brand-green);
    margin-bottom: 0.5rem;
  }

  .path-control-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .path-control-box li {
    padding: 0.25rem 0 0.25rem 1.25rem;
    position: relative;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-brand-grey);
  }

  .path-control-box li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  .path-cs-cso-box {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.04), rgba(0, 195, 147, 0.03));
    border-left: 4px solid var(--color-brand-green);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  .path-cs-cso-box strong {
    display: block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-brand-green);
    margin-bottom: 0.5rem;
  }

  .path-cs-cso-box p {
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-brand-grey);
    margin: 0;
  }

  .path-cs-disclaimer {
    background: linear-gradient(135deg, rgba(44, 112, 235, 0.04), rgba(44, 112, 235, 0.02));
    border-left: 4px solid var(--color-brand-blue);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-top: 1.5rem;
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-brand-grey);
  }

  .path-cs-disclaimer strong {
    display: block;
    margin-bottom: 4px;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-brand-blue);
  }

  /* Safety CTA */
  .path-safety-cta {
    margin-top: 2.5rem;
    padding: 2rem 2.5rem;
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(44, 112, 235, 0.1);
    box-shadow: var(--shadow-card);
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .path-safety-cta-content {
    flex: 1;
  }

  .path-safety-cta-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .path-safety-cta-content p {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin: 0;
  }

  .path-safety-cta-actions {
    flex-shrink: 0;
    text-align: center;
  }

  .path-safety-cta-sub {
    font-size: 0.8125rem;
    color: var(--color-brand-grey-muted);
    margin-top: 0.75rem;
  }

  .path-safety-cta-sub a {
    color: var(--color-brand-blue);
    text-decoration: none;
    font-weight: 600;
  }

  .path-safety-cta-sub a:hover {
    text-decoration: underline;
  }

  .safety-request-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 1rem;
    max-width: 300px;
  }

  .safety-request-form .form-field {
    font-size: 0.875rem;
    padding: 0.625rem 0.875rem;
  }

  @media (max-width: 768px) {
    .product-hero-icon {
      width: 36px;
      height: 36px;
    }
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
    .path-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .path-coverage-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    }
    .path-guardrail-body {
      padding-left: 1.5rem;
    }
    .path-governance-grid {
      grid-template-columns: 1fr;
    }
    .path-action-cards {
      grid-template-columns: 1fr;
    }
    .path-dashboard-grid {
      grid-template-columns: 1fr;
    }
    .path-rules-grid {
      grid-template-columns: 1fr;
    }
    .path-psa-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .path-users-grid {
      grid-template-columns: 1fr;
    }
    .path-cs-statement {
      flex-direction: column;
    }
    .path-safety-cta {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
      padding: 1.5rem;
    }
  }

