<script>
  // ── Calculator Logic ──
  const LABS_PER_PATIENT_DAILY = 0.0152;
  const GP_COST_PER_HOUR = 80;
  const MINS_PER_LAB = 1;
  const WORKING_DAYS = 250;
  const PRICE_PER_PATIENT = 0.30;

  function formatNumber(num: number): string {
    return new Intl.NumberFormat('en-GB').format(Math.round(num));
  }

  function recalculate() {
    const patientInput = document.getElementById('patient-list') as HTMLInputElement;
    const slider = document.getElementById('filing-slider') as HTMLInputElement;

    const patients = parseInt(patientInput.value) || 10000;
    const filingRate = parseInt(slider.value) / 100;

    // Pain metrics — no intermediate rounding, matches reference exactly
    const dailyLabs = patients * LABS_PER_PATIENT_DAILY;
    const annualLabs = dailyLabs * WORKING_DAYS;
    const totalHoursYear = (annualLabs * MINS_PER_LAB) / 60;
    const totalCostYear = totalHoursYear * GP_COST_PER_HOUR;

    // Win metrics
    const annualAutoFiled = annualLabs * filingRate;
    const hoursSaved = (annualAutoFiled * MINS_PER_LAB) / 60;
    const valueCreated = hoursSaved * GP_COST_PER_HOUR;
    const apolloCost = patients * PRICE_PER_PATIENT;
    const roi = apolloCost > 0 ? ((valueCreated - apolloCost) / apolloCost) * 100 : 0;

    // Update Pain
    (document.getElementById('daily-volume') as HTMLElement).textContent = formatNumber(dailyLabs);
    (document.getElementById('gp-capacity') as HTMLElement).textContent = formatNumber(totalHoursYear);
    (document.getElementById('annual-cost') as HTMLElement).textContent = '£' + formatNumber(totalCostYear);

    // Update Slider display
    (document.getElementById('slider-value') as HTMLElement).textContent = slider.value + '%';

    // Update Win
    (document.getElementById('hours-saved') as HTMLElement).textContent = formatNumber(hoursSaved);
    (document.getElementById('results-filed') as HTMLElement).textContent = formatNumber(annualAutoFiled);
    (document.getElementById('value-created') as HTMLElement).textContent = '£' + formatNumber(valueCreated);
    (document.getElementById('est-roi') as HTMLElement).textContent = formatNumber(roi) + '%';

    // Update ROI detail
    const roiDetail = document.querySelector('#est-roi')?.parentElement?.querySelector('.calc-result-detail');
    if (roiDetail) {
      roiDetail.textContent = 'based on £' + formatNumber(apolloCost) + ' annual cost';
    }
  }

  document.getElementById('patient-list')?.addEventListener('input', recalculate);
  document.getElementById('filing-slider')?.addEventListener('input', recalculate);

  // Initial calculation
  recalculate();

  // ── Lead Gate ──
  const gateForm = document.getElementById('calc-gate-form') as HTMLFormElement;
  if (gateForm) {
    gateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = gateForm.querySelector('.calc-gate-btn') as HTMLButtonElement;
      const original = btn.textContent;
      btn.textContent = 'Unlocking...';
      btn.disabled = true;

      const practice = (document.getElementById('gate-practice') as HTMLInputElement).value;

      // Auto-fill practice name into calculator if empty
      const practiceInput = document.getElementById('practice-name') as HTMLInputElement;
      if (practiceInput && !practiceInput.value) {
        practiceInput.value = practice;
      }

      // Gather form + calculator values for email
      const name = (document.getElementById('gate-name') as HTMLInputElement).value;
      const role = (document.getElementById('gate-role') as HTMLSelectElement).value;
      const email = (document.getElementById('gate-email') as HTMLInputElement).value;
      const patients = parseInt((document.getElementById('patient-list') as HTMLInputElement).value) || 10000;
      const filingRate = parseInt((document.getElementById('filing-slider') as HTMLInputElement).value) || 35;

      // Calculate key metrics for email
      const dailyLabs = Math.round(patients * LABS_PER_PATIENT_DAILY);
      const annualLabs = patients * LABS_PER_PATIENT_DAILY * WORKING_DAYS;
      const totalHours = Math.round((annualLabs * MINS_PER_LAB) / 60);
      const annualCost = Math.round(totalHours * GP_COST_PER_HOUR);
      const hoursSaved = Math.round((annualLabs * (filingRate / 100) * MINS_PER_LAB) / 60);
      const valueCreated = Math.round(hoursSaved * GP_COST_PER_HOUR);
      const apolloCost = patients * PRICE_PER_PATIENT;
      const roi = apolloCost > 0 ? Math.round(((valueCreated - apolloCost) / apolloCost) * 100) : 0;

      // Send personalised email via Google Apps Script (non-blocking)
      fetch('https://script.google.com/macros/s/AKfycbyxiagGQW6AIdiR8o8o0u4c0ET1I70injnp9ExqGWvFYHj6ucqSlPOe-ijPuewWToFZMw/exec', {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({
          type: 'pathology',
          email: email,
          name: name,
          practice: practice,
          role: role,
          patients: patients,
          dailyLabs: dailyLabs,
          totalHours: totalHours,
          annualCost: annualCost,
          filingRate: filingRate,
          hoursSaved: hoursSaved,
          valueCreated: valueCreated,
          roi: roi
        })
      }).catch(() => {});

      // Show gated content, hide gate
      (document.getElementById('calc-gate') as HTMLElement).style.display = 'none';
      (document.getElementById('calc-gated-content') as HTMLElement).style.display = 'block';

      // Scroll to the unlocked content
      document.getElementById('calc-gated-content')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>
