---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import CTASection from '../../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Locate Elixir" description="Instant medication stock visibility for healthcare staff. Real-time pharmacy availability with a traffic light system.">
  <Nav />

  <!-- Hero -->
  <section class="product-hero">
    <div class="container-site">
      <span class="product-badge">Spell</span>
      <h1 class="product-hero-title">Locate <span class="text-gradient">Elixir</span></h1>
      <p class="product-subtitle">Instant Stock Insight. Zero Delays.</p>
      <a href={`${base}contact-us`} class="btn-primary">Activate Spell</a>
    </div>
  </section>

  <!-- Overview -->
  <section class="section product-overview-section">
    <div class="container-site">
      <div class="product-overview-box">
        <span class="product-label">OVERVIEW</span>
        <h2 class="product-section-title">What is Locate Elixir?</h2>
        <p class="product-body-text">
          Locate Elixir is a live medication availability tool designed to give healthcare staff real-time visibility of pharmacy stock levels. Using a simple traffic light system, users can instantly check whether a medication is available to order (green) or currently out of stock (red). This reduces prescribing delays, enhances patient care, and simplifies the workflow for busy clinicians.
        </p>
        <a href={`${base}contact-us`} class="btn-primary" style="margin-top: 1rem;">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Key & <span class="text-gradient">Benefits</span></h2>
          <p class="product-split-intro">4 key features that make Locate Elixir essential for your practice.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>Live Stock Visibility</strong>
              <span>Instantly see which medications are in stock at pharmacies using our real-time traffic light system.</span>
            </li>
            <li>
              <strong>Faster Prescribing Decisions</strong>
              <span>Avoid delays by prescribing only what's currently available, improving treatment start times.</span>
            </li>
            <li>
              <strong>Reduced Admin Workload</strong>
              <span>Eliminate the need for back-and-forth calls with pharmacies to confirm availability.</span>
            </li>
            <li>
              <strong>Better Patient Experience</strong>
              <span>Ensure patients receive their medications without disruption or stock-related issues.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section product-why-section">
    <div class="container-site">
      <div class="product-why-box">
        <span class="product-label">WHY US?</span>
        <h2 class="product-section-title">Why Choose Locate Elixir?</h2>
        <p class="product-body-text">
          Merlin's Locate Elixir transforms how practices and pharmacies collaborate on medication supply, enhancing speed, efficiency, and patient care.
        </p>
        <ul class="product-benefit-list">
          <li><strong>Save Time:</strong> Quickly identify stock availability without contacting multiple pharmacies.</li>
          <li><strong>Improve Workflow:</strong> Enable clinicians to make informed prescribing decisions at the point of care.</li>
          <li><strong>Boost Efficiency:</strong> Streamline communication between GP surgeries and pharmacies.</li>
          <li><strong>Reduce Errors:</strong> Avoid prescribing medications that are currently unavailable.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">How Does It <span class="text-gradient">Work?</span></h2>
          <p class="product-split-intro">
            Locate Elixir is intuitive and fast -- designed for clinical environments with no learning curve.
          </p>
        </div>
        <div class="product-split-right">
          <ol class="product-steps-list">
            <li>
              <strong>Search the Medication Name</strong>
              <span>Start typing the medication name -- our smart search helps you find it instantly.</span>
            </li>
            <li>
              <strong>Check the Traffic Light Indicator</strong>
              <span>A green light means in stock and ready to order; red means currently out of stock.</span>
            </li>
            <li>
              <strong>View Additional Details</strong>
              <span>Access info on availability trends and alternative formulations when needed.</span>
            </li>
            <li>
              <strong>Prescribe Confidently</strong>
              <span>Use the live data to issue prescriptions that are more likely to be fulfilled promptly.</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section product-pricing-section">
    <div class="container-site">
      <div class="product-pricing-wrap">
        <span class="product-label">PRICING</span>
        <h2 class="product-section-title" style="text-align: center;">Simple, Transparent <span class="text-gradient">Pricing</span></h2>
        <p class="product-body-text" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem;">
          No hidden fees. No complex contracts. Just straightforward pricing.
        </p>
        <div class="product-pricing-cards">
          <div class="product-pricing-card">
            <div class="product-pricing-label">Individual</div>
            <div class="product-pricing-price">&pound;20</div>
            <div class="product-pricing-billed">per user / month</div>
            <ul class="product-check-list">
              <li>Full access to Locate Elixir</li>
              <li>Real-time stock visibility</li>
              <li>Traffic light availability system</li>
              <li>Smart medication search</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Organisation</div>
            <div class="product-pricing-price">&pound;13</div>
            <div class="product-pricing-billed">per user / month</div>
            <div class="product-pricing-calc">
              <div class="product-pricing-calc-row">
                <span>Example (10 users)</span>
                <span class="product-pricing-calc-val">&pound;130/mo</span>
              </div>
              <div class="product-pricing-calc-row">
                <span>Save per user</span>
                <span class="product-pricing-calc-val">&pound;7/mo</span>
              </div>
            </div>
            <ul class="product-check-list">
              <li>Everything in Individual</li>
              <li>Volume discount pricing</li>
              <li>Practice-wide deployment</li>
              <li>Priority support</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Enterprise</div>
            <div class="product-pricing-price" style="font-size: 2.25rem;">Custom</div>
            <div class="product-pricing-billed">tailored to your needs</div>
            <ul class="product-check-list">
              <li>Everything in Organisation</li>
              <li>Custom user limits</li>
              <li>Dedicated account manager</li>
              <li>Custom integrations</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  .product-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(135deg, #f8faff, #f0f7ff 50%, #f5fdf9);
    text-align: center;
  }

  .product-hero-title {
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .product-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    border-radius: 20px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .product-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-brand-blue);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .product-section-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 1.25rem;
  }

  .product-body-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .product-overview-section {
    background: #f9fafb;
  }

  .product-overview-box {
    max-width: 800px;
  }

  .product-split {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .product-split-left {
    flex: 1;
    min-width: 260px;
  }

  .product-split-right {
    flex: 1.2;
    min-width: 300px;
  }

  .product-split-intro {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-feature-list li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-green);
  }

  .product-feature-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-feature-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-why-section {
    background: #f9fafb;
  }

  .product-why-box {
    max-width: 800px;
  }

  .product-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-benefit-list li {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
  }

  .product-benefit-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  .product-benefit-list li strong {
    color: var(--color-brand-black);
  }

  .product-steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-steps-list li {
    counter-increment: steps;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 3rem;
    position: relative;
  }

  .product-steps-list li::before {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-brand-green);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-steps-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-steps-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
