---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import CTASection from '../../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Blood Pressure Scroll" description="Effortless blood pressure data extraction from handwritten submissions. AI-powered digitisation for GP practices.">
  <Nav />

  <!-- Hero -->
  <section class="product-hero">
    <div class="container-site">
      <span class="product-badge">Spell</span>
      <div class="product-hero-title-row">
        <img src={`${base}images/icon-blood-pressure.svg`} alt="" class="product-hero-icon" />
        <h1 class="product-hero-title">Blood Pressure <span class="text-gradient">Scroll</span></h1>
      </div>
      <p class="product-subtitle">Effortless blood pressure data extraction from handwritten submissions</p>
      <div class="hero-cta-group">
        <a href={`${base}contact-us`} class="btn-primary">Activate Spell</a>
        <a href="#book-demo" class="btn-secondary" data-product="bp-scroll">Book a Demo</a>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section product-overview-section">
    <div class="container-site">
      <div class="product-overview-box">
        <span class="product-label">OVERVIEW</span>
        <h2 class="product-section-title">What is Blood Pressure Scroll?</h2>
        <p class="product-body-text">
          Blood Pressure Scroll is a powerful AI-driven tool designed to support GP practices in digitising blood pressure records submitted by patients. Often, these readings come in handwritten formats, making manual transcription time-consuming and prone to error.
        </p>
        <p class="product-body-text">
          With Blood Pressure Scroll, clinicians can simply drag and drop the patient's document -- whether it's a photo, scan, or PDF -- and the tool instantly extracts and structures the blood pressure readings. The extracted data is clearly displayed for review, giving the clinician full control to verify and adjust if needed.
        </p>
        <p class="product-body-text">
          Once confirmed, the system automatically calculates the average systolic and diastolic pressures, helping clinicians make quicker, more informed decisions with confidence.
        </p>
        <p class="product-body-text"><strong>Save time, reduce errors, and streamline your workflow -- with Blood Pressure Scroll.</strong></p>
        <a href={`${base}contact-us`} class="btn-primary" style="margin-top: 1rem;">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Key & <span class="text-gradient">Benefits</span></h2>
          <p class="product-split-intro">4 key features that make Blood Pressure Scroll essential for your practice.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>Instant Data Extraction</strong>
              <span>Quickly digitises handwritten blood pressure submissions using advanced AI -- no manual entry required.</span>
            </li>
            <li>
              <strong>Clinician Review & Control</strong>
              <span>Allows full review and editing of extracted data before it's used -- ensuring accuracy and clinical confidence.</span>
            </li>
            <li>
              <strong>Automatic Averages</strong>
              <span>Calculates average systolic and diastolic readings instantly, supporting fast and informed decision-making.</span>
            </li>
            <li>
              <strong>Seamless Workflow Integration</strong>
              <span>Simple drag-and-drop functionality fits effortlessly into daily practice routines, saving time and reducing admin burden.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section product-why-section">
    <div class="container-site">
      <div class="product-why-box">
        <span class="product-label">WHY US?</span>
        <h2 class="product-section-title">Why Choose Merlin's Blood Pressure Scroll?</h2>
        <p class="product-body-text">
          Merlin's Blood Pressure Scroll offers powerful automation for GP surgeries, turning handwritten blood pressure logs into structured clinical data -- instantly. This saves valuable time, improves accuracy, and streamlines hypertension monitoring.
        </p>
        <ul class="product-benefit-list">
          <li><strong>Save Time:</strong> Automate the transcription of paper-based blood pressure readings, freeing up clinicians and admin staff. From 6 min to 30 seconds.</li>
          <li><strong>Improve Accuracy:</strong> AI-powered extraction minimizes errors from manual entry and ensures consistent data capture.</li>
          <li><strong>Support Clinical Decisions:</strong> Automatically calculates average systolic and diastolic values to support quick, informed reviews.</li>
          <li><strong>Stay in Control:</strong> All data is editable -- clinicians verify accuracy before integrating it into records or making treatment decisions.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">How Does It <span class="text-gradient">Work?</span></h2>
          <p class="product-split-intro">
            Merlin's Blood Pressure Scroll simplifies the processing of handwritten BP readings through AI-powered document analysis -- all in just a few clicks.
          </p>
        </div>
        <div class="product-split-right">
          <ol class="product-steps-list">
            <li>
              <strong>Upload the File</strong>
              <span>Drag and drop scanned or photographed BP sheets (PDF, PNG, JPG, etc.) — or use your mobile device or tablet to take a photo of the blood pressure journal directly.</span>
            </li>
            <li>
              <strong>AI Extraction</strong>
              <span>The system automatically detects and extracts all blood pressure values.</span>
            </li>
            <li>
              <strong>Review & Confirm</strong>
              <span>Clinicians can review and edit the extracted data before final use.</span>
            </li>
            <li>
              <strong>Instant Averages</strong>
              <span>The tool calculates average systolic and diastolic values automatically.</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinical Safety -->
  <section class="section bp-safety-section">
    <div class="container-site">
      <span class="product-label">DCB 0129 COMPLIANT</span>
      <h2 class="product-section-title">Clinical Safety & <span class="text-gradient">Risk Management</span></h2>
      <p class="product-body-text" style="max-width: 750px;">
        Blood Pressure Scroll has been developed in accordance with <strong>DCB 0129</strong> — the NHS standard for Clinical Risk Management in the manufacture of Health IT Systems. A formal Clinical Safety Case Report and Hazard Log have been produced and approved by our Clinical Safety Officer.
      </p>

      <div class="bp-safety-statement">
        <svg class="bp-safety-shield" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <h3>Safety Statement</h3>
          <p>The clinical benefits of this system — primarily the mitigation of high-risk manual transcription and calculation errors currently performed by staff — far outweigh the identified residual clinical risks. All residual risks have been reduced <strong>As Low As Reasonably Practicable (ALARP)</strong> and are deemed acceptable.</p>
        </div>
      </div>

      <h3 class="bp-hazard-title">Identified Hazards & Controls</h3>
      <p class="product-body-text" style="max-width: 750px;">
        The following hazards have been formally identified, assessed, and mitigated with technical and procedural controls.
      </p>

      <div class="bp-hazard-grid">
        <div class="bp-hazard-card">
          <div class="bp-hazard-ref">H-04</div>
          <div class="bp-hazard-content">
            <strong class="bp-hazard-risk">Patient Misattribution</strong>
            <p class="bp-hazard-desc">The system does not link to your EPR's patient record. Uploading a document or transferring data to the wrong patient context can cause significant harm.</p>
            <div class="bp-hazard-control">
              <span class="bp-control-label">Control:</span>
              <span>The user is 100% responsible for ensuring the correct patient is selected in the main clinical system (e.g., EMIS/SystmOne) before uploading or transferring data.</span>
            </div>
          </div>
        </div>

        <div class="bp-hazard-card">
          <div class="bp-hazard-ref">H-01 / H-05</div>
          <div class="bp-hazard-content">
            <strong class="bp-hazard-risk">Incorrect AI Extraction / Automation Bias</strong>
            <p class="bp-hazard-desc">The AI may misread a value (e.g., read "180" as "130"). Relying on the AI without checking can lead to missed diagnoses.</p>
            <div class="bp-hazard-control">
              <span class="bp-control-label">Control:</span>
              <span>Source document displayed side-by-side with extracted data. Users must manually compare every value against the source before confirming. <strong>Do not trust the AI blindly.</strong></span>
            </div>
          </div>
        </div>

        <div class="bp-hazard-card">
          <div class="bp-hazard-ref">H-02</div>
          <div class="bp-hazard-content">
            <strong class="bp-hazard-risk">Missed AI Extraction (False Negative)</strong>
            <p class="bp-hazard-desc">The AI may fail to extract a reading (e.g., a single very high value), causing the calculated average to be incorrect and misleading.</p>
            <div class="bp-hazard-control">
              <span class="bp-control-label">Control:</span>
              <span>Users must visually scan the entire source document. If a reading is missing, use the "Add New Reading" button to enter it manually.</span>
            </div>
          </div>
        </div>

        <div class="bp-hazard-card">
          <div class="bp-hazard-ref">H-03</div>
          <div class="bp-hazard-content">
            <strong class="bp-hazard-risk">Calculation Accuracy</strong>
            <p class="bp-hazard-desc">The calculated average is only as accurate as the data that has been verified by the user.</p>
            <div class="bp-hazard-control">
              <span class="bp-control-label">Control:</span>
              <span>Rigorous unit testing and validation of calculation logic. Ensure all values are correct and present before using the calculated average.</span>
            </div>
          </div>
        </div>

        <div class="bp-hazard-card">
          <div class="bp-hazard-ref">H-06</div>
          <div class="bp-hazard-content">
            <strong class="bp-hazard-risk">System Unavailability</strong>
            <p class="bp-hazard-desc">The tool is web-based and requires internet connectivity. It is not intended for emergency use.</p>
            <div class="bp-hazard-control">
              <span class="bp-control-label">Control:</span>
              <span>Practices must maintain a non-digital (manual) backup process for receiving and processing blood pressure readings during downtime.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bp-disclaimer-box">
        <p><strong>In-App Disclaimer:</strong> "It is the full responsibility of the user to verify the accuracy of the extracted data before making any clinical decisions."</p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section product-pricing-section">
    <div class="container-site">
      <div class="product-pricing-wrap">
        <span class="product-label">PRICING</span>
        <h2 class="product-section-title" style="text-align: center;">Simple, Transparent <span class="text-gradient">Pricing</span></h2>
        <p class="product-body-text" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem;">
          No hidden fees. No complex contracts. Just straightforward pricing.
        </p>
        <div class="product-pricing-cards">
          <div class="product-pricing-card">
            <div class="product-pricing-label">Individual</div>
            <div class="product-pricing-price">&pound;15</div>
            <div class="product-pricing-billed">per user / month</div>
            <ul class="product-check-list">
              <li>Full access to Blood Pressure Scroll</li>
              <li>AI-powered data extraction</li>
              <li>Automatic BP averages</li>
              <li>No minimum user requirement</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Organisation</div>
            <div class="product-pricing-price">&pound;10</div>
            <div class="product-pricing-billed">per user / month</div>
            <div class="product-pricing-calc">
              <div class="product-pricing-calc-row">
                <span>Minimum users</span>
                <span class="product-pricing-calc-val">5</span>
              </div>
              <div class="product-pricing-calc-row">
                <span>Example (10 users)</span>
                <span class="product-pricing-calc-val">&pound;100/mo</span>
              </div>
            </div>
            <ul class="product-check-list">
              <li>Everything in Individual</li>
              <li>5 users minimum</li>
              <li>Volume discount pricing</li>
              <li>Priority support</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Enterprise</div>
            <div class="product-pricing-price" style="font-size: 2.25rem;">Custom</div>
            <div class="product-pricing-billed">tailored to your needs</div>
            <ul class="product-check-list">
              <li>Everything in Organisation</li>
              <li>Custom user limits</li>
              <li>Dedicated account manager</li>
              <li>Custom integrations</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  .product-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(175deg, #ffffff 0%, #f0f4fb 40%, #eef8f5 70%, #f5f7fa 100%);
    text-align: center;
  }

  .product-hero-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-hero-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .product-hero-title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .product-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    border-radius: 16px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .product-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-brand-blue);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .product-section-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
    margin-bottom: 1.25rem;
  }

  .product-body-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  /* Overview box */
  .product-overview-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-overview-box {
    max-width: 800px;
  }

  /* Split layout */
  .product-split {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .product-split-left {
    flex: 1;
    min-width: 260px;
  }

  .product-split-right {
    flex: 1.2;
    min-width: 300px;
  }

  .product-split-intro {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* Feature list */
  .product-feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-feature-list li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-blue);
  }

  .product-feature-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-feature-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* Why box */
  .product-why-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-why-box {
    max-width: 800px;
  }

  .product-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-benefit-list li {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
  }

  .product-benefit-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  .product-benefit-list li strong {
    color: var(--color-brand-black);
  }

  /* Steps list */
  .product-steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-steps-list li {
    counter-increment: steps;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 3rem;
    position: relative;
  }

  .product-steps-list li::before {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-brand-blue);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-steps-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-steps-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* Clinical Safety */
  .bp-safety-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .bp-safety-statement {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.75rem;
    background: linear-gradient(135deg, rgba(39, 174, 96, 0.06), rgba(44, 112, 235, 0.06));
    border: 1px solid rgba(39, 174, 96, 0.2);
    border-radius: 14px;
    margin: 2rem 0 2.5rem;
    max-width: 750px;
  }

  .bp-safety-shield {
    color: var(--color-brand-green);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .bp-safety-statement h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 0.5rem;
  }

  .bp-safety-statement p {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    margin: 0;
  }

  .bp-safety-statement strong {
    color: var(--color-brand-black);
  }

  .bp-hazard-title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 0.75rem;
  }

  .bp-hazard-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0 2rem;
    max-width: 800px;
  }

  .bp-hazard-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 12px;
    border-left: 3px solid #f39c12;
  }

  .bp-hazard-ref {
    font-size: 0.75rem;
    font-weight: 700;
    color: #f39c12;
    background: rgba(243, 156, 18, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .bp-hazard-content {
    flex: 1;
  }

  .bp-hazard-risk {
    display: block;
    font-size: 1rem;
    color: var(--color-brand-black);
    margin-bottom: 0.375rem;
  }

  .bp-hazard-desc {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .bp-hazard-control {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
    padding: 0.75rem;
    background: var(--color-brand-grey-bg-subtle);
    border-radius: 8px;
  }

  .bp-hazard-control strong {
    color: var(--color-brand-black);
  }

  .bp-control-label {
    font-weight: 600;
    color: var(--color-brand-green);
    margin-right: 0.25rem;
  }

  .bp-disclaimer-box {
    max-width: 800px;
    padding: 1.25rem 1.5rem;
    background: rgba(44, 112, 235, 0.04);
    border: 1px solid rgba(44, 112, 235, 0.12);
    border-radius: 12px;
  }

  .bp-disclaimer-box p {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  .bp-disclaimer-box strong {
    color: var(--color-brand-black);
    font-style: normal;
  }

  @media (max-width: 768px) {
    .product-hero-icon {
      width: 36px;
      height: 36px;
    }
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
