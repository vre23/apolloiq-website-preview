---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import CTASection from '../../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="GP List Reallocation" description="Smart, automated patient redistribution when a GP leaves your practice. Fair allocation based on clinical need and workload.">
  <Nav />

  <!-- Hero -->
  <section class="product-hero">
    <div class="container-site">
      <span class="product-badge">Automated Workflow</span>
      <h1 class="product-hero-title">GP List <span class="text-gradient">Reallocation</span></h1>
      <p class="product-subtitle">Goodbye Manual Lists -- Hello Fair Allocation</p>
      <a href={`${base}contact-us`} class="btn-primary">Contact Us</a>
    </div>
  </section>

  <!-- Overview -->
  <section class="section product-overview-section">
    <div class="container-site">
      <div class="product-overview-box">
        <span class="product-label">OVERVIEW</span>
        <h2 class="product-section-title">What is GP List Reallocation?</h2>
        <p class="product-body-text">
          GP List Reallocation is a smart, automated tool designed to redistribute patients when a GP leaves a practice. Whether it's the entire patient list or just a subset, the system uses intelligent algorithms to assign patients fairly and strategically across your remaining clinicians.
        </p>
        <p class="product-body-text">
          It stratifies by clinical need, chronic conditions, demographics, and more -- ensuring your most vulnerable patients remain in the right hands, and reducing the admin burden on your team.
        </p>
        <a href={`${base}contact-us`} class="btn-primary" style="margin-top: 1rem;">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Key & <span class="text-gradient">Benefits</span></h2>
          <p class="product-split-intro">4 key features that make our GP List Reallocation essential for your practice.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>Automates a time-consuming task</strong>
              <span>Save hours of manual spreadsheet work with a click.</span>
            </li>
            <li>
              <strong>Fair and optimised distribution</strong>
              <span>Based on workload, patient complexity, and GP competencies.</span>
            </li>
            <li>
              <strong>Supports clinical safety</strong>
              <span>Ensures vulnerable and high-priority patients are matched appropriately.</span>
            </li>
            <li>
              <strong>Adaptable to your practice's needs</strong>
              <span>Tailor the criteria and scope to match your exact requirements.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section product-why-section">
    <div class="container-site">
      <div class="product-why-box">
        <span class="product-label">WHY US?</span>
        <h2 class="product-section-title">Why Choose ApolloIQ's GP List Reallocation?</h2>
        <p class="product-body-text">
          When a GP leaves, practices are often left scrambling with spreadsheets, guesswork, and pressure to ensure patients don't fall through the cracks. GP Reallocation List changes that -- with a smarter, safer, and faster approach to list redistribution.
        </p>
        <ul class="product-benefit-list">
          <li><strong>Built by Primary Care Experts:</strong> We understand the challenges of GP list management because we live it. This tool is designed by clinicians, for clinicians.</li>
          <li><strong>Customisable to Your Practice Needs:</strong> From full list reallocation to just one leaver's patients -- you're in control of the scope, logic, and output.</li>
          <li><strong>Clinically Informed Allocation:</strong> Stratification based on chronic conditions, demographics, and clinician skillsets ensures a fair, safe distribution.</li>
          <li><strong>Seamless Implementation:</strong> No training headaches or IT overhauls -- just a user-friendly tool that integrates into your workflow.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">How Does It <span class="text-gradient">Work?</span></h2>
          <p class="product-split-intro">
            Built to streamline one of the trickiest transitions in general practice:
          </p>
        </div>
        <div class="product-split-right">
          <ol class="product-steps-list">
            <li>
              <strong>Choose Your Mode</strong>
              <span>Reallocate the full patient list or just the leaver's patients.</span>
            </li>
            <li>
              <strong>Select Stratification Rules</strong>
              <span>Pick from chronic conditions, age, gender, languages, or custom tags.</span>
            </li>
            <li>
              <strong>Run the Algorithm</strong>
              <span>Our tool distributes patients based on your input and practice configuration.</span>
            </li>
            <li>
              <strong>Review & Apply</strong>
              <span>Agreed results are directly imported into your clinical system, fully ready to go.</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section product-pricing-section">
    <div class="container-site">
      <div class="product-pricing-wrap">
        <span class="product-label">PRICING</span>
        <h2 class="product-section-title" style="text-align: center;">Simple, Transparent <span class="text-gradient">Pricing</span></h2>
        <p class="product-body-text" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem;">
          No subscriptions. No hidden fees. Just a one-time cost per run.
        </p>
        <div class="product-pricing-cards">
          <div class="product-pricing-card">
            <div class="product-pricing-label">Full Reallocation</div>
            <div class="product-pricing-price">&pound;225</div>
            <div class="product-pricing-billed">per GP / one-time</div>
            <div class="product-pricing-calc">
              <div class="product-pricing-calc-row">
                <span>Example (3 GPs)</span>
                <span class="product-pricing-calc-val">&pound;675</span>
              </div>
              <div class="product-pricing-calc-row">
                <span>Billing</span>
                <span class="product-pricing-calc-val">One-time cost</span>
              </div>
            </div>
            <ul class="product-check-list">
              <li>Complete patient list redistribution</li>
              <li>Clinically informed allocation</li>
              <li>Stratification by need and complexity</li>
              <li>Direct import into clinical system</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Partial Reallocation</div>
            <div class="product-pricing-price">&pound;75</div>
            <div class="product-pricing-billed">per GP / one-time</div>
            <div class="product-pricing-calc">
              <div class="product-pricing-calc-row">
                <span>Example (3 GPs)</span>
                <span class="product-pricing-calc-val">&pound;225</span>
              </div>
              <div class="product-pricing-calc-row">
                <span>Billing</span>
                <span class="product-pricing-calc-val">One-time cost</span>
              </div>
            </div>
            <ul class="product-check-list">
              <li>Single leaver's patient redistribution</li>
              <li>Clinically informed allocation</li>
              <li>Customisable stratification rules</li>
              <li>Direct import into clinical system</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  .product-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(135deg, #f8faff, #f0f7ff 50%, #f5fdf9);
    text-align: center;
  }

  .product-hero-title {
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .product-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    border-radius: 20px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .product-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-brand-blue);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .product-section-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 1.25rem;
  }

  .product-body-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .product-overview-section {
    background: #f9fafb;
  }

  .product-overview-box {
    max-width: 800px;
  }

  .product-split {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .product-split-left {
    flex: 1;
    min-width: 260px;
  }

  .product-split-right {
    flex: 1.2;
    min-width: 300px;
  }

  .product-split-intro {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-feature-list li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-blue);
  }

  .product-feature-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-feature-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-why-section {
    background: #f9fafb;
  }

  .product-why-box {
    max-width: 800px;
  }

  .product-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-benefit-list li {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
  }

  .product-benefit-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  .product-benefit-list li strong {
    color: var(--color-brand-black);
  }

  /* Steps list */
  .product-steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-steps-list li {
    counter-increment: steps;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 3rem;
    position: relative;
  }

  .product-steps-list li::before {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-brand-blue);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-steps-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-steps-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
