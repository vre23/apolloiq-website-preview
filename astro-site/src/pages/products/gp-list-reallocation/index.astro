---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import CTASection from '../../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="GP List Reallocation - Clinical Stratification | ApolloIQ" description="Smart, clinically stratified patient redistribution when a GP joins or leaves your practice. Fair allocation based on clinical complexity, not just headcount.">
  <Nav />

  <!-- Hero -->
  <section class="product-hero">
    <div class="container-site">
      <span class="product-badge">Automated Workflow</span>
      <div class="product-hero-title-row">
        <img src={`${base}images/icon-spell-book.svg`} alt="GP List Reallocation" class="product-hero-icon" />
        <h1 class="product-hero-title">GP List <span class="text-gradient">Reallocation</span></h1>
      </div>
      <p class="product-subtitle">Clinical Stratification. Not Just Headcount.</p>
      <p class="product-hero-users">Strategic workforce solutions for GP practices, PCNs & federations</p>
      <div class="hero-cta-group">
        <a href={`${base}contact-us`} class="btn-primary">Contact Us</a>
        <a href="https://calendar.app.google/2mH1TehGUkFiBW2D9" target="_blank" rel="noopener" class="btn-secondary">Book a Demo</a>
      </div>
    </div>
  </section>

  <!-- Overview / The Problem -->
  <section class="section product-overview-section">
    <div class="container-site">
      <div class="product-overview-box">
        <span class="product-label">THE PROBLEM</span>
        <h2 class="product-section-title">Headcount Reallocation Creates Unsafe Lists</h2>
        <p class="product-body-text">
          When a GP leaves or joins a practice, patient lists need to be redistributed. The traditional approach — moving patients based on simple headcount — creates <strong>unsafe "dumping grounds"</strong> of high-complexity patients. One GP ends up with a disproportionate share of Learning Disability patients, Care Home residents, and chronic disease management, while another gets a "light" list.
        </p>
        <p class="product-body-text">
          This leads to clinician burnout, unsafe workloads, inequitable QOF burden, and ultimately — GPs leaving the practice. It's a vicious cycle that spreadsheets and guesswork cannot solve.
        </p>

        <div class="gp-solution-box">
          <span class="product-label">THE SOLUTION</span>
          <h2 class="product-section-title">Clinical Stratification That Protects Your Team</h2>
          <p class="product-body-text">
            GP List Reallocation uses a <strong>3-tier clinical stratification model</strong> to ensure every GP receives a balanced, clinically safe patient list. Rather than shuffling numbers, we categorise patients by clinical complexity and apply safety caps to prevent any single GP from being overburdened.
          </p>
          <p class="product-body-text">
            The result: equitable workloads, protected QOF performance, and workforce retention. This is <strong>workforce sustainability in action</strong>.
          </p>
        </div>
        <a href={`${base}contact-us`} class="btn-primary" style="margin-top: 1rem;">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- 3-Step Stratification Methodology -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Stratification <span class="text-gradient">Methodology</span></h2>
          <p class="product-split-intro">A 3-tier hierarchy of clinical need that prevents outlier concentration and ensures fairness.</p>
        </div>
        <div class="product-split-right">
          <div class="gp-strat-steps">
            <div class="gp-strat-card">
              <div class="gp-strat-number">1</div>
              <div>
                <strong>Primary Workload (Safety Cap)</strong>
                <span><em>Target:</em> Learning Disabilities (LD) & Care Home patients. Capped at ~33% for reallocation with random selection to prevent bias.</span>
              </div>
            </div>
            <div class="gp-strat-card">
              <div class="gp-strat-number">2</div>
              <div>
                <strong>Secondary Workload (QOF Protection)</strong>
                <span><em>Target:</em> Patients with 2+ chronic conditions. Capped at ~33% to prevent high concentration of chronic disease management in any single list.</span>
              </div>
            </div>
            <div class="gp-strat-card">
              <div class="gp-strat-number">3</div>
              <div>
                <strong>General Population</strong>
                <span><em>Target:</em> All remaining patients. Randomly selected from the remaining pool to meet the final numerical target required.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Benefits / Dual Value -->
  <section class="section product-why-section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Key <span class="text-gradient">Benefits</span></h2>
          <p class="product-split-intro">Clinical safety and workforce sustainability — not just admin efficiency.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>Prevents Unsafe Concentration</strong>
              <span>Clinical stratification ensures no single GP inherits a disproportionate share of complex patients — preventing "dumping grounds."</span>
            </li>
            <li>
              <strong>QOF Protection</strong>
              <span>Chronic disease management is distributed fairly across GPs, protecting practice QOF performance and income.</span>
            </li>
            <li>
              <strong>Workforce Retention</strong>
              <span>Equitable workloads reduce burnout and create "breathing room" for senior partners — keeping your team together.</span>
            </li>
            <li>
              <strong>CQC-Ready Audit Trail</strong>
              <span>Every run produces a detailed post-move audit report — robust "proof of work" for CQC inspections and partnership governance.</span>
            </li>
            <li>
              <strong>Operational Continuity</strong>
              <span>Patient lists updated rapidly to support workforce changes — whether a GP is leaving, joining, or on extended leave.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">How Does It <span class="text-gradient">Work?</span></h2>
          <p class="product-split-intro">
            A streamlined, end-to-end service — from data ingestion to EMIS execution.
          </p>
        </div>
        <div class="product-split-right">
          <ol class="product-steps-list">
            <li>
              <strong>Data Ingestion</strong>
              <span>You provide patient data lists in CSV format (EMIS numbers and designated destination GPs). We handle the rest.</span>
            </li>
            <li>
              <strong>Clinical Stratification</strong>
              <span>Our algorithm categorises patients by LD, Care Home status, chronic conditions (2+), and general population — applying safety caps at each tier.</span>
            </li>
            <li>
              <strong>Reallocation Execution</strong>
              <span>The automation engine executes transfers directly within your EMIS clinical system, based strictly on the stratified lists.</span>
            </li>
            <li>
              <strong>Validation & Audit Report</strong>
              <span>Safety checks ensure patient data integrity. A detailed post-move audit report is provided showing before/after composition for every GP.</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study / By the Numbers -->
  <section class="section gp-stats-section">
    <div class="container-site">
      <span class="product-label">CASE STUDY</span>
      <h2 class="product-section-title">By the <span class="text-gradient">Numbers</span></h2>
      <p class="product-body-text" style="max-width: 700px;">
        A real-world reallocation across a 9-GP practice, creating a new list for a joining GP while rebalancing the entire partnership.
      </p>
      <div class="gp-stats-grid">
        <div class="gp-stat-card">
          <div class="gp-stat-value">9</div>
          <div class="gp-stat-label">GPs Reallocated</div>
          <div class="gp-stat-compare">in a single run</div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-value">971</div>
          <div class="gp-stat-label">Patients Moved</div>
          <div class="gp-stat-compare">to create a new list</div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-value">~18%</div>
          <div class="gp-stat-label">Complex Cases</div>
          <div class="gp-stat-compare">in the new list (safe ratio)</div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-value">&pound;750</div>
          <div class="gp-stat-label">Total Cost</div>
          <div class="gp-stat-compare">for the entire practice</div>
        </div>
      </div>
      <div class="gp-case-detail">
        <h3 class="gp-case-title">What Happened</h3>
        <div class="gp-case-grid">
          <div class="gp-case-item">
            <div class="gp-case-icon gp-case-down">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="7 13 12 18 17 13"/><line x1="12" y1="6" x2="12" y2="18"/></svg>
            </div>
            <div>
              <strong>Overloaded GPs Reduced</strong>
              <span>GPs with 2,200+ patients brought down to ~1,300–1,500 — creating breathing room for senior partners.</span>
            </div>
          </div>
          <div class="gp-case-item">
            <div class="gp-case-icon gp-case-up">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 11 12 6 7 11"/><line x1="12" y1="18" x2="12" y2="6"/></svg>
            </div>
            <div>
              <strong>Under-Loaded GPs Balanced</strong>
              <span>GPs with just 200–500 patients brought up to the practice average of ~1,500 — absorbing appropriate complexity.</span>
            </div>
          </div>
          <div class="gp-case-item">
            <div class="gp-case-icon gp-case-new">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </div>
            <div>
              <strong>New List Created Safely</strong>
              <span>The joining GP received a balanced list of 971 patients: ~18% complex cases, ~82% general population — clinically safe from day one.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Service <span class="text-gradient">Features</span></h2>
          <p class="product-split-intro">Enterprise-grade automation with clinical governance built in.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>EMIS Integration</strong>
              <span>Automation executes transfers directly within the EMIS clinical system — no manual data entry required.</span>
            </li>
            <li>
              <strong>Data Integrity Validation</strong>
              <span>Safety checks ensure patient data is maintained accurately during every transfer.</span>
            </li>
            <li>
              <strong>Post-Move Audit Report</strong>
              <span>Detailed reporting showing before/after composition by GP, including LD, Care Home, chronic, and general patient counts.</span>
            </li>
            <li>
              <strong>Client-Controlled Logic</strong>
              <span>You retain control over clinical logic and patient selection. We handle the system processing, validation, and audit trails.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section product-pricing-section">
    <div class="container-site">
      <div class="product-pricing-wrap">
        <span class="product-label">PRICING</span>
        <h2 class="product-section-title" style="text-align: center;">Simple, Transparent <span class="text-gradient">Pricing</span></h2>
        <p class="product-body-text" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem;">
          No subscriptions. No hidden fees. Just a one-time cost per run.
        </p>
        <div class="product-pricing-cards">
          <div class="product-pricing-card">
            <div class="product-pricing-label">Partial Reallocation</div>
            <div class="product-pricing-price">&pound;75</div>
            <div class="product-pricing-billed">per GP / one-time</div>
            <ul class="product-check-list">
              <li>Adjust an existing GP's patient list</li>
              <li>Balance workload up or down</li>
              <li>Clinical stratification applied</li>
              <li>Post-move audit report</li>
              <li>Direct EMIS execution</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Complete Reallocation</div>
            <div class="product-pricing-price">&pound;225</div>
            <div class="product-pricing-billed">per list / one-time</div>
            <ul class="product-check-list">
              <li>Create a new list for a joining GP</li>
              <li>Or redistribute a leaver's full list</li>
              <li>Full 3-tier stratification logic</li>
              <li>Post-move audit report</li>
              <li>Direct EMIS execution</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
          </div>
          <div class="product-pricing-card">
            <div class="product-pricing-label">Block Agreement</div>
            <div class="product-pricing-price" style="font-size: 2.25rem;">10% Off</div>
            <div class="product-pricing-billed">volume commitment</div>
            <ul class="product-check-list">
              <li>Commit to 4+ runs</li>
              <li>10% discount on total</li>
              <li>Invoiced per run on completion</li>
              <li>12-month agreement</li>
              <li>Priority scheduling</li>
            </ul>
            <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  .product-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(175deg, #ffffff 0%, #f0f4fb 40%, #eef8f5 70%, #f5f7fa 100%);
    text-align: center;
  }

  .product-hero-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-hero-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .product-hero-title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted);
    max-width: 600px;
    margin: 0 auto 1rem;
  }

  .product-hero-users {
    font-size: 0.875rem;
    color: var(--color-brand-grey-muted);
    margin: 0 auto 2rem;
    max-width: 500px;
    opacity: 0.8;
  }

  .product-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    border-radius: 16px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .product-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-brand-blue);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .product-section-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
    margin-bottom: 1.25rem;
  }

  .product-body-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .product-body-text strong {
    color: var(--color-brand-black);
  }

  .product-overview-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-overview-box {
    max-width: 800px;
  }

  .gp-solution-box {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-brand-grey-border);
  }

  /* Stratification steps */
  .gp-strat-steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .gp-strat-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--color-brand-grey-bg-subtle);
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 12px;
  }

  .gp-strat-number {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-brand-blue);
    color: #fff;
    font-size: 1.125rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .gp-strat-card strong {
    display: block;
    font-size: 1.0625rem;
    color: var(--color-brand-black);
    margin-bottom: 0.375rem;
  }

  .gp-strat-card span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  .gp-strat-card em {
    color: var(--color-brand-blue);
    font-style: normal;
    font-weight: 500;
  }

  /* Stats section */
  .gp-stats-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .gp-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin: 2.5rem 0;
  }

  .gp-stat-card {
    background: #fff;
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 14px;
    padding: 1.75rem 1.25rem;
    text-align: center;
  }

  .gp-stat-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-brand-blue);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .gp-stat-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-brand-black);
    margin-top: 0.5rem;
  }

  .gp-stat-compare {
    font-size: 0.8125rem;
    color: var(--color-brand-grey-muted);
    margin-top: 0.25rem;
  }

  .gp-case-detail {
    background: #fff;
    border: 1px solid var(--color-brand-grey-border);
    border-radius: 14px;
    padding: 2rem;
  }

  .gp-case-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 1.5rem;
  }

  .gp-case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gp-case-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .gp-case-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .gp-case-down {
    background: rgba(231, 76, 60, 0.1);
    color: #e74c3c;
  }

  .gp-case-up {
    background: rgba(39, 174, 96, 0.1);
    color: #27ae60;
  }

  .gp-case-new {
    background: rgba(44, 112, 235, 0.1);
    color: var(--color-brand-blue);
  }

  .gp-case-item strong {
    display: block;
    font-size: 0.9375rem;
    color: var(--color-brand-black);
    margin-bottom: 0.25rem;
  }

  .gp-case-item span {
    font-size: 0.875rem;
    color: var(--color-brand-grey);
    line-height: 1.6;
  }

  /* Shared layout */
  .product-split {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .product-split-left {
    flex: 1;
    min-width: 260px;
  }

  .product-split-right {
    flex: 1.2;
    min-width: 300px;
  }

  .product-split-intro {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-feature-list li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-blue);
  }

  .product-feature-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-feature-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-why-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-steps-list li {
    counter-increment: steps;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 3rem;
    position: relative;
  }

  .product-steps-list li::before {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-brand-blue);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-steps-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-steps-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .product-hero-icon {
      width: 36px;
      height: 36px;
    }
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
    .gp-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gp-case-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .gp-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
