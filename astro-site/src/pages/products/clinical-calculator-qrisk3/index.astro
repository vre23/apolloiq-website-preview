---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import CTASection from '../../../components/CTASection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Clinical Calculator (QRisk3)" description="Automated cardiovascular risk scoring - fast, reliable, and cost-effective. QRisk3 calculations that save clinician time.">
  <Nav />

  <!-- Hero -->
  <section class="product-hero">
    <div class="container-site">
      <span class="product-badge">Automated Workflow</span>
      <div class="product-hero-title-row">
        <img src={`${base}images/icon-spell-book.svg`} alt="" class="product-hero-icon" />
        <h1 class="product-hero-title">Clinical Calculations <span class="text-gradient">(QRisk3)</span></h1>
      </div>
      <p class="product-subtitle">Automated Cardiovascular Risk Scoring -- Fast, Reliable, and Cost-Effective</p>
      <div class="hero-cta-group">
        <a href={`${base}contact-us`} class="btn-primary">Contact Us</a>
        <a href="#book-demo" class="btn-secondary" data-product="qrisk3">Book a Demo</a>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section product-overview-section">
    <div class="container-site">
      <div class="product-overview-box">
        <span class="product-label">OVERVIEW</span>
        <h2 class="product-section-title">QRisk3 Automated Calculations</h2>
        <p class="product-body-text">
          Say goodbye to manual calculations. Our QRisk3 Calculations delivers accurate cardiovascular risk assessments instantly. Designed to eliminate repetitive tasks, it empowers clinicians to focus on care -- not calculations.
        </p>
        <a href={`${base}contact-us`} class="btn-primary" style="margin-top: 1rem;">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Key & <span class="text-gradient">Benefits</span></h2>
          <p class="product-split-intro">3 key features that make our QRisk3 Automated Calculations essential for your practice.</p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>NHS Approved Calculator</strong>
              <span>Automatically calculates QRisk3 scores for patients in bulk or on demand using NHS approved QRisk3 calculator.</span>
            </li>
            <li>
              <strong>High-Speed Processing</strong>
              <span>Processes up to 70 patients per minute, dramatically cutting down time.</span>
            </li>
            <li>
              <strong>Direct Integration</strong>
              <span>Results integrate directly into clinical decision-making workflows.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section product-why-section">
    <div class="container-site">
      <div class="product-why-box">
        <span class="product-label">WHY US?</span>
        <h2 class="product-section-title">Why Choose ApolloIQ's QRisk Calculator?</h2>
        <p class="product-body-text">
          Our QRisk3 Calculator is built for practices seeking accuracy, safety, and efficiency. It eliminates human error, saves clinical time, and scales effortlessly across large patient populations. Reliable, fast, and built for primary care -- this is automation done right.
        </p>
        <ul class="product-benefit-list">
          <li><strong>Saves clinician time</strong> by replacing manual, repetitive calculations.</li>
          <li><strong>Reduces costs</strong> -- saving practices up to &pound;22,000/year.</li>
          <li><strong>Minimises errors</strong> through automation and standardised outputs.</li>
          <li><strong>Improves patient care</strong> with real-time, data-driven assessments.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Why You'll Love It -->
  <section class="section">
    <div class="container-site">
      <div class="product-split">
        <div class="product-split-left">
          <h2 class="product-section-title">Why You Will <span class="text-gradient">Love</span> It</h2>
          <p class="product-split-intro">
            This Workflow automatically calculates risk scores using patient data during consultations.
          </p>
        </div>
        <div class="product-split-right">
          <ul class="product-feature-list">
            <li>
              <strong>More Time with Patients</strong>
              <span>Manual assessments take 4-5 minutes per patient -- you have more time with your patient.</span>
            </li>
            <li>
              <strong>Reduced Manual Work</strong>
              <span>Reduces manual calculation time for clinicians.</span>
            </li>
            <li>
              <strong>Affordable Pricing</strong>
              <span>&pound;150 per 1,000 patients per year.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section product-pricing-section">
    <div class="container-site">
      <div class="product-pricing-wrap">
        <span class="product-label">PRICING</span>
        <h2 class="product-section-title" style="text-align: center;">Simple, Transparent <span class="text-gradient">Pricing</span></h2>
        <p class="product-body-text" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem;">
          No hidden fees. No complex contracts. Just straightforward pricing.
        </p>
        <div class="product-pricing-card">
          <div class="product-pricing-label">Per 1,000 patients / year</div>
          <div class="product-pricing-price">&pound;150</div>
          <div class="product-pricing-billed">per 1,000 patients / year</div>
          <div class="product-pricing-calc">
            <div class="product-pricing-calc-row">
              <span>10,000 patients</span>
              <span class="product-pricing-calc-val">&pound;1,500/year</span>
            </div>
            <div class="product-pricing-calc-row">
              <span>Manual calculation cost</span>
              <span class="product-pricing-calc-val">~&pound;23,500/year</span>
            </div>
            <div class="product-pricing-calc-row">
              <span>Your savings</span>
              <span class="product-pricing-calc-val">Up to &pound;22,000/year</span>
            </div>
          </div>
          <ul class="product-check-list">
            <li>NHS approved QRisk3 calculator</li>
            <li>Up to 70 patients processed per minute</li>
            <li>Save up to &pound;22,000/year vs manual calculations</li>
            <li>Direct integration into clinical workflows</li>
            <li>Bulk and on-demand processing</li>
          </ul>
          <a href={`${base}contact-us`} class="btn-primary" style="width: 100%;">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section qrisk-stats-section">
    <div class="container-site">
      <div class="qrisk-stats-grid">
        <div class="qrisk-stat-card">
          <div class="qrisk-stat-value">70</div>
          <div class="qrisk-stat-desc">patients processed per minute</div>
        </div>
        <div class="qrisk-stat-card">
          <div class="qrisk-stat-value qrisk-stat-green">4-5 min</div>
          <div class="qrisk-stat-desc">saved per patient assessment</div>
        </div>
        <div class="qrisk-stat-card">
          <div class="qrisk-stat-value">&pound;22,000</div>
          <div class="qrisk-stat-desc">potential annual savings</div>
        </div>
        <div class="qrisk-stat-card">
          <div class="qrisk-stat-value qrisk-stat-green">&pound;150</div>
          <div class="qrisk-stat-desc">per 1,000 patients per year</div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>

<style>
  .product-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(175deg, #ffffff 0%, #f0f4fb 40%, #eef8f5 70%, #f5f7fa 100%);
    text-align: center;
  }

  .product-hero-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-hero-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .product-hero-title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-brand-grey-muted);
    max-width: 650px;
    margin: 0 auto 2rem;
  }

  .product-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(44, 112, 235, 0.08);
    color: var(--color-brand-blue);
    border-radius: 16px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .product-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-brand-blue);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .product-section-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
    margin-bottom: 1.25rem;
  }

  .product-body-text {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .product-overview-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-overview-box {
    max-width: 800px;
  }

  .product-split {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .product-split-left {
    flex: 1;
    min-width: 260px;
  }

  .product-split-right {
    flex: 1.2;
    min-width: 300px;
  }

  .product-split-intro {
    font-size: 1.0625rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-feature-list li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-blue);
  }

  .product-feature-list li strong {
    font-size: 1.0625rem;
    color: var(--color-brand-black);
  }

  .product-feature-list li span {
    font-size: 0.9375rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .product-why-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .product-why-box {
    max-width: 800px;
  }

  .product-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-benefit-list li {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
  }

  .product-benefit-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-brand-green);
    font-weight: 700;
  }

  .product-benefit-list li strong {
    color: var(--color-brand-black);
  }

  /* Stats */
  .qrisk-stats-section {
    background: linear-gradient(180deg, #f0f4fb 0%, #eef8f5 50%, #f5f7fa 100%);
  }

  .qrisk-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .qrisk-stat-card {
    text-align: center;
    padding: 2rem 1.5rem;
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(44, 112, 235, 0.06);
    box-shadow: var(--shadow-card);
  }

  .qrisk-stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .qrisk-stat-green {
    color: var(--color-brand-green);
  }

  .qrisk-stat-desc {
    font-size: 0.9375rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .product-hero-icon {
      width: 36px;
      height: 36px;
    }
    .product-hero-title {
      font-size: 2.25rem;
    }
    .product-split {
      flex-direction: column;
      gap: 2rem;
    }
    .qrisk-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .qrisk-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
