---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact Us" description="Get in touch with ApolloIQ. We're here to help with questions about our healthcare automation products and services.">
  <Nav />

  <!-- Hero Section -->
  <section class="section-hero contact-hero">
    <div class="container-site">
      <div class="hero-split">
        <div class="hero-left">
          <h1 class="hero-title">
            Get In Touch with <span class="text-gradient">ApolloIQ</span>
          </h1>
        </div>
        <div class="hero-right">
          <p class="hero-subtitle">
            We're here to help. Whether you have questions about our products, need support,
            or want to discuss how we can tailor solutions for your practice, our team is ready to assist you.
          </p>
          <a href={`${base}about`} class="btn-primary">Find out more</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section contact-section">
    <div class="container-site">
      <div class="contact-wrapper">
        <div class="contact-body">
          <!-- Info Side -->
          <div class="contact-info">
            <h2 class="contact-info-heading">Let's Start a Conversation</h2>
            <p class="contact-info-text">
              Feel free to contact us with any queries, or questions that you have.
              A member of our team will reach out to you as quickly as we can!
            </p>
            <p class="contact-info-text">
              Alternatively, if you prefer to contact us directly, you can email us at:
              <a href="mailto:contact@apolloiq.co.uk" class="contact-email-link">contact@apolloiq.co.uk</a>
            </p>

            <div class="contact-details">
              <div class="contact-detail-item">
                <div class="contact-detail-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <p class="contact-detail-label">Email</p>
                  <a href="mailto:contact@apolloiq.co.uk" class="contact-detail-value">contact@apolloiq.co.uk</a>
                </div>
              </div>
              <div class="contact-detail-item">
                <div class="contact-detail-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <p class="contact-detail-label">Location</p>
                  <p class="contact-detail-value">Taunton, Somerset, UK</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Form Side -->
          <div class="contact-form-wrap">
            <form class="contact-form" id="contact-form">
              <div class="form-group">
                <label for="contact-name" class="form-label">Name / Business</label>
                <input
                  class="form-field"
                  type="text"
                  id="contact-name"
                  name="name"
                  placeholder="Name/Business*"
                  required
                  autocomplete="organization"
                />
              </div>
              <div class="form-group">
                <label for="contact-email" class="form-label">Email</label>
                <input
                  class="form-field"
                  type="email"
                  id="contact-email"
                  name="email"
                  placeholder="Email*"
                  required
                  autocomplete="email"
                />
              </div>
              <div class="form-group">
                <label for="contact-message" class="form-label">Message</label>
                <textarea
                  class="form-field form-textarea"
                  id="contact-message"
                  name="message"
                  placeholder="Write your message here...*"
                  required
                  rows="5"
                ></textarea>
              </div>
              <button type="submit" class="btn-primary contact-submit">Submit!</button>
              <label class="contact-consent">
                <input type="checkbox" name="consent" class="contact-checkbox" />
                <span class="contact-consent-text">
                  I consent to receive updates on events, digital marketing and business.
                </span>
              </label>
            </form>
            <div class="form-success" id="form-success" hidden>
              <div class="success-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="24" fill="var(--color-brand-green)"/>
                  <path d="M16 24L22 30L32 18" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Thank you!</h3>
              <p>Your submission has been received. We'll get back to you soon.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .contact-hero {
    padding: 6rem 0 4rem;
  }

  .hero-split {
    display: flex;
    align-items: flex-start;
    gap: 4rem;
  }

  .hero-left {
    flex: 1.2;
  }

  .hero-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  /* ── Contact Section ── */
  .contact-section {
    padding-bottom: 5rem;
  }

  .contact-wrapper {
    background-image: url('/apolloiq-website-preview/images/685dc40ff887e05cecfae31f_Background4.png');
    background-position: center;
    background-size: cover;
    border-radius: var(--radius-card);
    padding: 3rem;
    box-shadow: var(--shadow-card-lg);
  }

  .contact-body {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
  }

  /* ── Info Side ── */
  .contact-info {
    flex: 1;
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-brand-black);
    line-height: 1.2;
  }

  .contact-info-text {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .contact-email-link {
    color: var(--color-brand-blue);
    font-weight: 500;
    transition: color 0.2s;
  }

  .contact-email-link:hover {
    color: var(--color-brand-blue-dark);
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-brand-grey-border);
  }

  .contact-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .contact-detail-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--color-brand-blue-light);
    color: var(--color-brand-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-detail-label {
    font-size: 0.8125rem;
    color: var(--color-brand-grey-muted);
    margin-bottom: 0.125rem;
  }

  .contact-detail-value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-brand-black);
    transition: color 0.2s;
  }

  a.contact-detail-value:hover {
    color: var(--color-brand-blue);
  }

  /* ── Form Side ── */
  .contact-form-wrap {
    flex: 1;
    min-width: 300px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-black);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    margin-top: 0.5rem;
    width: fit-content;
  }

  .contact-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-top: 0.25rem;
    cursor: pointer;
  }

  .contact-checkbox {
    margin-top: 3px;
    flex-shrink: 0;
    accent-color: var(--color-brand-blue);
  }

  .contact-consent-text {
    font-size: 0.75rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.5;
  }

  /* ── Form Success ── */
  .form-success {
    text-align: center;
    padding: 3rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-black);
  }

  .form-success p {
    font-size: 1rem;
    color: var(--color-brand-grey);
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .hero-split {
      flex-direction: column;
      gap: 2rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding: 4rem 0 3rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .contact-wrapper {
      padding: 2rem 1.5rem;
    }

    .contact-body {
      gap: 2.5rem;
    }

    .contact-info-heading {
      font-size: 1.5rem;
    }
  }
</style>
