---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Practice Efficiency Audit | ApolloIQ" description="Find out how much time and money your practice loses to manual admin — and see a clear ROI breakdown for automating it.">
  <Nav />

  <section class="audit-hero">
    <div class="container-site">
      <a href={`${base}`} class="audit-back-link">&larr; Back to Home</a>
    </div>
  </section>

  <section class="audit-wrapper">
    <div class="container-site">
      <div id="audit-app" class="audit-app"></div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .audit-hero {
    padding: 1.5rem 0 0;
  }

  .audit-back-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-grey-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .audit-back-link:hover {
    color: var(--color-brand-blue);
  }

  .audit-wrapper {
    padding: 1.5rem 0 5rem;
    min-height: 60vh;
  }

  .audit-app {
    max-width: 720px;
    margin: 0 auto;
    font-family: 'Outfit', var(--font-roboto), sans-serif;
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<script define:vars={{ base }}>
// ─── PRACTICE EFFICIENCY AUDIT v5 ───────────────────
// 17 questions, 5 modules, real pricing & ROI

const QUESTIONS = [
  { id: "practice_size", section: "About Your Practice", question: "How many registered patients does your practice have?", type: "single", options: [
    { label: "Under 5,000", value: "small", mult: 0.5, patients: 3500, pathEpisodesPerDay: 33, pathResultsPerDay: 150, docsPerDay: 75, gpsHeadcount: 2 },
    { label: "5,000 \u2013 10,000", value: "medium", mult: 1, patients: 7500, pathEpisodesPerDay: 65, pathResultsPerDay: 290, docsPerDay: 145, gpsHeadcount: 4 },
    { label: "10,000 \u2013 15,000", value: "large", mult: 1.5, patients: 12500, pathEpisodesPerDay: 98, pathResultsPerDay: 440, docsPerDay: 220, gpsHeadcount: 6 },
    { label: "Over 15,000", value: "xlarge", mult: 2, patients: 17500, pathEpisodesPerDay: 130, pathResultsPerDay: 580, docsPerDay: 290, gpsHeadcount: 8 },
  ]},
  { id: "clinical_users", section: "About Your Practice", question: "How many clinical users would need access to practice tools? (GPs, nurses, pharmacists, paramedics \u2014 anyone who reviews results, documents, or prescriptions)", type: "single", options: [
    { label: "1 \u2013 3 users", value: "tiny", users: 2 },
    { label: "4 \u2013 6 users", value: "small", users: 5 },
    { label: "7 \u2013 10 users", value: "medium", users: 8 },
    { label: "11 \u2013 15 users", value: "large", users: 13 },
    { label: "Over 15 users", value: "xlarge", users: 18 },
  ]},
  { id: "vendor_count", section: "Your Current Setup", question: "How many different software tools or vendors does your practice use for admin automation (excluding your clinical system)?", type: "single", options: [
    { label: "None \u2014 everything is manual", value: "none", score: 3 },
    { label: "1 \u2013 2 tools", value: "few", score: 1 },
    { label: "3 \u2013 4 tools", value: "several", score: 2 },
    { label: "5 or more tools", value: "many", score: 3 },
  ]},
  { id: "vendor_pain", section: "Your Current Setup", question: "What frustrates you most about your current admin and automation setup?", type: "multi", options: [
    { label: "Too many separate systems that don't talk to each other", value: "fragmented" },
    { label: "Manual processes that are slow and error-prone", value: "manual" },
    { label: "Difficult to train new staff on multiple tools", value: "training" },
    { label: "No single view of what's been done and what's outstanding", value: "visibility" },
    { label: "Cost of maintaining multiple vendor contracts", value: "cost" },
    { label: "Compliance and IG headaches across multiple vendors", value: "compliance" },
  ]},
  { id: "path_backlog", section: "Pathology Results", question: "At the end of a typical day, how many pathology results are still waiting to be reviewed by a GP?", type: "single", options: [
    { label: "Very few \u2014 most are reviewed the same day", value: "low", score: 0 },
    { label: "A noticeable backlog \u2014 some wait until the next day", value: "moderate", score: 2 },
    { label: "A significant backlog \u2014 results can wait 2\u20133 days", value: "high", score: 3 },
    { label: "It varies wildly depending on who's in", value: "variable", score: 2 },
  ]},
  { id: "path_overtime", section: "Pathology Results", question: "Do GPs at your practice regularly stay late or work outside of sessions to get through pathology results?", type: "single", options: [
    { label: "No \u2014 results are managed within normal sessions", value: "none", score: 0 },
    { label: "Occasionally \u2014 maybe once or twice a week", value: "occasional", score: 2 },
    { label: "Regularly \u2014 most GPs stay late to clear results", value: "regular", score: 3 },
    { label: "It's a constant source of frustration and burnout", value: "severe", score: 4 },
  ]},
  { id: "path_abnormal", section: "Pathology Results", question: "How confident are you that abnormal results are always spotted and actioned promptly \u2014 even on busy days?", type: "single", options: [
    { label: "Very confident \u2014 we have a robust system", value: "confident", score: 0 },
    { label: "Fairly confident \u2014 but it depends on workload", value: "mostly", score: 2 },
    { label: "Not very confident \u2014 things have been missed before", value: "concerned", score: 4 },
    { label: "It keeps me up at night honestly", value: "serious", score: 5 },
  ]},
  { id: "doc_sorting", section: "Clinical Documents", question: "How are incoming clinical documents (letters, discharge summaries, reports) sorted and routed to the right clinician?", type: "single", options: [
    { label: "Admin staff read each document and manually assign it", value: "manual", score: 3 },
    { label: "We use a tool but still need manual sorting for most items", value: "partial", score: 2 },
    { label: "Mostly automated \u2014 very little manual sorting needed", value: "mostly_auto", score: 1 },
    { label: "Fully automated \u2014 documents route themselves", value: "automated", score: 0 },
  ]},
  { id: "doc_bottleneck", section: "Clinical Documents", question: "How often does the document workflow create a bottleneck \u2014 documents piling up or being delayed?", type: "single", options: [
    { label: "Rarely \u2014 we keep on top of it", value: "rarely", score: 0 },
    { label: "Occasionally \u2014 when staff are off or it's busy", value: "occasional", score: 2 },
    { label: "Frequently \u2014 there's almost always a queue", value: "frequent", score: 3 },
    { label: "Constantly \u2014 it's one of our biggest admin headaches", value: "constant", score: 4 },
  ]},
  { id: "scribe_current", section: "Clinical Documentation", question: "How do your GPs currently document consultations?", type: "single", options: [
    { label: "Type notes manually during or after each consultation", value: "manual", score: 3 },
    { label: "Use templates/macros but still type most of the free text", value: "templates", score: 2 },
    { label: "Use dictation software (e.g. Dragon) that they then edit", value: "dictation", score: 1 },
    { label: "Already using an AI scribe (e.g. Heidi, Tortus, Accurx Scribe)", value: "ai_scribe", score: 0 },
  ]},
  { id: "scribe_afterhours", section: "Clinical Documentation", question: "How much time do your GPs spend writing up or finishing consultation notes outside of appointment slots (lunch, after sessions, evenings)?", type: "single", options: [
    { label: "Very little \u2014 notes are done within the consultation", value: "none", score: 0, minsPerGPPerDay: 0 },
    { label: "15 \u2013 30 minutes per GP per day", value: "some", score: 2, minsPerGPPerDay: 22 },
    { label: "30 \u2013 60 minutes per GP per day", value: "significant", score: 3, minsPerGPPerDay: 45 },
    { label: "Over an hour per GP per day \u2014 it's a major issue", value: "severe", score: 4, minsPerGPPerDay: 75 },
  ]},
  { id: "bp_register", section: "Blood Pressure Management", question: "Roughly how many patients are on your practice's hypertension QOF register?", type: "single", options: [
    { label: "Under 800", value: "small", htCount: 600, bpEpisodes: 1400 },
    { label: "800 \u2013 1,500", value: "medium", htCount: 1150, bpEpisodes: 2700 },
    { label: "1,500 \u2013 2,500", value: "large", htCount: 2000, bpEpisodes: 4600 },
    { label: "Over 2,500", value: "xlarge", htCount: 3000, bpEpisodes: 6900 },
    { label: "I'm not sure", value: "unknown", htCount: 1550, bpEpisodes: 3600 },
  ]},
  { id: "bp_process", section: "Blood Pressure Management", question: "How does your practice handle BP readings \u2014 recording, averaging, and adding to patient records?", type: "single", options: [
    { label: "Manually calculated and entered by staff", value: "manual", score: 3, hours: 3 },
    { label: "We use a spreadsheet or calculator, then manually enter", value: "semi", score: 2, hours: 2 },
    { label: "Automated \u2014 readings are digitised and averaged automatically", value: "automated", score: 0, hours: 0 },
    { label: "We don't have a consistent process", value: "inconsistent", score: 3, hours: 3 },
  ]},
  { id: "bp_errors", section: "Blood Pressure Management", question: "Has your practice ever identified (or suspected) a BP averaging error that could have affected a treatment decision \u2014 e.g. starting, stopping, or changing antihypertensive medication?", type: "single", options: [
    { label: "No \u2014 we're confident our calculations are accurate", value: "confident", score: 0 },
    { label: "Possibly \u2014 but we'd have no way of knowing for certain", value: "uncertain", score: 2 },
    { label: "Yes \u2014 we've caught errors before they reached the patient", value: "caught", score: 3 },
    { label: "Yes \u2014 and an error has affected a clinical decision at least once", value: "affected", score: 5 },
  ]},
  { id: "rx_pharmacy_calls", section: "Medication Queries", question: "How many calls per day does your practice receive from pharmacies about out-of-stock medications needing prescription changes?", type: "single", options: [
    { label: "Rarely \u2014 less than 1 per day", value: "rare", callsPerDay: 0.5, score: 0 },
    { label: "1 \u2013 3 calls per day", value: "some", callsPerDay: 2, score: 1 },
    { label: "4 \u2013 8 calls per day", value: "frequent", callsPerDay: 6, score: 3 },
    { label: "More than 8 \u2014 it's constant", value: "flood", callsPerDay: 10, score: 4 },
  ]},
  { id: "rx_search_time", section: "Medication Queries", question: "How much time per week does your team spend searching for medication availability when items are out of stock?", type: "single", options: [
    { label: "Less than 1 hour", value: "low", hours: 0.5 },
    { label: "1 \u2013 3 hours", value: "medium", hours: 2 },
    { label: "3 \u2013 5 hours", value: "high", hours: 4 },
    { label: "Over 5 hours \u2014 it's constant phone calls", value: "very_high", hours: 6 },
  ]},
];

// Module icon paths (relative to base)
const MODULE_ICONS = {
  pathology: base + "images/icon-spell-book.svg",
  documents: base + "images/icon-spell-book.svg",
  scribecraft: base + "images/icon-scribe.svg",
  bp: base + "images/icon-blood-pressure.svg",
  prescriptions: base + "images/icon-locate-elixir.svg",
};

const MODULE_MAP = {
  pathology: { name: "Pathology Automation", key: "pathology", color: "#2c70eb", description: "Results are automatically prepared and prioritised for GP review \u2014 abnormals flagged, routine results batched. GPs spend less time sorting and more time making clinical decisions." },
  documents: { name: "Clinical Document Management", key: "documents", color: "#00c393", description: "Incoming letters, discharge summaries, and reports are automatically sorted and routed to the right clinician \u2014 no more admin staff reading and manually assigning every document." },
  scribecraft: { name: "ScribeCraft", key: "scribecraft", color: "#10a5b3", description: "AI-powered clinical documentation that listens to consultations and generates structured notes for GP review. Reduces documentation time by up to 50%, giving GPs more time with patients and less time typing." },
  bp: { name: "Blood Pressure Scroll", key: "bp", color: "#e74c6f", description: "Digitises and averages BP readings automatically \u2014 eliminating manual calculation errors that can cross treatment thresholds and lead to wrong prescribing decisions. Accurate every time, for every patient." },
  prescriptions: { name: "Locate Elixir", key: "prescriptions", color: "#7C3AED", description: "Real-time medication availability search across pharmacies. Replaces time-consuming phone calls when items are out of stock with an instant lookup." },
};

const PRICING = { pathology: { perPatientYear: 0.30 }, documents: { perPatientYear: 0.30 }, scribecraft: { perUserMonth: 16.99 }, bp: { perUserMonth: 10 }, prescriptions: { perUserMonth: 13 } };
const HOURLY_RATE_ADMIN = 14.50;
const HOURLY_RATE_GP = 85;
const WEEKS_PER_YEAR = 48;
const WORKING_DAYS_YEAR = 240;

const painLabels = {
  fragmented: "Systems that don't talk to each other",
  manual: "Slow, error-prone manual processes",
  training: "Hard to train staff across multiple tools",
  visibility: "No single view of what's done and what's outstanding",
  cost: "Multiple vendor contracts adding up",
  compliance: "IG headaches across multiple vendors",
};

// ─── STATE ───────────────────────────────────────────
let phase = "start";
let currentQ = 0;
let answers = {};
let multiSelect = [];
let resultStep = 0;
let resultTimer = null;
const app = document.getElementById("audit-app");

function moduleIcon(key, size) {
  size = size || 24;
  return '<img src="' + MODULE_ICONS[key] + '" alt="" width="' + size + '" height="' + size + '" style="display:block" />';
}

function render() {
  if (phase === "start") renderStart();
  else if (phase === "questions") renderQuestion();
  else if (phase === "results") renderResults();
}

// ─── START SCREEN ────────────────────────────────────
function renderStart() {
  app.innerHTML = '\
    <div class="au-card">\
      <div class="au-hdr" style="text-align:center;padding:36px 32px">\
        <div style="margin-bottom:12px"><img src="' + base + 'images/logo_Merlin_color.svg" alt="Merlin" style="height:48px;filter:brightness(0) invert(1);opacity:0.9" /></div>\
        <div style="font-size:23px;font-weight:800;margin-bottom:8px">Practice Efficiency Audit</div>\
        <div style="font-size:14px;opacity:0.8;line-height:1.55;max-width:460px;margin:0 auto">\
          Find out how much time and money your practice loses to manual admin \u2014 and see a clear ROI breakdown for automating it.\
        </div>\
      </div>\
      <div class="au-body">\
        <div class="au-chips">\
          <div class="au-chip"><span style="font-size:18px;display:block;margin-bottom:4px">\u23F1\uFE0F</span>Takes 3 minutes</div>\
          <div class="au-chip"><span style="font-size:18px;display:block;margin-bottom:4px">\uD83D\uDCB0</span>Real ROI numbers</div>\
          <div class="au-chip"><span style="font-size:18px;display:block;margin-bottom:4px">\uD83D\uDCCA</span>Instant results</div>\
        </div>\
        <p style="font-size:13px;color:#667085;line-height:1.6;margin-bottom:22px;text-align:center">' + QUESTIONS.length + ' quick questions about pathology, documents, clinical documentation, blood pressure, and prescriptions. You\u2019ll see where time is lost, how you benchmark nationally, and a transparent cost-vs-savings breakdown.</p>\
        <button class="au-primary" id="au-start">Start the Audit \u2192</button>\
        <div style="font-size:11px;color:#98a2b3;text-align:center;margin-top:10px">Benchmarks: NHS England Digital, BJGP, GOSH AI Scribe Pilot, QOF 2024\u201325 \u00B7 Pricing: apolloiq.co.uk (Org tier)</div>\
      </div>\
    </div>';
  document.getElementById("au-start").addEventListener("click", function() {
    phase = "questions"; currentQ = 0; render();
  });
}

// ─── QUESTION SCREEN ─────────────────────────────────
function renderQuestion() {
  var q = QUESTIONS[currentQ];
  var progress = Math.round((currentQ / QUESTIONS.length) * 100);
  var isMulti = q.type === "multi";

  app.innerHTML = '\
    <div class="au-card">\
      <div class="au-hdr">\
        <div class="au-hdr-sub">Practice Efficiency Audit</div>\
        <div class="au-hdr-title">' + q.section + '</div>\
        <div class="au-pbar"><div class="au-pfill" style="width:' + progress + '%"></div></div>\
      </div>\
      <div class="au-body au-fade-in">\
        <div class="au-section-label">Question ' + (currentQ + 1) + ' of ' + QUESTIONS.length + '</div>\
        <div class="au-q-text">' + q.question + '</div>\
        <div id="au-options">' +
          q.options.map(function(opt) {
            var sel = isMulti ? multiSelect.indexOf(opt.value) !== -1 : false;
            return '<div class="au-opt ' + (sel ? 'au-opt--sel' : '') + '" data-value="' + opt.value + '">' +
              (isMulti
                ? '<div class="au-chk ' + (sel ? 'au-chk--sel' : '') + '">' + (sel ? '\u2713' : '') + '</div>'
                : '<div class="au-radio"></div>') +
              '<span>' + opt.label + '</span></div>';
          }).join("") +
        '</div>' +
        (isMulti ? '<button class="au-primary au-multi-next" ' + (multiSelect.length === 0 ? 'disabled style="opacity:0.4;cursor:default"' : '') + '>Continue \u2192</button>' : '') +
        '<div class="au-foot">' +
          (currentQ > 0 ? '<button class="au-back-btn" id="au-back">\u2190 Back</button>' : '<span></span>') +
          '<span>' + progress + '% complete</span>' +
        '</div>\
      </div>\
    </div>';

  document.querySelectorAll("#au-options .au-opt").forEach(function(el) {
    el.addEventListener("click", function() {
      var val = el.dataset.value;
      if (isMulti) {
        var idx = multiSelect.indexOf(val);
        if (idx !== -1) multiSelect.splice(idx, 1);
        else multiSelect.push(val);
        render();
      } else {
        var opt = q.options.find(function(o) { return o.value === val; });
        var entry = { value: val };
        for (var k in opt) entry[k] = opt[k];
        answers[q.id] = entry;
        advance();
      }
    });
  });

  var multiBtn = document.querySelector(".au-multi-next");
  if (multiBtn) {
    multiBtn.addEventListener("click", function() {
      if (multiSelect.length === 0) return;
      answers[q.id] = { value: multiSelect.slice(), options: multiSelect.slice() };
      multiSelect = [];
      advance();
    });
  }

  var backBtn = document.getElementById("au-back");
  if (backBtn) {
    backBtn.addEventListener("click", function() {
      if (currentQ > 0) { currentQ--; render(); }
    });
  }
}

function advance() {
  if (currentQ < QUESTIONS.length - 1) { currentQ++; render(); }
  else { phase = "results"; resultStep = 0; render(); }
}

// ─── RESULTS CALCULATION ─────────────────────────────
function calculateResults() {
  var size = answers.practice_size || {};
  var mult = size.mult || 1;
  var patients = size.patients || 7500;
  var pathEpisodesPerDay = size.pathEpisodesPerDay || 65;
  var pathResultsPerDay = size.pathResultsPerDay || 290;
  var docsPerDay = size.docsPerDay || 145;
  var gpsHeadcount = size.gpsHeadcount || 4;
  var clinicalUsers = (answers.clinical_users && answers.clinical_users.users) || 5;
  var modules = [];
  var totalAdminHoursWeek = 0, totalGPHoursWeek = 0, totalApolloIQCost = 0;

  // PATHOLOGY
  var bS = (answers.path_backlog && answers.path_backlog.score) || 0;
  var oS = (answers.path_overtime && answers.path_overtime.score) || 0;
  var aS = (answers.path_abnormal && answers.path_abnormal.score) || 0;
  if (bS + oS + aS > 0) {
    var gpOT = oS === 0 ? 0 : oS === 2 ? 2 : oS === 3 ? 5 : 8;
    var adm = bS >= 2 ? Math.round(pathResultsPerDay * 5 * 0.02 * 10) / 10 : 0;
    totalGPHoursWeek += gpOT; totalAdminHoursWeek += adm;
    var cur = Math.round((adm * HOURLY_RATE_ADMIN + gpOT * HOURLY_RATE_GP) * WEEKS_PER_YEAR);
    var aiq = Math.round(patients * PRICING.pathology.perPatientYear); totalApolloIQCost += aiq;
    var f = [];
    if (oS >= 3) f.push("GPs are regularly staying late to process results \u2014 a key driver of burnout and retention risk.");
    else if (oS === 2) f.push("GPs are occasionally working overtime to clear results.");
    if (bS >= 2) f.push("With ~" + pathEpisodesPerDay + " blood draws arriving daily (generating ~" + pathResultsPerDay + " individual results), backlogs build quickly when workload peaks.");
    if (aS >= 4) f.push("There's real concern about abnormal results being missed in a large queue \u2014 this is a clinical safety risk.");
    else if (aS >= 2) f.push("Confidence in catching abnormals depends on workload \u2014 busy days create risk.");
    modules.push({ name: MODULE_MAP.pathology.name, key: "pathology", color: MODULE_MAP.pathology.color, description: MODULE_MAP.pathology.description, adminHours: adm, gpHours: gpOT, currentCost: cur, apolloiqCost: aiq, netROI: cur - aiq, severity: bS + oS + aS, dailyVolume: pathEpisodesPerDay + " episodes \u2192 " + pathResultsPerDay + " results", pricingLabel: "\u00A30.30 \u00D7 " + patients.toLocaleString() + " patients = \u00A3" + aiq.toLocaleString() + "/year", benchmark: "National average: ~65 blood draw episodes/day for a 10K practice, each generating 4\u20135 results. Up to 27-fold variation in ordering rates between practices.", findings: f });
  }

  // DOCUMENTS
  var sS = (answers.doc_sorting && answers.doc_sorting.score) || 0;
  var bnS = (answers.doc_bottleneck && answers.doc_bottleneck.score) || 0;
  if (sS + bnS > 0) {
    var mpd = sS >= 3 ? 2 : sS === 2 ? 1.5 : sS === 1 ? 0.5 : 0;
    var adm2 = Math.round(docsPerDay * 5 * mpd / 60 * 10) / 10; totalAdminHoursWeek += adm2;
    var cur2 = Math.round(adm2 * HOURLY_RATE_ADMIN * WEEKS_PER_YEAR);
    var aiq2 = Math.round(patients * PRICING.documents.perPatientYear); totalApolloIQCost += aiq2;
    var f2 = [];
    if (sS >= 3) f2.push("Admin staff are manually reading and routing ~" + docsPerDay + " documents per day \u2014 that's ~" + Math.round(docsPerDay * 250).toLocaleString() + " per year.");
    else if (sS === 2) f2.push("You're using a tool but still manually sorting most documents.");
    if (bnS >= 3) f2.push("Documents are frequently piling up, creating delays in clinical correspondence reaching the right clinician.");
    modules.push({ name: MODULE_MAP.documents.name, key: "documents", color: MODULE_MAP.documents.color, description: MODULE_MAP.documents.description, adminHours: adm2, gpHours: 0, currentCost: cur2, apolloiqCost: aiq2, netROI: cur2 - aiq2, severity: sS + bnS, dailyVolume: docsPerDay + " docs", pricingLabel: "\u00A30.30 \u00D7 " + patients.toLocaleString() + " patients = \u00A3" + aiq2.toLocaleString() + "/year", benchmark: "National average: ~145 documents/day for a 10K practice (~36,000/year). Includes clinic letters, discharge summaries, lab results, and admin correspondence.", findings: f2 });
  }

  // SCRIBECRAFT
  var scS = (answers.scribe_current && answers.scribe_current.score) || 0;
  var ahS = (answers.scribe_afterhours && answers.scribe_afterhours.score) || 0;
  var ahM = (answers.scribe_afterhours && answers.scribe_afterhours.minsPerGPPerDay) || 0;
  if (scS + ahS > 0) {
    var gpAfterHrsWk = Math.round(ahM * gpsHeadcount * 5 / 60 * 10) / 10;
    var inSessionMins = scS >= 2 ? 30 : scS === 1 ? 15 : 0;
    var inSessionHrsWk = Math.round(inSessionMins * gpsHeadcount * 5 / 60 * 10) / 10;
    totalGPHoursWeek += gpAfterHrsWk;
    var totalScribeHrs = gpAfterHrsWk + inSessionHrsWk;
    var cur3 = Math.round(totalScribeHrs * HOURLY_RATE_GP * WEEKS_PER_YEAR);
    var scribeUsers = Math.max(gpsHeadcount, Math.round(clinicalUsers * 0.7));
    var aiq3 = Math.round(scribeUsers * PRICING.scribecraft.perUserMonth * 12); totalApolloIQCost += aiq3;
    var f3 = [];
    if (scS >= 3) f3.push("Your GPs are typing all consultation notes manually. Research shows GPs spend ~14% of session time on documentation \u2014 that's over an hour per GP per day just typing.");
    else if (scS === 2) f3.push("Templates help, but your GPs are still writing most free-text notes manually \u2014 the most time-consuming part of documentation.");
    else if (scS === 1) f3.push("Dictation is faster than typing but still requires significant editing time. AI scribes go further by structuring and coding notes automatically.");
    if (ahM >= 45) f3.push("GPs are spending " + Math.round(ahM) + " minutes per day writing up notes outside appointments \u2014 that's " + Math.round(ahM * gpsHeadcount * WORKING_DAYS_YEAR / 60).toLocaleString() + " hours of unpaid GP time per year across your practice.");
    else if (ahM >= 20) f3.push(Math.round(ahM) + " minutes per GP per day on after-hours notes adds up to " + Math.round(ahM * gpsHeadcount * WORKING_DAYS_YEAR / 60).toLocaleString() + " hours of GP time per year.");
    modules.push({ name: MODULE_MAP.scribecraft.name, key: "scribecraft", color: MODULE_MAP.scribecraft.color, description: MODULE_MAP.scribecraft.description, adminHours: 0, gpHours: gpAfterHrsWk, gpInSessionHours: inSessionHrsWk, currentCost: cur3, apolloiqCost: aiq3, netROI: cur3 - aiq3, severity: scS + ahS, dailyVolume: Math.round(gpsHeadcount * 28) + " consultations", pricingLabel: "\u00A316.99/user/month \u00D7 " + scribeUsers + " users \u00D7 12 = \u00A3" + aiq3.toLocaleString() + "/year", benchmark: "NHS research: GPs spend ~14% of session time on documentation (Sinnott et al., BJGP 2022). The GOSH-led 9-site NHS pilot (17,000 encounters) showed a 51.7% reduction in documentation time and 23.5% more time with patients.", findings: f3 });
  }

  // BP \u2014 enhanced with clinical risk
  var bpS = (answers.bp_process && answers.bp_process.score) || 0;
  var bpH = ((answers.bp_process && answers.bp_process.hours) || 0) * mult;
  var bpErrS = (answers.bp_errors && answers.bp_errors.score) || 0;
  var htC = (answers.bp_register && answers.bp_register.htCount) || 1550;
  var bpE = (answers.bp_register && answers.bp_register.bpEpisodes) || 3600;
  var bpTotal = bpS + bpErrS;
  if (bpTotal > 0) {
    totalAdminHoursWeek += bpH;
    var cur4 = Math.round(bpH * HOURLY_RATE_ADMIN * WEEKS_PER_YEAR);
    var aiq4 = Math.round(clinicalUsers * PRICING.bp.perUserMonth * 12); totalApolloIQCost += aiq4;
    var errorRate = bpS >= 3 ? 0.03 : bpS === 2 ? 0.02 : 0.01;
    var episodesAtRisk = Math.round(bpE * errorRate);
    var treatmentDecisionsAtRisk = Math.round(episodesAtRisk * 0.3);
    var f4 = [];
    if (bpS >= 3) f4.push("BP readings are handled manually or inconsistently \u2014 creating real risk of calculation errors that affect treatment decisions.");
    else if (bpS === 2) f4.push("You're using a workaround that still requires manual calculation and data entry \u2014 every manual step is an opportunity for error.");
    if (bpErrS >= 5) f4.push("You've confirmed that a BP averaging error has already affected a clinical decision. With manual processes, there's no audit trail to know how often this happens silently.");
    else if (bpErrS >= 3) f4.push("You've caught errors before they reached patients \u2014 but how many weren't caught? Manual averaging has no built-in safety net.");
    else if (bpErrS >= 2) f4.push("You'd have no way of knowing if errors have occurred \u2014 and with manual calculation, that uncertainty is itself a clinical risk.");
    f4.push("With ~" + htC.toLocaleString() + " patients on your HTN register generating ~" + bpE.toLocaleString() + " BP episodes per year, even a small error rate means ~" + episodesAtRisk + " readings per year could be wrong \u2014 and ~" + treatmentDecisionsAtRisk + " of those could cross the NICE NG136 treatment threshold of 140/90 (clinic) or 135/85 (HBPM), leading to incorrect prescribing decisions.");
    var clinicalRiskLabel = bpErrS >= 3 ? "Confirmed clinical safety concern" : bpErrS >= 2 ? "Unquantified clinical risk" : bpS >= 3 ? "Manual process \u2014 error risk present" : null;
    var clinicalRiskSevere = bpErrS >= 3;
    modules.push({ name: MODULE_MAP.bp.name, key: "bp", color: MODULE_MAP.bp.color, description: MODULE_MAP.bp.description, adminHours: bpH, gpHours: 0, currentCost: cur4, apolloiqCost: aiq4, netROI: cur4 - aiq4, severity: bpTotal, dailyVolume: Math.round(bpE / 250) + "/day", pricingLabel: "\u00A310/user/month \u00D7 " + clinicalUsers + " users \u00D7 12 = \u00A3" + aiq4.toLocaleString() + "/year", benchmark: "National average: ~1,550 patients on the HTN register per practice, generating ~3,600 BP episodes/year. NICE NG136 treatment thresholds sit at 140/90 (clinic) and 135/85 (HBPM/ABPM) \u2014 a 2\u20133 mmHg averaging error can cross these thresholds and change a treatment decision. QOF 2025/26 raised CVD upper thresholds to 85\u201390%, increasing monitoring volumes further.", findings: f4, clinicalRiskLabel: clinicalRiskLabel, clinicalRiskSevere: clinicalRiskSevere });
  }

  // PRESCRIPTIONS
  var rxC = (answers.rx_pharmacy_calls && answers.rx_pharmacy_calls.callsPerDay) || 0;
  var rxCS = (answers.rx_pharmacy_calls && answers.rx_pharmacy_calls.score) || 0;
  var rxSH = ((answers.rx_search_time && answers.rx_search_time.hours) || 0) * mult;
  var rxInt = Math.round(rxC * 5 * 8 / 60 * 10) / 10;
  var totRx = rxSH + rxInt;
  if (totRx > 0.5) {
    totalAdminHoursWeek += totRx;
    var cur5 = Math.round(totRx * HOURLY_RATE_ADMIN * WEEKS_PER_YEAR);
    var aiq5 = Math.round(clinicalUsers * PRICING.prescriptions.perUserMonth * 12); totalApolloIQCost += aiq5;
    var f5 = [];
    if (rxC >= 4) f5.push("Your practice receives ~" + Math.round(rxC) + " pharmacy calls per day about stock shortages \u2014 ~" + Math.round(rxC * 250) + " interruptions per year, each taking ~8 minutes to resolve.");
    else if (rxC >= 1) f5.push("Even at " + Math.round(rxC) + " shortage calls/day, that's ~" + Math.round(rxC * 250) + " unplanned contacts per year disrupting workflow.");
    if (rxSH > 3) f5.push("Over 3 hours per week lost to manual searching for medication availability on top of incoming pharmacy calls.");
    else if (rxSH > 0.5) f5.push("Staff time is being spent chasing stock that could be answered with an instant lookup.");
    modules.push({ name: MODULE_MAP.prescriptions.name, key: "prescriptions", color: MODULE_MAP.prescriptions.color, description: MODULE_MAP.prescriptions.description, adminHours: totRx, gpHours: 0, currentCost: cur5, apolloiqCost: aiq5, netROI: cur5 - aiq5, severity: rxCS >= 3 ? 3 : totRx > 4 ? 3 : 2, dailyVolume: rxC >= 1 ? Math.round(rxC) + " shortage calls" : null, pricingLabel: "\u00A313/user/month \u00D7 " + clinicalUsers + " users \u00D7 12 = \u00A3" + aiq5.toLocaleString() + "/year", benchmark: "National context: 60% of pharmacies contact GP practices daily about shortages (CPE 2024). 94% of GPs report increased workload from medicine supply disruptions.", findings: f5 });
  }

  return { modules: modules, totalAdminHoursWeek: totalAdminHoursWeek, totalGPHoursWeek: totalGPHoursWeek, totalCurrentCost: modules.reduce(function(s, m) { return s + m.currentCost; }, 0), totalApolloIQCost: totalApolloIQCost, totalNetROI: modules.reduce(function(s, m) { return s + (m.netROI || 0); }, 0), vendorPains: (answers.vendor_pain && answers.vendor_pain.options) || [], vendorCount: answers.vendor_count && answers.vendor_count.value, clinicalUsers: clinicalUsers, patients: patients };
}

// ─── RESULTS ─────────────────────────────────────────
function renderResults() {
  if (resultTimer) clearInterval(resultTimer);
  resultStep = 0;
  var R = calculateResults();
  var totalWeeklyHrs = Math.round((R.totalAdminHoursWeek + R.totalGPHoursWeek) * 10) / 10;
  var positiveROI = R.totalNetROI > 0;
  var platformMsg = R.vendorCount === "none"
    ? "Your practice is running entirely on manual processes. A single platform can automate everything \u2014 one contract, one IG assessment, one support team."
    : R.vendorCount === "many" || R.vendorCount === "several"
    ? "You're managing " + (R.vendorCount === "many" ? "5+" : "3\u20134") + " separate tools. That's multiple vendor contracts, staff training sets, and IG assessments. A single platform replaces the lot."
    : "You have a couple of tools but gaps remain. A unified platform fills every gap without adding another vendor.";

  var html = '<div class="au-card">\
    <div class="au-hdr" style="text-align:center;padding:32px">\
      <div class="au-hdr-sub">Your Results</div>\
      <div style="font-size:24px;font-weight:800">Practice Efficiency Report</div>\
      <div style="font-size:12px;opacity:0.6;margin-top:4px">' + R.patients.toLocaleString() + ' patients \u00B7 ' + R.clinicalUsers + ' clinical users</div>\
    </div>\
    <div class="au-body">\
      <div class="au-stats-row au-reveal" data-step="1">\
        <div class="au-stat-box au-stat-box--red">\
          <div class="au-stat-value">' + totalWeeklyHrs + '</div>\
          <div class="au-stat-label">hrs lost / week</div>' +
          (R.totalGPHoursWeek > 0 ? '<div class="au-stat-detail">incl. ' + R.totalGPHoursWeek + ' GP overtime</div>' : '') +
        '</div>\
        <div class="au-stat-box au-stat-box--amber">\
          <div class="au-stat-value">\u00A3' + R.totalCurrentCost.toLocaleString() + '</div>\
          <div class="au-stat-label">current annual cost</div>\
          <div class="au-stat-detail">admin + GP time combined</div>\
        </div>\
        <div class="au-stat-box ' + (positiveROI ? 'au-stat-box--green' : 'au-stat-box--blue') + '">\
          <div class="au-stat-value">' + (positiveROI ? '\u00A3' + R.totalNetROI.toLocaleString() : '\u00A3' + R.totalApolloIQCost.toLocaleString()) + '</div>\
          <div class="au-stat-label">' + (positiveROI ? 'net annual saving' : 'ApolloIQ annual cost') + '</div>\
          <div class="au-stat-detail">' + (positiveROI ? 'after \u00A3' + R.totalApolloIQCost.toLocaleString() + ' platform cost' : 'vs \u00A3' + R.totalCurrentCost.toLocaleString() + ' current cost') + '</div>\
        </div>\
      </div>';

  // Vendor pains
  if (R.vendorPains.length > 0) {
    html += '<div class="au-vendor-pains au-reveal" data-step="1">\
      <div style="font-size:12px;font-weight:700;color:#92400E;margin-bottom:6px">You told us these frustrate you:</div>';
    R.vendorPains.forEach(function(p) {
      html += '<div style="display:flex;gap:8px;align-items:center;margin-bottom:3px;font-size:12px;color:#78350F"><span style="color:#D97706">\u2715</span> ' + (painLabels[p] || p) + '</div>';
    });
    html += '</div>';
  }

  // Module breakdown
  html += '<div class="au-reveal" data-step="2">\
    <div class="au-section-label" style="margin-bottom:14px">Module-by-Module Breakdown</div>';

  R.modules.forEach(function(mod, i) {
    html += '<div class="au-module au-reveal" data-step="' + (2) + '" style="border-left-color:' + mod.color + '">\
      <div class="au-module-top">\
        <div class="au-module-name">' + moduleIcon(mod.key, 28) + '<span style="font-size:15px;font-weight:700;color:#191d21">' + mod.name + '</span></div>\
        <div class="au-module-stats">' +
          (mod.dailyVolume ? '<div style="font-size:12px;color:#667085">~' + mod.dailyVolume + '/day</div>' : '') +
          (mod.adminHours != null && mod.adminHours > 0 ? '<div style="font-size:12px;font-weight:600;color:' + mod.color + '">' + mod.adminHours + ' admin hrs/wk</div>' : '') +
          (mod.gpHours != null && mod.gpHours > 0 ? '<div style="font-size:12px;font-weight:600;color:#e74c6f">' + mod.gpHours + ' GP hrs/wk overtime</div>' : '') +
          (mod.gpInSessionHours != null && mod.gpInSessionHours > 0 ? '<div style="font-size:12px;font-weight:600;color:#10a5b3">' + mod.gpInSessionHours + ' GP hrs/wk reclaimable</div>' : '') +
        '</div>\
      </div>';

    // Clinical risk label for BP
    if (mod.clinicalRiskLabel) {
      html += '<div class="au-risk-badge ' + (mod.clinicalRiskSevere ? 'au-risk-badge--severe' : 'au-risk-badge--warn') + '">' + (mod.clinicalRiskSevere ? '\u26D4' : '\u26A0\uFE0F') + ' ' + mod.clinicalRiskLabel + '</div>';
    }

    // ROI pill
    var pos = mod.netROI > 0;
    html += '<div class="au-roi-pills">\
      <div class="au-roi-pill au-roi-pill--red">Current: \u00A3' + mod.currentCost.toLocaleString() + '/yr</div>\
      <span class="au-roi-arrow">\u2192</span>\
      <div class="au-roi-pill au-roi-pill--blue">ApolloIQ: \u00A3' + mod.apolloiqCost.toLocaleString() + '/yr</div>\
      <span class="au-roi-arrow">=</span>\
      <div class="au-roi-pill ' + (pos ? 'au-roi-pill--green' : 'au-roi-pill--amber') + '">' + (pos ? '\u2713 Save \u00A3' + mod.netROI.toLocaleString() + '/yr' : '+\u00A3' + Math.abs(mod.netROI).toLocaleString() + '/yr net cost') + '</div>\
    </div>';

    html += '<div style="font-size:11px;color:#667085;margin-bottom:8px;font-style:italic">' + mod.pricingLabel + '</div>';

    mod.findings.forEach(function(finding) {
      html += '<div class="au-finding">\u26A0\uFE0F ' + finding + '</div>';
    });

    if (mod.benchmark) {
      html += '<div class="au-benchmark"><strong style="color:#344054">Benchmark:</strong> ' + mod.benchmark + '</div>';
    }

    html += '<div class="au-solution"><strong style="color:' + mod.color + '">Merlin solves this \u2192</strong> ' + mod.description + '</div>\
    </div>';
  });

  html += '</div>';

  // Total ROI summary
  html += '<div class="au-roi-summary ' + (positiveROI ? 'au-roi-summary--green' : 'au-roi-summary--blue') + ' au-reveal" data-step="5">\
    <div style="font-size:15px;font-weight:700;color:' + (positiveROI ? '#065F46' : '#1E40AF') + ';margin-bottom:10px">' + (positiveROI ? 'Your Total ROI' : 'Your Cost Summary') + '</div>\
    <div class="au-roi-grid">\
      <div style="text-align:center"><div style="font-size:11px;font-weight:600;color:#667085;margin-bottom:2px">Current cost</div><div style="font-size:20px;font-weight:800;color:#e74c6f">\u00A3' + R.totalCurrentCost.toLocaleString() + '</div><div style="font-size:10px;color:#98a2b3">per year</div></div>\
      <div style="font-size:16px;color:#98a2b3">\u2212</div>\
      <div style="text-align:center"><div style="font-size:11px;font-weight:600;color:#667085;margin-bottom:2px">ApolloIQ cost</div><div style="font-size:20px;font-weight:800;color:#2c70eb">\u00A3' + R.totalApolloIQCost.toLocaleString() + '</div><div style="font-size:10px;color:#98a2b3">per year (Org tier)</div></div>\
      <div style="font-size:16px;color:#98a2b3">=</div>\
      <div style="text-align:center"><div style="font-size:11px;font-weight:600;color:#667085;margin-bottom:2px">' + (positiveROI ? 'Net saving' : 'Net cost') + '</div><div style="font-size:20px;font-weight:800;color:' + (positiveROI ? '#00c393' : '#D97706') + '">' + (positiveROI ? '\u00A3' + R.totalNetROI.toLocaleString() : '\u00A3' + Math.abs(R.totalNetROI).toLocaleString()) + '</div><div style="font-size:10px;color:#98a2b3">per year</div></div>\
    </div>';
  if (positiveROI) {
    html += '<div style="font-size:12px;color:#065F46;margin-top:10px;line-height:1.5">That\u2019s a <strong>' + Math.round((R.totalNetROI / R.totalApolloIQCost) * 100) + '% return</strong> on your ApolloIQ investment \u2014 before you factor in reduced clinical risk from BP and pathology automation, GP retention, and QOF performance improvements.</div>';
  } else {
    html += '<div style="font-size:12px;color:#667085;margin-top:10px;line-height:1.5">The financial case is close \u2014 but this ROI doesn\u2019t capture the value of reduced clinical risk (especially BP averaging errors affecting treatment decisions), GP retention, and reclaimed clinician time.</div>';
  }
  html += '</div>';

  // Platform argument
  html += '<div class="au-platform au-reveal" data-step="6">\
    <div style="font-size:15px;font-weight:700;margin-bottom:10px">Why One Platform Beats ' + (R.vendorCount === "none" ? "Doing It All Manually" : "Multiple Vendors") + '</div>\
    <p style="font-size:13px;line-height:1.6;opacity:0.9;margin:0 0 14px">' + platformMsg + '</p>\
    <div class="au-platform-label">Merlin replaces all of that with:</div>';
  ["One platform \u2014 pathology, documents, AI scribe, BP automation, and medication search",
   "One vendor contract, one IG assessment, one support team",
   "One dashboard showing everything processed \u2014 and everything outstanding",
   "DCB0129 clinical safety certification across every workflow",
   "Transparent pricing \u2014 per-patient for workflows, per-user for spells, no hidden costs"
  ].forEach(function(pt) {
    html += '<div class="au-platform-item"><span style="color:#00c393">\u2713</span> ' + pt + '</div>';
  });
  html += '</div>';

  // Data sources
  html += '<div class="au-data-sources au-reveal" data-step="7">\
    <div style="font-size:11px;font-weight:700;color:#667085;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.06em">Data Sources & Methodology</div>\
    <div style="font-size:11px;color:#98a2b3;line-height:1.6">Benchmarks: NHS Transformation Directorate; O\u2019Sullivan et al. BMC Medicine 2018; Sinnott et al. BJGP 2022 (GP documentation time); GOSH-led 9-site NHS AI scribe pilot (17,000 encounters, July 2025); Docman/OneAdvanced (~6,000 practices); NHS Digital QOF 2024\u201325; CPE Medicines Supply Report 2024; NICE NG136 (hypertension thresholds); IfG Performance Tracker 2025. Rates: AfC Band 3 top (\u00A314.50/hr), GP sessional mid-range (\u00A385/hr). ApolloIQ pricing: Organisation tier from apolloiq.co.uk/pricing (March 2026). BP error rate estimates are conservative modelling \u2014 actual error rates in your practice may differ. All figures are estimates \u2014 a full on-site audit uses your real data.</div>\
  </div>';

  // CTA
  html += '<div style="margin-top:24px;text-align:center" class="au-reveal" data-step="8">\
    <p style="font-size:13px;color:#667085;line-height:1.6;margin-bottom:14px">These are estimates based on national averages and your answers. Want the exact numbers using your practice\u2019s real data?</p>\
    <a href="' + base + 'contact-us" class="au-primary" style="display:inline-block;text-decoration:none;text-align:center;font-size:15px;padding:14px 28px">Book a Free Efficiency Review Call</a>\
    <div style="font-size:11px;color:#98a2b3;margin-top:8px">No commitment \u00B7 1 hour online \u00B7 Full report with your actual numbers and ROI</div>\
    <button class="au-back-btn" style="margin-top:14px;color:#2c70eb" id="au-restart">\u2190 Retake audit</button>\
  </div>';

  html += '</div></div>';
  app.innerHTML = html;

  // Animate results in
  resultTimer = setInterval(function() {
    resultStep++;
    if (resultStep > 12) { clearInterval(resultTimer); resultTimer = null; return; }
    document.querySelectorAll('.au-reveal').forEach(function(el) {
      var step = parseInt(el.dataset.step, 10);
      if (step <= resultStep) el.classList.add('au-revealed');
    });
  }, 280);
  // Reveal step 1 immediately
  setTimeout(function() {
    resultStep = 1;
    document.querySelectorAll('.au-reveal[data-step="1"]').forEach(function(el) {
      el.classList.add('au-revealed');
    });
  }, 50);

  document.getElementById("au-restart").addEventListener("click", function() {
    if (resultTimer) { clearInterval(resultTimer); resultTimer = null; }
    phase = "start"; currentQ = 0; answers = {}; multiSelect = []; resultStep = 0;
    render();
  });
}

// ─── INIT ────────────────────────────────────────────
render();
</script>

