---
const base = import.meta.env.BASE_URL;
---

<section class="section cta-section">
  <div class="container-site">
    <div class="cta-wrapper">
      <div class="cta-content">
        <div class="cta-heading-area">
          <h2 class="cta-title">Get in <span class="text-gradient">Touch</span></h2>
        </div>
        <div class="cta-body">
          <div class="cta-form-wrap">
            <form class="cta-form" id="cta-form" action="#" method="POST">
              <input
                class="form-field"
                type="text"
                name="name"
                placeholder="Name/Business*"
                required
                autocomplete="organization"
              />
              <input
                class="form-field"
                type="email"
                name="email"
                placeholder="Email*"
                required
                autocomplete="email"
              />
              <textarea
                class="form-field form-textarea"
                name="message"
                placeholder="Write your message here...*"
                required
                rows="4"
              ></textarea>
              <button type="submit" class="btn-primary cta-submit">Submit</button>
              <label class="cta-consent">
                <input type="checkbox" name="consent" class="cta-checkbox" />
                <span class="cta-consent-text">I consent to receive updates on events, digital marketing and business.</span>
              </label>
            </form>
            <div class="cta-success" id="cta-success" hidden>
              <div class="success-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="24" fill="var(--color-brand-green)"/>
                  <path d="M16 24L22 30L32 18" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Thank you!</h3>
              <p>Your submission has been received. We'll get back to you soon.</p>
            </div>
          </div>
          <div class="cta-info">
            <p class="cta-info-text">
              Feel free to contact us with any queries, or questions that you have.
              One of our team will be in touch as soon as we can!
            </p>
            <p class="cta-info-text">
              Alternatively, if you prefer to contact us directly, you can email us at:
              <a href="mailto:contact@apolloiq.co.uk" class="cta-email-link">contact@apolloiq.co.uk</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 5rem 0;
  }

  .cta-wrapper {
    background-image: url('/apolloiq-website-preview/images/685dc40ff887e05cecfae31f_Background4.png');
    background-position: center;
    background-size: cover;
    border-radius: var(--radius-card);
    padding: 3rem;
    box-shadow: var(--shadow-card-lg);
    border: 1px solid rgba(44, 112, 235, 0.08);
  }

  .cta-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .cta-body {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap-reverse;
  }

  .cta-form-wrap {
    flex: 1;
    min-width: 280px;
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .cta-submit {
    margin-top: 0.25rem;
    width: fit-content;
  }

  .cta-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-top: 0.25rem;
    cursor: pointer;
  }

  .cta-checkbox {
    margin-top: 3px;
    flex-shrink: 0;
    accent-color: var(--color-brand-blue);
  }

  .cta-consent-text {
    font-size: 0.75rem;
    color: var(--color-brand-grey-muted);
    line-height: 1.5;
  }

  .cta-info {
    flex: 1;
    min-width: 250px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    justify-content: center;
  }

  .cta-info-text {
    font-size: 1rem;
    color: var(--color-brand-grey);
    line-height: 1.7;
  }

  .cta-email-link {
    color: var(--color-brand-blue);
    font-weight: 500;
    transition: color 0.2s;
  }
  .cta-email-link:hover {
    color: var(--color-brand-blue-dark);
  }

  .cta-success {
    text-align: center;
    padding: 3rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .cta-success h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-black);
  }
  .cta-success p {
    font-size: 1rem;
    color: var(--color-brand-grey);
  }

  @media (max-width: 768px) {
    .cta-wrapper {
      padding: 2rem 1.5rem;
    }
    .cta-title {
      font-size: 2.25rem;
    }
    .cta-body {
      gap: 2rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('cta-form');
    const success = document.getElementById('cta-success');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('.cta-submit');
      btn.textContent = 'Sending...';
      btn.disabled = true;

      var fd = new FormData(form);
      var data = { type: 'contact', name: fd.get('name'), email: fd.get('email'), message: fd.get('message'), consent: fd.get('consent') ? 'yes' : 'no', _source: 'CTA Section' };
      fetch('https://script.google.com/macros/s/AKfycbyxiagGQW6AIdiR8o8o0u4c0ET1I70injnp9ExqGWvFYHj6ucqSlPOe-ijPuewWToFZMw/exec', { method: 'POST', headers: { 'Content-Type': 'text/plain' }, body: JSON.stringify(data) }).catch(function(){});

      form.style.display = 'none';
      success.hidden = false;
    });
  });
</script>
